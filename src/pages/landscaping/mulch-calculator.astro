---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/landscapingTools';

const tool = getToolBySlug('mulch-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much mulch do I need?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Measure the area in square feet, then decide on depth (2-3 inches is standard). Use the formula: (Area x Depth in inches) / 12 / 27 = cubic yards. For example, 500 sq ft at 3 inches deep needs about 4.6 cubic yards. Add 5-10% for waste."
      }
    },
    {
      "@type": "Question",
      "name": "How many cubic yards of mulch do I need for 1,000 square feet?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "At 2 inches deep, 1,000 sq ft needs about 6.2 cubic yards. At 3 inches deep, you need about 9.3 cubic yards. At 4 inches, about 12.3 cubic yards. Always add 5% for waste and settling."
      }
    },
    {
      "@type": "Question",
      "name": "What is the recommended mulch depth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For most landscaping beds, 2-3 inches is the recommended depth. This provides adequate weed suppression and moisture retention without suffocating plant roots. Never exceed 4 inches, as too-deep mulch can cause bark rot and create habitat for pests."
      }
    },
    {
      "@type": "Question",
      "name": "How many bags of mulch are in a cubic yard?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A standard bag of mulch is 2 cubic feet. One cubic yard equals 27 cubic feet, so you need 13.5 bags per cubic yard. Most pros order bulk mulch by the cubic yard for jobs over 3 yards — it is significantly cheaper than bagged."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="mulch-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="calcMethod">Measurement Method</label>
        <select id="calcMethod" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="area">Enter Total Area (sq ft)</option>
          <option value="lw">Enter Length x Width</option>
        </select>
      </div>
      <div id="area-input">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="area">Bed Area (sq ft)</label>
        <input type="number" id="area" value="500" min="1" max="100000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div id="length-input" class="hidden">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="length">Length (ft)</label>
        <input type="number" id="length" value="25" min="1" max="10000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div id="width-input" class="hidden">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="width">Width (ft)</label>
        <input type="number" id="width" value="20" min="1" max="10000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="depth">Mulch Depth (inches)</label>
        <select id="depth" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1">1 inch</option>
          <option value="1.5">1.5 inches</option>
          <option value="2">2 inches</option>
          <option value="2.5">2.5 inches</option>
          <option value="3" selected>3 inches (recommended)</option>
          <option value="4">4 inches</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="waste">Waste / Buffer (%)</label>
        <select id="waste" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="0">0% — No waste</option>
          <option value="5" selected>5% — Standard buffer</option>
          <option value="10">10% — Curved edges / cuts</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="costPerYard">Mulch Cost per Cubic Yard ($)</label>
        <input type="number" id="costPerYard" value="35" min="0" max="200" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Leave at 0 to skip cost estimate</p>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cubic Yards</div>
          <div id="result-yards" class="font-heading font-extrabold text-3xl text-accent">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cubic Feet</div>
          <div id="result-cuft" class="font-heading font-extrabold text-3xl text-text-primary">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">2 cu ft Bags</div>
          <div id="result-bags" class="font-heading font-extrabold text-3xl text-text-primary">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Est. Cost</div>
          <div id="result-cost" class="font-heading font-extrabold text-3xl text-text-primary">—</div>
        </div>
      </div>

      <!-- Coverage Reference -->
      <div class="bg-bg-dark rounded-xl p-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Coverage Reference (per cubic yard)</h4>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
          <div><span class="text-text-muted">1" depth:</span> <span class="text-text-primary font-semibold">324 sq ft</span></div>
          <div><span class="text-text-muted">2" depth:</span> <span class="text-text-primary font-semibold">162 sq ft</span></div>
          <div><span class="text-text-muted">3" depth:</span> <span class="text-text-primary font-semibold">108 sq ft</span></div>
          <div><span class="text-text-muted">4" depth:</span> <span class="text-text-primary font-semibold">81 sq ft</span></div>
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Choose your measurement method.</strong> Enter the total bed area in square feet, or enter length and width separately if the bed is rectangular.</p>
          <p><strong class="text-text-primary">2. Select mulch depth.</strong> 2-3 inches is the recommended depth for most beds. Use 3 inches for new beds and 2 inches for annual top-dressing.</p>
          <p><strong class="text-text-primary">3. Set a waste buffer.</strong> Use 5% for rectangular beds and 10% for beds with curved edges or irregular shapes.</p>
          <p><strong class="text-text-primary">4. Enter mulch cost (optional).</strong> Enter your bulk price per cubic yard to get a material cost estimate for the job.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Mulch Formula Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>The calculator uses the standard cubic volume formula used across the landscaping industry:</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Volume (cubic feet) = Area (sq ft) x Depth (inches) / 12</p>
            <p>Volume (cubic yards) = Cubic Feet / 27</p>
            <p>With Waste = Cubic Yards x (1 + Waste% / 100)</p>
          </div>
          <p>One cubic yard equals 27 cubic feet. At 3 inches deep, one cubic yard covers 108 square feet. The waste buffer accounts for settling, uneven edges, and areas where you need slightly more depth to maintain a consistent look.</p>
          <p>Bag count is calculated at 2 cubic feet per bag (standard retail mulch bag). For jobs over 3 cubic yards, bulk delivery is significantly more cost-effective than bagged mulch.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When Landscape Pros Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Building estimates on site.</strong> Walk the property, measure the beds, and plug in the numbers right on your phone. Give the customer an accurate quote for materials before you leave.</p>
          <p><strong class="text-text-primary">Ordering bulk materials.</strong> Before calling the mulch supplier, run the numbers for every bed on the property. Add them up and order one delivery instead of guessing and paying for a second trip.</p>
          <p><strong class="text-text-primary">Annual refreshes.</strong> For maintenance customers who need mulch topped off each spring, reduce the depth to 1-2 inches and recalculate. This gives you the refresh quantity without over-mulching.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much mulch do I need?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Measure the area in square feet, then decide on depth (2-3 inches is standard). Use the formula: (Area x Depth in inches) / 12 / 27 = cubic yards. For example, 500 sq ft at 3 inches deep needs about 4.6 cubic yards. Add 5-10% for waste.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many cubic yards of mulch do I need for 1,000 square feet?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">At 2 inches deep, 1,000 sq ft needs about 6.2 cubic yards. At 3 inches deep, you need about 9.3 cubic yards. At 4 inches, about 12.3 cubic yards. Always add 5% for waste and settling.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is the recommended mulch depth?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For most landscaping beds, 2-3 inches is the recommended depth. This provides adequate weed suppression and moisture retention without suffocating plant roots. Never exceed 4 inches, as too-deep mulch can cause bark rot and create habitat for pests.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many bags of mulch are in a cubic yard?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A standard bag of mulch is 2 cubic feet. One cubic yard equals 27 cubic feet, so you need 13.5 bags per cubic yard. Most pros order bulk mulch by the cubic yard for jobs over 3 yards — it is significantly cheaper than bagged.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const method = (document.getElementById('calcMethod') as HTMLSelectElement).value;
    let area: number;

    if (method === 'lw') {
      const length = parseFloat((document.getElementById('length') as HTMLInputElement).value) || 0;
      const width = parseFloat((document.getElementById('width') as HTMLInputElement).value) || 0;
      area = length * width;
    } else {
      area = parseFloat((document.getElementById('area') as HTMLInputElement).value) || 0;
    }

    const depth = parseFloat((document.getElementById('depth') as HTMLSelectElement).value);
    const waste = parseFloat((document.getElementById('waste') as HTMLSelectElement).value);
    const costPerYard = parseFloat((document.getElementById('costPerYard') as HTMLInputElement).value) || 0;

    const cubicFeet = (area * depth) / 12;
    const cubicYards = cubicFeet / 27;
    const withWaste = cubicYards * (1 + waste / 100);
    const bags = Math.ceil((withWaste * 27) / 2);
    const cost = withWaste * costPerYard;

    document.getElementById('result-yards')!.textContent = withWaste.toFixed(1);
    document.getElementById('result-cuft')!.textContent = (withWaste * 27).toFixed(0);
    document.getElementById('result-bags')!.textContent = bags.toString();
    document.getElementById('result-cost')!.textContent = costPerYard > 0 ? '$' + cost.toFixed(0) : '—';
  }

  function toggleMethod() {
    const method = (document.getElementById('calcMethod') as HTMLSelectElement).value;
    document.getElementById('area-input')!.classList.toggle('hidden', method === 'lw');
    document.getElementById('length-input')!.classList.toggle('hidden', method !== 'lw');
    document.getElementById('width-input')!.classList.toggle('hidden', method !== 'lw');
    calculate();
  }

  document.getElementById('calcMethod')?.addEventListener('change', toggleMethod);
  document.querySelectorAll('#mulch-calc input, #mulch-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
