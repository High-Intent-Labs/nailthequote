---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/landscapingTools';

const tool = getToolBySlug('roi-estimator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the average ROI on landscaping projects?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "According to the National Association of Realtors and the National Association of Landscape Professionals, landscaping projects recover 100% to 150% of their cost on average at resale. Basic lawn care and maintenance can return 200-300%, garden beds and plantings return 100-200%, and hardscaping like patios and walkways returns 50-75%. The exact ROI depends on the project type, home value, local market conditions, and quality of the work."
      }
    },
    {
      "@type": "Question",
      "name": "How much does landscaping increase home value?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Professional landscaping typically increases home value by 5% to 15%. On a $400,000 home, that translates to $20,000 to $60,000 in added value. The biggest impact comes from a well-maintained lawn, mature trees, and a cohesive landscape design. First impressions matter most in real estate, and landscaping is the first thing buyers see. Homes with excellent curb appeal sell for 7% more on average than comparable homes with poor landscaping."
      }
    },
    {
      "@type": "Question",
      "name": "Which landscaping projects have the highest ROI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Basic lawn care and maintenance consistently delivers the highest ROI at 200-300% because it has the lowest cost relative to perceived value. Mature tree planting also performs well at 100-200% ROI, with each healthy mature tree adding $1,000 to $3,000 in property value. Garden beds and plantings return 100-200%. Full landscape redesigns return 100-150%. Hardscaping projects like patios return a lower percentage (50-75%) but can add substantial dollar value on higher-end homes."
      }
    },
    {
      "@type": "Question",
      "name": "How does curb appeal affect home sale price?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Curb appeal has a measurable impact on sale price. Homes with high curb appeal sell for 7% more on average according to multiple real estate studies. In a seller's market, the premium can reach 10-15% because buyers compete for move-in ready homes. Poor curb appeal can reduce offers by 5-10% or cause buyers to skip the listing entirely. Landscaping is the most cost-effective way to improve curb appeal because it covers the entire front-facing impression of the property."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="roi-calc">
    <!-- Two-column inputs -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <!-- Left Column: Project Details -->
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-1">Project Details</h3>
        <p class="text-text-muted text-xs mb-5">Select the type of work you're quoting</p>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="project-type">Project Type</label>
            <select id="project-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
              <option value="lawn">New Lawn / Lawn Renovation</option>
              <option value="garden-beds">Garden Beds &amp; Plantings</option>
              <option value="hardscaping" selected>Hardscaping (Patio, Walkway)</option>
              <option value="full-landscape">Full Landscape Redesign</option>
              <option value="trees">Mature Tree Planting</option>
              <option value="lighting">Outdoor Lighting</option>
              <option value="irrigation">Irrigation System</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="project-cost">Estimated Project Cost ($)</label>
            <input type="number" id="project-cost" value="12000" min="500" max="500000" step="500" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            <p class="text-text-muted text-xs mt-1">Enter the total you're quoting for the job</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="num-trees">Number of Trees (if applicable)</label>
            <input type="number" id="num-trees" value="0" min="0" max="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            <p class="text-text-muted text-xs mt-1">Each mature tree adds $1,000-$3,000 in value</p>
          </div>
        </div>
      </div>

      <!-- Right Column: Property Info -->
      <div class="bg-bg-card border border-border rounded-xl p-6" style="border-color: rgba(255,107,43,0.3);">
        <h3 class="font-heading font-bold text-lg text-accent mb-1">Property Information</h3>
        <p class="text-text-muted text-xs mb-5">Enter the customer's home details</p>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="home-value">Home's Current Estimated Value ($)</label>
            <input type="number" id="home-value" value="400000" min="50000" max="5000000" step="10000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            <p class="text-text-muted text-xs mt-1">Approximate market value before landscaping</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="home-condition">Current Landscape Condition</label>
            <select id="home-condition" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
              <option value="needs-work">Needs Work (overgrown, bare, neglected)</option>
              <option value="average" selected>Average (basic lawn, minimal plantings)</option>
              <option value="well-maintained">Well-Maintained (decent shape, some gaps)</option>
              <option value="high-end">High-End (already landscaped, upgrading)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="market-condition">Local Market Conditions</label>
            <select id="market-condition" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
              <option value="buyers">Buyer's Market (slower sales, price-sensitive)</option>
              <option value="balanced" selected>Balanced Market</option>
              <option value="sellers">Seller's Market (fast sales, competitive offers)</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <!-- Value increase summary cards -->
      <h3 class="font-heading font-bold text-xl mb-6">Estimated Return on Investment</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center border-2" style="border-color: rgba(255,107,43,0.4);">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Est. Value Increase</div>
          <div class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
            <span id="result-value-increase" class="font-heading font-extrabold text-3xl text-accent">--</span>
          </div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">ROI Percentage</div>
          <div id="result-roi-pct" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Net Gain / (Loss)</div>
          <div id="result-net-gain" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">New Home Value</div>
          <div id="result-new-home-value" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <!-- Visual bar chart comparison -->
      <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Investment vs. Value Added</h4>
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Project Cost</span>
              <span id="bar-cost-label" class="text-text-primary font-medium">--</span>
            </div>
            <div class="w-full bg-bg-dark rounded-full h-8 overflow-hidden">
              <div id="bar-cost" class="h-full rounded-full transition-all duration-700 ease-out flex items-center justify-end pr-3" style="width: 50%; background: linear-gradient(90deg, #2563eb, #3b82f6);">
                <span class="text-white text-xs font-bold whitespace-nowrap"></span>
              </div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Estimated Value Added</span>
              <span id="bar-value-label" class="text-text-primary font-medium">--</span>
            </div>
            <div class="w-full bg-bg-dark rounded-full h-8 overflow-hidden">
              <div id="bar-value" class="h-full rounded-full transition-all duration-700 ease-out flex items-center justify-end pr-3" style="width: 80%; background: linear-gradient(90deg, #16a34a, #22c55e);">
                <span class="text-white text-xs font-bold whitespace-nowrap"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Curb appeal and context cards -->
      <h3 class="font-heading font-bold text-xl mb-6">Curb Appeal &amp; Market Impact</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Curb Appeal Score</div>
          <div class="flex items-center justify-center gap-3">
            <span id="result-curb-before" class="font-heading font-bold text-2xl text-text-muted">--</span>
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            <span id="result-curb-after" class="font-heading font-extrabold text-2xl text-green-500">--</span>
          </div>
          <div class="text-text-muted text-xs mt-1">out of 10</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Value as % of Home</div>
          <div id="result-pct-of-home" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">of current home value invested</div>
        </div>
      </div>

      <!-- Payback context -->
      <div class="bg-bg-card border border-border rounded-xl p-6 mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">What This Means for the Homeowner</h4>
        <p id="result-context" class="text-text-secondary text-sm leading-relaxed">--</p>
      </div>

      <p class="text-text-muted text-sm italic">Estimates based on national averages from NAR/NALP research data. Actual ROI varies by region, home style, neighborhood comparables, quality of materials, and local buyer preferences. Use these figures as a conversation guide, not a guarantee.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Tool</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the project type.</strong> Choose the category that best matches the work you're quoting. Each project type uses different ROI ranges backed by NAR and NALP research data, so selecting the right one gives the most accurate estimate.</p>
          <p><strong class="text-text-primary">2. Enter the project cost.</strong> Use the total amount from your quote. This is the number the homeowner will see as their investment, so make sure it matches what you plan to present.</p>
          <p><strong class="text-text-primary">3. Fill in the property details.</strong> Enter the home's estimated value (Zillow or recent comps work fine), the current landscape condition, and local market conditions. These factors shift the ROI calculation up or down to reflect reality.</p>
          <p><strong class="text-text-primary">4. Show the results to your customer.</strong> Walk them through the estimated value increase, ROI percentage, and curb appeal improvement. The visual bar chart makes the value-over-cost story immediately clear. Screenshot the results for your proposal.</p>
        </div>
      </section>

      <!-- Understanding Landscaping ROI -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Understanding Landscaping ROI</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Why landscaping delivers strong returns.</strong> Landscaping is one of the few home improvements that consistently recovers 100% or more of its cost at resale. Unlike kitchen remodels or bathroom upgrades that return 50-80%, outdoor improvements benefit from maximum visibility. Every visitor, neighbor, and potential buyer sees the landscaping before they walk through the front door.</p>
          <p><strong class="text-text-primary">The research behind the numbers.</strong> The National Association of Realtors and the National Association of Landscape Professionals conduct joint studies on landscape investment recovery. Their data shows that a well-executed landscape project recovers 100-150% of its cost on average. Basic lawn care leads the pack because it has the lowest cost relative to the perceived value it creates. Mature trees are also standout performers, with each healthy specimen adding $1,000 to $3,000 in appraised value.</p>
          <p><strong class="text-text-primary">Curb appeal drives sale price.</strong> Homes with strong curb appeal sell for 7% more on average than comparable homes with poor landscaping. In a competitive seller's market, that premium climbs even higher because buyers make snap judgments from the street. A $400,000 home with excellent landscaping can command $28,000 or more above a similar home with a neglected yard.</p>
          <p><strong class="text-text-primary">Condition matters.</strong> The biggest ROI comes from improving a neglected yard to a well-maintained one. Going from bare dirt or overgrown weeds to a clean, designed landscape has more impact than upgrading an already decent yard to a premium one. This tool adjusts for that starting condition.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Pull this up during the sales visit.</strong> When you're sitting with a homeowner who is hesitant about the price, open this tool on your phone or tablet. Enter their project details and show them the ROI numbers. Shifting the conversation from cost to investment changes how the homeowner thinks about the project.</p>
          <p><strong class="text-text-primary">Justify premium materials and design.</strong> When you're quoting a full landscape redesign against a competitor's basic bid, this tool shows why the investment makes sense. A $15,000 landscape that adds $18,000 in home value is a financial win, and customers need to see that math to feel confident about the bigger number.</p>
          <p><strong class="text-text-primary">Help customers prioritize projects.</strong> Run two or three project types through the estimator to show which improvements deliver the best return. A customer debating between a patio and garden beds can see the ROI difference. This positions you as a trusted advisor, not just a contractor asking for money.</p>
          <p><strong class="text-text-primary">Support proposals for homeowners planning to sell.</strong> Customers preparing their home for sale are especially receptive to ROI data. Show them how a targeted landscape investment can net them thousands more at closing. The numbers from this tool give them confidence to move forward now rather than later.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is the average ROI on landscaping projects?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">According to the National Association of Realtors and the National Association of Landscape Professionals, landscaping projects recover 100% to 150% of their cost on average at resale. Basic lawn care and maintenance can return 200-300%, garden beds and plantings return 100-200%, and hardscaping like patios and walkways returns 50-75%. The exact ROI depends on the project type, home value, local market conditions, and quality of the work.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does landscaping increase home value?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Professional landscaping typically increases home value by 5% to 15%. On a $400,000 home, that translates to $20,000 to $60,000 in added value. The biggest impact comes from a well-maintained lawn, mature trees, and a cohesive landscape design. First impressions matter most in real estate, and landscaping is the first thing buyers see. Homes with excellent curb appeal sell for 7% more on average than comparable homes with poor landscaping.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Which landscaping projects have the highest ROI?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Basic lawn care and maintenance consistently delivers the highest ROI at 200-300% because it has the lowest cost relative to perceived value. Mature tree planting also performs well at 100-200% ROI, with each healthy mature tree adding $1,000 to $3,000 in property value. Garden beds and plantings return 100-200%. Full landscape redesigns return 100-150%. Hardscaping projects like patios return a lower percentage (50-75%) but can add substantial dollar value on higher-end homes.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How does curb appeal affect home sale price?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Curb appeal has a measurable impact on sale price. Homes with high curb appeal sell for 7% more on average according to multiple real estate studies. In a seller's market, the premium can reach 10-15% because buyers compete for move-in ready homes. Poor curb appeal can reduce offers by 5-10% or cause buyers to skip the listing entirely. Landscaping is the most cost-effective way to improve curb appeal because it covers the entire front-facing impression of the property.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // ROI ranges by project type: [lowROI, highROI] as multipliers (1.0 = 100%)
  interface ProjectROI {
    lowROI: number;
    highROI: number;
    treeValueLow: number;
    treeValueHigh: number;
  }

  const projectROIs: Record<string, ProjectROI> = {
    'lawn':           { lowROI: 2.0, highROI: 3.0, treeValueLow: 0, treeValueHigh: 0 },
    'garden-beds':    { lowROI: 1.0, highROI: 2.0, treeValueLow: 0, treeValueHigh: 0 },
    'hardscaping':    { lowROI: 0.5, highROI: 0.75, treeValueLow: 0, treeValueHigh: 0 },
    'full-landscape': { lowROI: 1.0, highROI: 1.5, treeValueLow: 0, treeValueHigh: 0 },
    'trees':          { lowROI: 1.0, highROI: 2.0, treeValueLow: 1000, treeValueHigh: 3000 },
    'lighting':       { lowROI: 0.5, highROI: 0.75, treeValueLow: 0, treeValueHigh: 0 },
    'irrigation':     { lowROI: 0.5, highROI: 0.75, treeValueLow: 0, treeValueHigh: 0 },
  };

  // Condition multipliers: how much extra ROI boost from improving a worse starting point
  const conditionMultipliers: Record<string, number> = {
    'needs-work':      1.20,
    'average':         1.00,
    'well-maintained': 0.85,
    'high-end':        0.70,
  };

  // Market condition multipliers
  const marketMultipliers: Record<string, number> = {
    'buyers':   0.85,
    'balanced': 1.00,
    'sellers':  1.15,
  };

  // Curb appeal base scores by condition
  const curbScoresBefore: Record<string, number> = {
    'needs-work':      2,
    'average':         4,
    'well-maintained': 6,
    'high-end':        8,
  };

  // Curb appeal improvement by project type (points added, out of 10)
  const curbImprovements: Record<string, number> = {
    'lawn':           3,
    'garden-beds':    2.5,
    'hardscaping':    2,
    'full-landscape': 4,
    'trees':          2,
    'lighting':       1.5,
    'irrigation':     1,
  };

  function formatCurrency(val: number): string {
    return '$' + val.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function calculate(): void {
    // Inputs
    const projectType = (document.getElementById('project-type') as HTMLSelectElement).value;
    const projectCost = parseFloat((document.getElementById('project-cost') as HTMLInputElement).value) || 12000;
    const numTrees = parseInt((document.getElementById('num-trees') as HTMLInputElement).value) || 0;
    const homeValue = parseFloat((document.getElementById('home-value') as HTMLInputElement).value) || 400000;
    const homeCondition = (document.getElementById('home-condition') as HTMLSelectElement).value;
    const marketCondition = (document.getElementById('market-condition') as HTMLSelectElement).value;

    // Get ROI data for project type
    const roi = projectROIs[projectType] || projectROIs['hardscaping'];
    const condMult = conditionMultipliers[homeCondition] || 1.0;
    const marketMult = marketMultipliers[marketCondition] || 1.0;

    // Calculate midpoint ROI with adjustments
    const baseROI = (roi.lowROI + roi.highROI) / 2;
    const adjustedROI = baseROI * condMult * marketMult;

    // Calculate value increase
    let valueIncrease = projectCost * adjustedROI;

    // Add tree value bonus if applicable
    if (numTrees > 0) {
      const treeValueMid = (roi.treeValueLow + roi.treeValueHigh) / 2;
      // If project is specifically trees, the tree value is the main ROI
      // For other projects, trees are an extra bonus
      if (projectType === 'trees') {
        valueIncrease = numTrees * treeValueMid * condMult * marketMult;
      } else {
        valueIncrease += numTrees * treeValueMid * condMult * marketMult;
      }
    }

    // Cap value increase at reasonable percentage of home value (20%)
    const maxIncrease = homeValue * 0.20;
    valueIncrease = Math.min(valueIncrease, maxIncrease);

    const roiPct = (valueIncrease / projectCost) * 100;
    const netGain = valueIncrease - projectCost;
    const newHomeValue = homeValue + valueIncrease;
    const pctOfHome = (projectCost / homeValue) * 100;

    // Curb appeal scores
    const curbBefore = curbScoresBefore[homeCondition] || 4;
    const curbImprovement = curbImprovements[projectType] || 2;
    // Scale improvement by investment relative to home value (diminishing returns)
    const investmentScale = Math.min(projectCost / (homeValue * 0.05), 1.0);
    const scaledImprovement = curbImprovement * investmentScale * condMult;
    const curbAfter = Math.min(Math.round((curbBefore + scaledImprovement) * 10) / 10, 10);

    // Update value cards
    document.getElementById('result-value-increase')!.textContent = formatCurrency(Math.round(valueIncrease));
    document.getElementById('result-roi-pct')!.textContent = Math.round(roiPct) + '%';
    document.getElementById('result-net-gain')!.textContent = formatCurrency(Math.round(netGain));

    const netGainEl = document.getElementById('result-net-gain')!;
    if (netGain >= 0) {
      netGainEl.classList.remove('text-red-400');
      netGainEl.classList.add('text-text-primary');
    } else {
      netGainEl.classList.remove('text-text-primary');
      netGainEl.classList.add('text-red-400');
    }

    document.getElementById('result-new-home-value')!.textContent = formatCurrency(Math.round(newHomeValue));

    // Update bar chart
    const maxBar = Math.max(projectCost, valueIncrease, 1);
    const costBarPct = (projectCost / maxBar) * 100;
    const valueBarPct = (valueIncrease / maxBar) * 100;
    (document.getElementById('bar-cost') as HTMLElement).style.width = costBarPct + '%';
    (document.getElementById('bar-value') as HTMLElement).style.width = valueBarPct + '%';
    document.getElementById('bar-cost-label')!.textContent = formatCurrency(Math.round(projectCost));
    document.getElementById('bar-value-label')!.textContent = formatCurrency(Math.round(valueIncrease));

    // Update curb appeal
    document.getElementById('result-curb-before')!.textContent = curbBefore.toString();
    document.getElementById('result-curb-after')!.textContent = curbAfter.toFixed(1);

    // Update percentage of home value
    document.getElementById('result-pct-of-home')!.textContent = pctOfHome.toFixed(1) + '%';

    // Build context message
    let context = '';
    if (roiPct >= 150) {
      context = `This project is projected to return ${Math.round(roiPct)}% of the investment, adding an estimated ${formatCurrency(Math.round(valueIncrease))} to the home's value. That's a net gain of ${formatCurrency(Math.round(netGain))} in equity. This is a strong investment that more than pays for itself at resale. `;
    } else if (roiPct >= 100) {
      context = `This project is projected to return ${Math.round(roiPct)}% of the investment, fully recovering the cost and adding ${formatCurrency(Math.round(netGain))} in net value. The homeowner gets to enjoy the improvement now and recover the full cost when they sell. `;
    } else if (roiPct >= 60) {
      context = `This project is projected to recover ${Math.round(roiPct)}% of its cost at resale, adding ${formatCurrency(Math.round(valueIncrease))} in value. While the full cost isn't recovered at sale, the homeowner benefits from daily enjoyment, improved curb appeal, and a more competitive listing when it's time to sell. `;
    } else {
      context = `This project is projected to recover ${Math.round(roiPct)}% of its cost at resale. The primary value here is the homeowner's personal enjoyment and lifestyle improvement rather than a pure financial return. That said, ${formatCurrency(Math.round(valueIncrease))} in added value is meaningful. `;
    }

    // Add curb appeal context
    if (scaledImprovement >= 3) {
      context += `The curb appeal jump from ${curbBefore} to ${curbAfter.toFixed(1)} out of 10 is dramatic and will be immediately noticeable from the street.`;
    } else if (scaledImprovement >= 1.5) {
      context += `The curb appeal improvement from ${curbBefore} to ${curbAfter.toFixed(1)} out of 10 is a solid upgrade that buyers and neighbors will notice.`;
    } else {
      context += `The curb appeal moves from ${curbBefore} to ${curbAfter.toFixed(1)} out of 10, a meaningful improvement that adds to the overall property presentation.`;
    }

    document.getElementById('result-context')!.textContent = context;
  }

  // Auto-calculate on any input change
  document.querySelectorAll('#roi-calc input, #roi-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
