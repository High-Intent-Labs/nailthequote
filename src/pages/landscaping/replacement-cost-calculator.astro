---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/landscapingTools';

const tool = getToolBySlug('replacement-cost-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a full landscape renovation cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A full landscape redesign typically runs $10 to $25 per square foot installed, depending on scope, materials, and region. A basic 1,000 sq ft redesign might start around $10,000, while a premium design with high-end hardscaping, mature plantings, and lighting can exceed $25,000. Complexity factors like steep slopes or difficult access add 15-30% to the total."
      }
    },
    {
      "@type": "Question",
      "name": "What landscape project gives the best return on investment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lawn replacement (sod) and garden bed installation offer the highest ROI at the lowest cost per square foot. Hardscaping projects like patios and retaining walls add significant perceived value but cost more. Studies consistently show that well-maintained landscaping can increase property value by 5-15%, with curb appeal improvements recovering 100% or more of the investment at resale."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a typical landscape renovation take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Timelines vary by project type. A basic sod installation for 1,000-2,000 sq ft takes 1-2 days. A mid-range patio or retaining wall project runs 3-7 days. A full landscape redesign with hardscaping, irrigation, planting, and lighting typically takes 2-4 weeks. Steep slopes, drainage work, and weather delays can extend timelines significantly."
      }
    },
    {
      "@type": "Question",
      "name": "What factors affect landscaping project cost the most?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The four biggest cost drivers are project type, material quality, site complexity, and region. Hardscaping and retaining walls are the most expensive per unit. Premium materials (natural stone vs. concrete pavers, mature trees vs. saplings) can double costs. Steep slopes require retaining, specialized equipment, and more labor. West Coast and Northeast markets run 10-15% above national averages."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="cost-calc">
    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="projectType">Project Type</label>
        <select id="projectType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="full-redesign">Full Landscape Redesign</option>
          <option value="lawn-sod" selected>Lawn Replacement / Sod</option>
          <option value="patio-hardscape">Patio / Hardscaping</option>
          <option value="retaining-wall">Retaining Wall</option>
          <option value="irrigation">Irrigation System</option>
          <option value="drainage">Drainage Solution</option>
          <option value="outdoor-lighting">Outdoor Lighting</option>
          <option value="garden-beds">Garden Beds</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="areaSize">
          <span id="areaLabel">Area Size (sq ft)</span>
        </label>
        <input id="areaSize" type="number" min="50" max="100000" value="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="scope">Scope / Material Quality</label>
        <select id="scope" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="basic">Basic</option>
          <option value="mid" selected>Mid-Range</option>
          <option value="premium">Premium</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="region">Region</label>
        <select id="region" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="0.85">Southeast</option>
          <option value="0.90">Midwest</option>
          <option value="0.95">South</option>
          <option value="1.00" selected>National Average</option>
          <option value="1.05">Mountain</option>
          <option value="1.10">Northeast</option>
          <option value="1.10">Pacific NW</option>
          <option value="1.15">West</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="complexity">Site Complexity</label>
        <select id="complexity" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1.0" selected>Flat Lot</option>
          <option value="1.15">Mild Slope</option>
          <option value="1.30">Steep Slope / Difficult Access</option>
        </select>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Estimated Project Cost</h3>

      <!-- Cost Range Bar -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <div class="flex justify-between items-end mb-3">
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Low</div>
            <div id="result-low" class="font-heading font-extrabold text-xl text-text-secondary">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Mid Estimate</div>
            <div id="result-mid" class="font-heading font-extrabold text-3xl text-accent">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">High</div>
            <div id="result-high" class="font-heading font-extrabold text-xl text-text-secondary">--</div>
          </div>
        </div>
        <!-- Visual range bar -->
        <div class="relative h-3 bg-bg-card rounded-full overflow-hidden mt-4">
          <div id="range-bar" class="absolute inset-y-0 left-[10%] right-[10%] rounded-full bg-gradient-to-r from-accent/40 via-accent to-accent/40"></div>
          <div id="range-marker" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-accent rounded-full border-2 border-white shadow-lg"></div>
        </div>
      </div>

      <!-- Cost Per Unit + Timeline -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost Per Unit</div>
          <div id="result-per-unit" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div id="result-per-unit-label" class="text-text-muted text-xs mt-1">per sq ft</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Typical Timeline</div>
          <div id="result-timeline" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">working days</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">60-Month Financing</div>
          <div id="result-monthly" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">per month</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">This is a ballpark estimate based on national averages. Actual costs vary by contractor, materials, soil conditions, and site access. Use this to set customer expectations, then follow up with a detailed proposal after a site visit.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Estimator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the project type.</strong> Choose from full redesigns, lawn replacement, hardscaping, retaining walls, irrigation, drainage, lighting, or garden beds. Each project type uses different cost-per-unit data.</p>
          <p><strong class="text-text-primary">2. Enter the area or quantity.</strong> Input the square footage of the area being worked on. For retaining walls and drainage, enter linear feet instead. For outdoor lighting, enter the number of fixture zones.</p>
          <p><strong class="text-text-primary">3. Pick the scope level.</strong> Basic uses standard materials and simple designs. Mid-range includes better materials and moderate design complexity. Premium covers high-end materials, mature plantings, and custom design work.</p>
          <p><strong class="text-text-primary">4. Set region and site complexity.</strong> Regional labor and material costs vary significantly. Steep slopes, poor access, and rocky soil add 15-30% to the project due to extra equipment, retaining needs, and labor time.</p>
        </div>
      </section>

      <!-- What Affects Cost -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Affects Landscape Renovation Cost</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Project type and materials.</strong> The biggest cost driver is what you are building. Sod installation is the most affordable per square foot. Hardscaping and retaining walls are the most expensive due to material weight, base preparation, and skilled labor. Natural stone costs significantly more than concrete pavers or block.</p>
          <p><strong class="text-text-primary">Property size and scope.</strong> Larger areas cost more overall but often have a lower cost per square foot due to equipment efficiency and bulk material pricing. Premium scope with mature plantings, custom stonework, and integrated lighting can double or triple the per-unit cost compared to basic.</p>
          <p><strong class="text-text-primary">Regional pricing.</strong> Labor rates, material availability, and permit requirements vary by market. Southeastern states tend to have the lowest installation costs, while the West Coast and Northeast are the most expensive. Desert climates may have different plant material costs but higher irrigation requirements.</p>
          <p><strong class="text-text-primary">Site complexity.</strong> A flat, open lot with good soil is the easiest and cheapest to work. Mild slopes require grading and may need minor retention. Steep slopes or sites with difficult access (narrow gates, no equipment access, rocky soil) require hand-carry of materials, specialized equipment, and significantly more labor hours.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">During sales consultations.</strong> Pull this up on your tablet during the initial site visit. Walk the customer through their project options, show them how scope and materials affect the price, and set realistic expectations before you go back to the office to build a detailed proposal.</p>
          <p><strong class="text-text-primary">Phone and email inquiries.</strong> When a homeowner calls asking "how much to redo my backyard?" you can walk them through a few questions and give a ballpark range in seconds. This qualifies the lead and builds trust before you commit to a site visit.</p>
          <p><strong class="text-text-primary">Website lead generation.</strong> Embed this calculator on your company website so homeowners can self-educate on pricing. Visitors who use the tool and then contact you are better-informed and more likely to convert because they already have realistic price expectations for their project.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does a full landscape renovation cost?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A full landscape redesign typically runs $10 to $25 per square foot installed, depending on scope, materials, and region. A basic 1,000 sq ft redesign might start around $10,000, while a premium design with high-end hardscaping, mature plantings, and lighting can exceed $25,000. Complexity factors like steep slopes or difficult access add 15-30% to the total.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What landscape project gives the best return on investment?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Lawn replacement (sod) and garden bed installation offer the highest ROI at the lowest cost per square foot. Hardscaping projects like patios and retaining walls add significant perceived value but cost more. Studies consistently show that well-maintained landscaping can increase property value by 5-15%, with curb appeal improvements recovering 100% or more of the investment at resale.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How long does a typical landscape renovation take?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Timelines vary by project type. A basic sod installation for 1,000-2,000 sq ft takes 1-2 days. A mid-range patio or retaining wall project runs 3-7 days. A full landscape redesign with hardscaping, irrigation, planting, and lighting typically takes 2-4 weeks. Steep slopes, drainage work, and weather delays can extend timelines significantly.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What factors affect landscaping project cost the most?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The four biggest cost drivers are project type, material quality, site complexity, and region. Hardscaping and retaining walls are the most expensive per unit. Premium materials (natural stone vs. concrete pavers, mature trees vs. saplings) can double costs. Steep slopes require retaining, specialized equipment, and more labor. West Coast and Northeast markets run 10-15% above national averages.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  interface ProjectData {
    /** [low, high] cost per unit */
    range: [number, number];
    /** unit type for display */
    unit: 'sq ft' | 'linear ft' | 'fixture zone';
    /** label for the area input */
    areaLabel: string;
    /** [low, high] timeline in working days per 1000 units (or per 10 for lighting) */
    timeline: [number, number];
  }

  const projectData: Record<string, Record<string, ProjectData>> = {
    'full-redesign': {
      basic:   { range: [10, 15], unit: 'sq ft', areaLabel: 'Area Size (sq ft)', timeline: [10, 15] },
      mid:     { range: [15, 20], unit: 'sq ft', areaLabel: 'Area Size (sq ft)', timeline: [12, 20] },
      premium: { range: [20, 25], unit: 'sq ft', areaLabel: 'Area Size (sq ft)', timeline: [15, 28] },
    },
    'lawn-sod': {
      basic:   { range: [1.00, 1.50], unit: 'sq ft', areaLabel: 'Lawn Area (sq ft)', timeline: [1, 2] },
      mid:     { range: [1.50, 2.25], unit: 'sq ft', areaLabel: 'Lawn Area (sq ft)', timeline: [1, 3] },
      premium: { range: [2.25, 3.00], unit: 'sq ft', areaLabel: 'Lawn Area (sq ft)', timeline: [2, 4] },
    },
    'patio-hardscape': {
      basic:   { range: [15, 20], unit: 'sq ft', areaLabel: 'Patio Area (sq ft)', timeline: [3, 5] },
      mid:     { range: [20, 25], unit: 'sq ft', areaLabel: 'Patio Area (sq ft)', timeline: [4, 7] },
      premium: { range: [25, 30], unit: 'sq ft', areaLabel: 'Patio Area (sq ft)', timeline: [5, 10] },
    },
    'retaining-wall': {
      basic:   { range: [25, 35], unit: 'linear ft', areaLabel: 'Wall Length (linear ft)', timeline: [3, 5] },
      mid:     { range: [35, 42], unit: 'linear ft', areaLabel: 'Wall Length (linear ft)', timeline: [4, 7] },
      premium: { range: [42, 50], unit: 'linear ft', areaLabel: 'Wall Length (linear ft)', timeline: [5, 10] },
    },
    'irrigation': {
      basic:   { range: [1.00, 1.50], unit: 'sq ft', areaLabel: 'Coverage Area (sq ft)', timeline: [2, 3] },
      mid:     { range: [1.50, 2.25], unit: 'sq ft', areaLabel: 'Coverage Area (sq ft)', timeline: [3, 5] },
      premium: { range: [2.25, 3.00], unit: 'sq ft', areaLabel: 'Coverage Area (sq ft)', timeline: [4, 7] },
    },
    'drainage': {
      basic:   { range: [8, 10],  unit: 'linear ft', areaLabel: 'Drain Run Length (linear ft)', timeline: [2, 3] },
      mid:     { range: [10, 12], unit: 'linear ft', areaLabel: 'Drain Run Length (linear ft)', timeline: [3, 5] },
      premium: { range: [12, 15], unit: 'linear ft', areaLabel: 'Drain Run Length (linear ft)', timeline: [4, 7] },
    },
    'outdoor-lighting': {
      basic:   { range: [200, 300], unit: 'fixture zone', areaLabel: 'Number of Fixture Zones', timeline: [1, 2] },
      mid:     { range: [300, 400], unit: 'fixture zone', areaLabel: 'Number of Fixture Zones', timeline: [2, 3] },
      premium: { range: [400, 500], unit: 'fixture zone', areaLabel: 'Number of Fixture Zones', timeline: [2, 4] },
    },
    'garden-beds': {
      basic:   { range: [5, 8],   unit: 'sq ft', areaLabel: 'Bed Area (sq ft)', timeline: [2, 3] },
      mid:     { range: [8, 12],  unit: 'sq ft', areaLabel: 'Bed Area (sq ft)', timeline: [3, 5] },
      premium: { range: [12, 15], unit: 'sq ft', areaLabel: 'Bed Area (sq ft)', timeline: [4, 7] },
    },
  };

  function calculate(): void {
    const projectType = (document.getElementById('projectType') as HTMLSelectElement).value;
    const areaSize = parseFloat((document.getElementById('areaSize') as HTMLInputElement).value) || 0;
    const scope = (document.getElementById('scope') as HTMLSelectElement).value;
    const region = parseFloat((document.getElementById('region') as HTMLSelectElement).value);
    const complexity = parseFloat((document.getElementById('complexity') as HTMLSelectElement).value);

    const data = projectData[projectType]?.[scope];
    if (!data || areaSize <= 0) return;

    // Update area label dynamically
    document.getElementById('areaLabel')!.textContent = data.areaLabel;

    const [rateLow, rateHigh] = data.range;
    const rateMid = (rateLow + rateHigh) / 2;

    const low = Math.round(areaSize * rateLow * region * complexity);
    const mid = Math.round(areaSize * rateMid * region * complexity);
    const high = Math.round(areaSize * rateHigh * region * complexity);

    const costPerUnit = rateMid * region * complexity;
    const monthly60 = Math.round(mid / 60);

    // Timeline: scale based on area relative to 1000 units (baseline)
    const [tlLow, tlHigh] = data.timeline;
    const scaleFactor = data.unit === 'fixture zone' ? areaSize / 10 : areaSize / 1000;
    const timelineLow = Math.max(1, Math.round(tlLow * Math.max(scaleFactor, 0.5) * complexity));
    const timelineHigh = Math.max(1, Math.round(tlHigh * Math.max(scaleFactor, 0.5) * complexity));

    const fmt = (n: number): string => '$' + n.toLocaleString();

    document.getElementById('result-low')!.textContent = fmt(low);
    document.getElementById('result-mid')!.textContent = fmt(mid);
    document.getElementById('result-high')!.textContent = fmt(high);

    // Cost per unit display
    const perUnitEl = document.getElementById('result-per-unit')!;
    const perUnitLabelEl = document.getElementById('result-per-unit-label')!;
    if (data.unit === 'fixture zone') {
      perUnitEl.textContent = fmt(Math.round(costPerUnit));
    } else {
      perUnitEl.textContent = '$' + costPerUnit.toFixed(2);
    }
    perUnitLabelEl.textContent = 'per ' + data.unit;

    // Timeline
    const timelineEl = document.getElementById('result-timeline')!;
    if (timelineLow === timelineHigh) {
      timelineEl.textContent = `${timelineLow}`;
    } else {
      timelineEl.textContent = `${timelineLow} - ${timelineHigh}`;
    }

    // Monthly financing
    document.getElementById('result-monthly')!.textContent = fmt(monthly60);
  }

  // Update area label when project type changes
  function updateAreaLabel(): void {
    const projectType = (document.getElementById('projectType') as HTMLSelectElement).value;
    const scope = (document.getElementById('scope') as HTMLSelectElement).value;
    const data = projectData[projectType]?.[scope];
    if (data) {
      document.getElementById('areaLabel')!.textContent = data.areaLabel;
    }
  }

  // Auto-calculate on input change
  document.querySelectorAll('#cost-calc select').forEach(el => {
    el.addEventListener('change', () => {
      updateAreaLabel();
      calculate();
    });
  });

  document.getElementById('areaSize')!.addEventListener('input', calculate);

  // Calculate on load with defaults
  updateAreaLabel();
  calculate();
</script>
