---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/landscapingTools';

const tool = getToolBySlug('equipment-rental-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Should I rent or buy landscaping equipment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rent equipment you use fewer than 40-60 days per year. If the annual rental cost exceeds 30-40% of the purchase price, buying usually makes more sense. Also consider storage, maintenance, and transport costs when comparing. For specialty equipment like stump grinders, trenchers, and skid steers that you only need for specific jobs, renting almost always wins. For daily-use equipment like mowers and blowers, ownership is more cost-effective."
      }
    },
    {
      "@type": "Question",
      "name": "How do I pass equipment rental costs to the customer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Add the rental cost to your job estimate as a line item, then apply a markup of 15-30% to cover your time picking up, transporting, and returning the equipment. Some landscapers include fuel surcharges and delivery fees as separate line items. Always quote the rental cost before starting work so the customer knows what to expect. For recurring jobs that need the same rental, consider negotiating weekly or monthly rates with your rental yard."
      }
    },
    {
      "@type": "Question",
      "name": "What landscaping equipment is most commonly rented?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most commonly rented landscaping equipment includes mini excavators, skid steers, stump grinders, trenchers, sod cutters, plate compactors, augers, and brush chippers. These machines are expensive to own, require regular maintenance, and are typically only needed for specific project types. Daily rental rates range from $150 for a plate compactor to $500 or more for a mini excavator."
      }
    },
    {
      "@type": "Question",
      "name": "How do I estimate equipment rental costs for a bid?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start with the daily or weekly rental rate from your local equipment yard. Estimate how many days you will need the machine based on the job scope, then add delivery and pickup fees if applicable. Factor in fuel cost for the equipment. Apply your markup to cover logistics and your time managing the rental. Always pad your estimate by at least half a day because jobs rarely finish exactly on schedule."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="rental-calc">
    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equipmentType">Equipment Type</label>
        <select id="equipmentType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="mini-excavator" selected>Mini Excavator</option>
          <option value="skid-steer">Skid Steer</option>
          <option value="stump-grinder">Stump Grinder</option>
          <option value="trencher">Trencher (walk-behind)</option>
          <option value="sod-cutter">Sod Cutter</option>
          <option value="plate-compactor">Plate Compactor</option>
          <option value="auger">Post Hole Auger</option>
          <option value="chipper">Brush Chipper (6")</option>
          <option value="chipper-large">Brush Chipper (12")</option>
          <option value="dingo">Dingo / Compact Utility Loader</option>
          <option value="custom">Custom (enter your own)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="dailyRate">Daily Rental Rate ($)</label>
        <input type="number" id="dailyRate" value="450" min="0" max="5000" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="rentalDuration">Rental Duration</label>
        <select id="rentalDuration" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="half-day">Half Day (4 hours)</option>
          <option value="1" selected>1 Day</option>
          <option value="2">2 Days</option>
          <option value="3">3 Days</option>
          <option value="week">1 Week</option>
          <option value="2week">2 Weeks</option>
          <option value="month">1 Month</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="delivery">Delivery & Pickup</label>
        <select id="delivery" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="0">Self-transport (no fee)</option>
          <option value="150" selected>Standard delivery ($150)</option>
          <option value="250">Long-distance delivery ($250)</option>
          <option value="custom">Custom amount</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="deliveryCustom">Delivery Fee ($)</label>
        <input type="number" id="deliveryCustom" value="150" min="0" max="1000" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="fuelCost">Estimated Fuel Cost ($)</label>
        <input type="number" id="fuelCost" value="50" min="0" max="1000" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Diesel or gas for the equipment itself</p>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Rental Cost Summary</h3>

      <!-- Primary Result -->
      <div class="bg-bg-dark rounded-xl p-6 text-center mb-6 border border-accent/30">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Rental Cost</div>
        <div id="result-total" class="font-heading font-extrabold text-5xl text-accent">--</div>
        <div id="result-equipment-label" class="text-text-muted text-sm mt-2">--</div>
      </div>

      <!-- Breakdown -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Rental Charge</div>
          <div id="result-rental" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Delivery</div>
          <div id="result-delivery" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Fuel</div>
          <div id="result-fuel" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost per Day</div>
          <div id="result-per-day" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Customer Price (25% markup)</div>
          <div id="result-customer" class="font-heading font-extrabold text-xl text-[#34D399]">--</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">Rates based on typical rental yard pricing. Actual rates vary by location, equipment age and condition, and seasonal demand. Always confirm rates with your rental supplier before quoting a job.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the equipment type.</strong> Choose from common landscaping rental equipment. The daily rate auto-fills with a typical rate, but you should override it with the actual rate from your local rental yard.</p>
          <p><strong class="text-text-primary">2. Set the rental duration.</strong> Weekly rates are typically 3x the daily rate, and monthly rates are around 10x daily. The calculator applies these standard discount tiers. Always pad your rental by at least half a day because jobs rarely finish exactly on schedule.</p>
          <p><strong class="text-text-primary">3. Add delivery and fuel costs.</strong> Delivery fees cover the rental yard transporting the equipment to your job site and picking it up. If you haul it yourself on a trailer, set delivery to zero but factor in your fuel and time. Fuel cost is what the equipment itself burns while running.</p>
          <p><strong class="text-text-primary">4. Review the total and customer price.</strong> The calculator shows your total rental cost and a suggested customer price with a 25% markup. Adjust the markup based on your overhead and the complexity of managing the rental for the job.</p>
        </div>
      </section>

      <!-- Rental Pricing Tips -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Equipment Rental Pricing Tips</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Always get the weekly rate.</strong> If a job might take more than 3 days, the weekly rate almost always saves money. Most rental yards price a week at 3x the daily rate, so day four is essentially free. Even if you only need 4 days, the weekly rate is cheaper than 4 separate day rates.</p>
          <p><strong class="text-text-primary">Build in a buffer day.</strong> Weather, site conditions, and unexpected issues can stretch a rental. If you quote the customer based on a 2-day rental and the job takes 3 days, that extra day comes out of your profit. Estimate the realistic duration and add at least half a day as a buffer.</p>
          <p><strong class="text-text-primary">Negotiate with your rental yard.</strong> If you rent consistently from the same supplier, negotiate standing discounts. Many rental yards offer 10-15% off for regular customers or annual volume commitments. Building a relationship with one or two yards is more valuable than shopping every rental.</p>
          <p><strong class="text-text-primary">Mark up the rental in your bid.</strong> Your time has value. Calling the rental yard, coordinating delivery, meeting the driver on site, overseeing the equipment, and managing the return all take time. A 20-30% markup on the rental cost covers this logistics work. Never pass through rental costs at your cost.</p>
          <p><strong class="text-text-primary">Track your equipment usage.</strong> If you are renting the same piece of equipment more than 50 days a year, run the numbers on buying. Purchase price, maintenance, insurance, storage, and depreciation all factor in. There is usually a clear breakeven point where ownership wins.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Bidding jobs that need specialty equipment.</strong> Before you finalize a bid, run the rental cost through this calculator to make sure it is included in your price. A forgotten rental can eat 10-20% of a job's profit. This is especially critical for jobs involving excavators, chippers, or large grading equipment.</p>
          <p><strong class="text-text-primary">Comparing rental options.</strong> Use this calculator to compare the cost of renting different equipment for the same task. For example, a mini excavator for a full day versus a dingo for two days. The total cost including fuel and delivery often determines which machine is the smarter choice.</p>
          <p><strong class="text-text-primary">Evaluating rent vs. buy decisions.</strong> Calculate your annual rental spend for a specific piece of equipment. If the total exceeds 30-40% of the purchase price, pull the trigger on buying. This calculator helps you see the per-job rental cost clearly so you can aggregate it over your season.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I rent or buy landscaping equipment?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Rent equipment you use fewer than 40-60 days per year. If the annual rental cost exceeds 30-40% of the purchase price, buying usually makes more sense. Also consider storage, maintenance, and transport costs when comparing. For specialty equipment like stump grinders, trenchers, and skid steers that you only need for specific jobs, renting almost always wins. For daily-use equipment like mowers and blowers, ownership is more cost-effective.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I pass equipment rental costs to the customer?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Add the rental cost to your job estimate as a line item, then apply a markup of 15-30% to cover your time picking up, transporting, and returning the equipment. Some landscapers include fuel surcharges and delivery fees as separate line items. Always quote the rental cost before starting work so the customer knows what to expect. For recurring jobs that need the same rental, consider negotiating weekly or monthly rates with your rental yard.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What landscaping equipment is most commonly rented?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The most commonly rented landscaping equipment includes mini excavators, skid steers, stump grinders, trenchers, sod cutters, plate compactors, augers, and brush chippers. These machines are expensive to own, require regular maintenance, and are typically only needed for specific project types. Daily rental rates range from $150 for a plate compactor to $500 or more for a mini excavator.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I estimate equipment rental costs for a bid?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Start with the daily or weekly rental rate from your local equipment yard. Estimate how many days you will need the machine based on the job scope, then add delivery and pickup fees if applicable. Factor in fuel cost for the equipment. Apply your markup to cover logistics and your time managing the rental. Always pad your estimate by at least half a day because jobs rarely finish exactly on schedule.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // Typical daily rates by equipment type
  const equipmentRates: Record<string, { daily: number; label: string; fuelEstimate: number }> = {
    'mini-excavator':  { daily: 450, label: 'Mini Excavator',               fuelEstimate: 60  },
    'skid-steer':      { daily: 400, label: 'Skid Steer',                   fuelEstimate: 55  },
    'stump-grinder':   { daily: 350, label: 'Stump Grinder',                fuelEstimate: 40  },
    'trencher':        { daily: 250, label: 'Trencher (walk-behind)',        fuelEstimate: 25  },
    'sod-cutter':      { daily: 200, label: 'Sod Cutter',                   fuelEstimate: 20  },
    'plate-compactor': { daily: 150, label: 'Plate Compactor',              fuelEstimate: 15  },
    'auger':           { daily: 175, label: 'Post Hole Auger',              fuelEstimate: 15  },
    'chipper':         { daily: 300, label: 'Brush Chipper (6")',            fuelEstimate: 40  },
    'chipper-large':   { daily: 550, label: 'Brush Chipper (12")',           fuelEstimate: 70  },
    'dingo':           { daily: 350, label: 'Dingo / Compact Utility Loader', fuelEstimate: 35 },
    'custom':          { daily: 0,   label: 'Custom Equipment',              fuelEstimate: 0   },
  };

  function onEquipmentChange(): void {
    const type = (document.getElementById('equipmentType') as HTMLSelectElement).value;
    const eq = equipmentRates[type];
    if (!eq || type === 'custom') return;

    (document.getElementById('dailyRate') as HTMLInputElement).value = String(eq.daily);
    (document.getElementById('fuelCost') as HTMLInputElement).value = String(eq.fuelEstimate);
  }

  function calculate(): void {
    const type = (document.getElementById('equipmentType') as HTMLSelectElement).value;
    const dailyRate = parseFloat((document.getElementById('dailyRate') as HTMLInputElement).value) || 0;
    const duration = (document.getElementById('rentalDuration') as HTMLSelectElement).value;
    const deliverySelect = (document.getElementById('delivery') as HTMLSelectElement).value;
    const deliveryCustom = parseFloat((document.getElementById('deliveryCustom') as HTMLInputElement).value) || 0;
    const fuelCost = parseFloat((document.getElementById('fuelCost') as HTMLInputElement).value) || 0;

    // Delivery fee
    let deliveryFee: number;
    if (deliverySelect === 'custom') {
      deliveryFee = deliveryCustom;
    } else {
      deliveryFee = parseFloat(deliverySelect) || 0;
      (document.getElementById('deliveryCustom') as HTMLInputElement).value = String(deliveryFee);
    }

    // Rental charge based on duration
    // Standard rental pricing: week = 3x daily, 2 weeks = 5x daily, month = 10x daily
    let rentalCharge: number;
    let rentalDays: number;
    switch (duration) {
      case 'half-day':
        rentalCharge = dailyRate * 0.65;
        rentalDays = 0.5;
        break;
      case '1':
        rentalCharge = dailyRate;
        rentalDays = 1;
        break;
      case '2':
        rentalCharge = dailyRate * 2;
        rentalDays = 2;
        break;
      case '3':
        rentalCharge = dailyRate * 3;
        rentalDays = 3;
        break;
      case 'week':
        rentalCharge = dailyRate * 3; // weekly rate = 3x daily
        rentalDays = 7;
        break;
      case '2week':
        rentalCharge = dailyRate * 5; // 2-week rate
        rentalDays = 14;
        break;
      case 'month':
        rentalCharge = dailyRate * 10; // monthly rate
        rentalDays = 30;
        break;
      default:
        rentalCharge = dailyRate;
        rentalDays = 1;
    }

    // Scale fuel by duration days (base fuel estimate is per day)
    const totalFuel = fuelCost * Math.max(rentalDays, 0.5);

    // Total cost
    const totalCost = rentalCharge + deliveryFee + totalFuel;

    // Cost per day
    const costPerDay = rentalDays > 0 ? totalCost / rentalDays : totalCost;

    // Customer price with 25% markup
    const customerPrice = Math.round(totalCost * 1.25);

    // Equipment label
    const eq = equipmentRates[type];
    const label = eq ? eq.label : 'Custom Equipment';

    const fmt = (n: number): string => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });

    document.getElementById('result-total')!.textContent = fmt(Math.round(totalCost));
    document.getElementById('result-equipment-label')!.textContent = `${label} \u2014 ${duration === 'half-day' ? 'Half day' : duration === 'week' ? '1 week' : duration === '2week' ? '2 weeks' : duration === 'month' ? '1 month' : duration + (parseInt(duration) === 1 ? ' day' : ' days')}`;
    document.getElementById('result-rental')!.textContent = fmt(Math.round(rentalCharge));
    document.getElementById('result-delivery')!.textContent = fmt(deliveryFee);
    document.getElementById('result-fuel')!.textContent = fmt(Math.round(totalFuel));
    document.getElementById('result-per-day')!.textContent = fmt(Math.round(costPerDay));
    document.getElementById('result-customer')!.textContent = fmt(customerPrice);
  }

  // Equipment type change pre-fills rates
  document.getElementById('equipmentType')?.addEventListener('change', () => {
    onEquipmentChange();
    calculate();
  });

  // Delivery dropdown syncs custom input
  document.getElementById('delivery')?.addEventListener('change', () => {
    const val = (document.getElementById('delivery') as HTMLSelectElement).value;
    if (val !== 'custom') {
      (document.getElementById('deliveryCustom') as HTMLInputElement).value = val;
    }
    calculate();
  });

  // Auto-calculate on any input change
  document.querySelectorAll('#rental-calc input, #rental-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
