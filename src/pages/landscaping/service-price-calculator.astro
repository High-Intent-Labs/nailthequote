---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/landscapingTools';

const tool = getToolBySlug('service-price-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much should I charge for lawn mowing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most landscapers charge $35 to $75 per visit for a standard residential lawn (5,000-10,000 sq ft) for basic mowing, edging, and blowing. Smaller properties under 5,000 sq ft typically run $30 to $50. Larger properties over a quarter acre range from $60 to $120+. Your price needs to cover your labor, equipment wear, fuel, travel time, and profit. A good rule of thumb is to charge at least $1 per minute on site with a minimum of $35 per stop."
      }
    },
    {
      "@type": "Question",
      "name": "How do I price a full maintenance contract?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A full maintenance contract bundles mowing, edging, blowing, trimming, bed maintenance, and seasonal cleanup into a monthly or annual price. Start by calculating your per-visit cost for each service, multiply by the number of visits per year, add seasonal work like spring and fall cleanups, then divide by 12 for a monthly price. Full maintenance contracts typically run 2x to 3x the cost of mow-only service because of the additional labor and materials."
      }
    },
    {
      "@type": "Question",
      "name": "How many visits per year should I plan for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In most US climates, plan for 28 to 34 mowing visits per year (weekly during the growing season). Southern states may need 36 to 42 visits. Northern states with short seasons may only need 24 to 28. Full maintenance adds 2 to 4 seasonal cleanup visits, 3 to 6 hedge trimming visits, and monthly bed maintenance. Build your annual visit count based on your local growing season and the specific services included."
      }
    },
    {
      "@type": "Question",
      "name": "Should I charge monthly or per visit for landscaping services?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Monthly billing is better for your cash flow and customer retention. Calculate your annual revenue for the property, divide by 12, and bill the same amount every month regardless of visit count. This smooths out seasonal variation and keeps revenue predictable through slower months. Per-visit billing works for mow-only customers who want flexibility, but your revenue drops to zero in the off-season."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="service-calc">
    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="serviceType">Service Type</label>
        <select id="serviceType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="mow-only" selected>Mow / Edge / Blow Only</option>
          <option value="basic-maintenance">Basic Maintenance (mow + trim + beds)</option>
          <option value="full-maintenance">Full Maintenance (all services)</option>
          <option value="seasonal">Seasonal Cleanup Only</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="propertySize">Property Size</label>
        <select id="propertySize" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="small">Small (under 5,000 sq ft)</option>
          <option value="medium" selected>Medium (5,000 - 10,000 sq ft)</option>
          <option value="large">Large (10,000 - 20,000 sq ft)</option>
          <option value="xlarge">X-Large (20,000 - 43,560 sq ft / 1 acre)</option>
          <option value="estate">Estate (1+ acre)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="visitFrequency">Visit Frequency</label>
        <select id="visitFrequency" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="weekly" selected>Weekly</option>
          <option value="biweekly">Biweekly</option>
          <option value="10day">Every 10 Days</option>
          <option value="seasonal-only">Seasonal Only (spring/fall)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="growingSeason">Growing Season (weeks)</label>
        <input type="number" id="growingSeason" value="30" min="16" max="48" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Typical: 24-28 North, 30-34 Mid, 36-42 South</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="propertyCondition">Lawn Condition</label>
        <select id="propertyCondition" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="well-kept" selected>Well-Kept</option>
          <option value="average">Average</option>
          <option value="overgrown">Overgrown / Neglected</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="obstacles">Obstacles / Difficulty</label>
        <select id="obstacles" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="easy" selected>Easy (open yard, few beds)</option>
          <option value="moderate">Moderate (fenced, beds, trees)</option>
          <option value="difficult">Difficult (slopes, tight gates, many beds)</option>
        </select>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Your Pricing</h3>

      <!-- Primary Results -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-6 text-center border border-accent/30">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Price per Visit</div>
          <div id="result-per-visit" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-6 text-center border border-accent/30">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Monthly Price</div>
          <div id="result-monthly" class="font-heading font-extrabold text-3xl text-accent">--</div>
          <div class="text-text-muted text-xs mt-1">billed 12 months</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-6 text-center border border-accent/30">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Revenue</div>
          <div id="result-annual" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
      </div>

      <!-- Detail Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Visits per Year</div>
          <div id="result-visits" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Est. Time on Site</div>
          <div id="result-time" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">minutes per visit</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Revenue per Hour</div>
          <div id="result-per-hour" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">on-site time</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Revenue per Sq Ft</div>
          <div id="result-per-sqft" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">per visit</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">Pricing estimate based on industry averages. Adjust for your local market, overhead, crew size, and target profit margins. Travel time and drive distance between stops should also factor into your per-property pricing.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the service type.</strong> Mow-only is your base service. Basic maintenance adds hedge trimming and bed weeding. Full maintenance includes everything from mowing to seasonal cleanups, pruning, and bed care. Seasonal-only covers spring and fall cleanup visits.</p>
          <p><strong class="text-text-primary">2. Set the property size and visit frequency.</strong> Larger properties take more time per visit and cost more. Weekly visits are standard during the growing season. Biweekly is cheaper per month but costs more per visit because the grass is taller and takes longer to cut.</p>
          <p><strong class="text-text-primary">3. Enter your growing season length.</strong> This determines the number of mowing visits per year. Northern climates might get 24 weeks. Southern climates can stretch to 42 weeks. The calculator uses this to compute annual revenue and monthly billing amounts.</p>
          <p><strong class="text-text-primary">4. Review the pricing breakdown.</strong> The per-visit price is what each stop earns. The monthly price is for 12-month billing. The annual revenue is the total contract value. Compare revenue per hour to make sure the property is worth your time.</p>
        </div>
      </section>

      <!-- How Pricing Works -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How Recurring Service Pricing Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Price per minute is your core metric.</strong> You need to know how many minutes each property takes and what you earn per minute on site. If your target is $1.50 per minute and a property takes 40 minutes, your minimum price is $60 per visit. Everything else flows from there.</p>
          <p><strong class="text-text-primary">Monthly billing smooths your revenue.</strong> Calculate the total annual value of the contract, then divide by 12. The customer pays the same amount January through December even though you mow 30 times in summer and zero times in winter. This keeps your cash flow steady and reduces seasonal revenue swings.</p>
          <p><strong class="text-text-primary">Full maintenance contracts are more profitable.</strong> Bundling services into one contract increases the per-property revenue without proportionally increasing your travel time and overhead. A full maintenance contract might be 2.5x the mow-only price, but it does not take 2.5x the time because you are already on site.</p>
          <p><strong class="text-text-primary">Biweekly customers need a premium.</strong> Cutting every two weeks means taller grass, more clippings, and slower mowing. Biweekly per-visit prices should be 20-30% higher than weekly prices. Do not give a discount for fewer visits because each visit takes longer and creates more wear on your equipment.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Quoting new customers.</strong> Walk the property, estimate the size and difficulty, then plug those numbers into this calculator. Give the homeowner a per-visit or monthly price on the spot. Quick quoting closes more deals because the customer does not have to wait for a follow-up email or call.</p>
          <p><strong class="text-text-primary">Upselling existing mow-only customers.</strong> Run the numbers for basic or full maintenance and show your mow-only customer the monthly difference. When they see that full service is only $80 more per month than mowing alone, many will upgrade because the convenience is worth it.</p>
          <p><strong class="text-text-primary">Annual price reviews.</strong> Every year your costs go up for fuel, insurance, labor, and equipment. Run your route through this calculator with current rates to see if your pricing is still hitting your margin targets. If not, it is time for a price increase letter.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much should I charge for lawn mowing?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most landscapers charge $35 to $75 per visit for a standard residential lawn (5,000-10,000 sq ft) for basic mowing, edging, and blowing. Smaller properties under 5,000 sq ft typically run $30 to $50. Larger properties over a quarter acre range from $60 to $120+. Your price needs to cover your labor, equipment wear, fuel, travel time, and profit. A good rule of thumb is to charge at least $1 per minute on site with a minimum of $35 per stop.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I price a full maintenance contract?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A full maintenance contract bundles mowing, edging, blowing, trimming, bed maintenance, and seasonal cleanup into a monthly or annual price. Start by calculating your per-visit cost for each service, multiply by the number of visits per year, add seasonal work like spring and fall cleanups, then divide by 12 for a monthly price. Full maintenance contracts typically run 2x to 3x the cost of mow-only service because of the additional labor and materials.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many visits per year should I plan for?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">In most US climates, plan for 28 to 34 mowing visits per year (weekly during the growing season). Southern states may need 36 to 42 visits. Northern states with short seasons may only need 24 to 28. Full maintenance adds 2 to 4 seasonal cleanup visits, 3 to 6 hedge trimming visits, and monthly bed maintenance. Build your annual visit count based on your local growing season and the specific services included.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I charge monthly or per visit for landscaping services?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Monthly billing is better for your cash flow and customer retention. Calculate your annual revenue for the property, divide by 12, and bill the same amount every month regardless of visit count. This smooths out seasonal variation and keeps revenue predictable through slower months. Per-visit billing works for mow-only customers who want flexibility, but your revenue drops to zero in the off-season.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate(): void {
    const serviceType = (document.getElementById('serviceType') as HTMLSelectElement).value;
    const propertySize = (document.getElementById('propertySize') as HTMLSelectElement).value;
    const visitFrequency = (document.getElementById('visitFrequency') as HTMLSelectElement).value;
    const growingSeason = parseInt((document.getElementById('growingSeason') as HTMLInputElement).value) || 30;
    const condition = (document.getElementById('propertyCondition') as HTMLSelectElement).value;
    const obstacles = (document.getElementById('obstacles') as HTMLSelectElement).value;

    // Base per-visit price by property size (mow-only)
    const basePrices: Record<string, number> = {
      small: 40,
      medium: 55,
      large: 80,
      xlarge: 120,
      estate: 200,
    };
    const basePrice = basePrices[propertySize] ?? 55;

    // Approximate sq ft for revenue per sq ft calculation
    const sqftEstimate: Record<string, number> = {
      small: 3500,
      medium: 7500,
      large: 15000,
      xlarge: 30000,
      estate: 50000,
    };
    const sqft = sqftEstimate[propertySize] ?? 7500;

    // Time on site in minutes (mow-only base)
    const baseTimes: Record<string, number> = {
      small: 25,
      medium: 40,
      large: 60,
      xlarge: 90,
      estate: 150,
    };
    const baseTime = baseTimes[propertySize] ?? 40;

    // Service type multiplier (affects price and time)
    const serviceMultipliers: Record<string, { price: number; time: number }> = {
      'mow-only':          { price: 1.0,  time: 1.0  },
      'basic-maintenance': { price: 1.6,  time: 1.4  },
      'full-maintenance':  { price: 2.5,  time: 2.0  },
      'seasonal':          { price: 3.0,  time: 3.5  }, // per visit is higher, fewer visits
    };
    const serviceFactor = serviceMultipliers[serviceType] ?? serviceMultipliers['mow-only'];

    // Condition multiplier
    const conditionMultipliers: Record<string, number> = {
      'well-kept': 1.0,
      'average': 1.1,
      'overgrown': 1.3,
    };
    const condFactor = conditionMultipliers[condition] ?? 1.0;

    // Obstacle multiplier
    const obstacleMultipliers: Record<string, number> = {
      easy: 1.0,
      moderate: 1.15,
      difficult: 1.30,
    };
    const obstFactor = obstacleMultipliers[obstacles] ?? 1.0;

    // Frequency multiplier (biweekly costs more per visit)
    const freqPriceMultiplier: Record<string, number> = {
      weekly: 1.0,
      biweekly: 1.25,
      '10day': 1.10,
      'seasonal-only': 1.0,
    };
    const freqPriceFactor = freqPriceMultiplier[visitFrequency] ?? 1.0;

    // Calculate visits per year
    let visitsPerYear: number;
    if (serviceType === 'seasonal') {
      visitsPerYear = 4; // spring + fall cleanups
    } else if (visitFrequency === 'weekly') {
      visitsPerYear = growingSeason;
    } else if (visitFrequency === 'biweekly') {
      visitsPerYear = Math.round(growingSeason / 2);
    } else if (visitFrequency === '10day') {
      visitsPerYear = Math.round((growingSeason * 7) / 10);
    } else {
      visitsPerYear = 4;
    }

    // Add seasonal cleanup visits for maintenance plans
    if (serviceType === 'basic-maintenance') {
      visitsPerYear += 2; // spring + fall light cleanup
    } else if (serviceType === 'full-maintenance') {
      visitsPerYear += 6; // spring cleanup, fall cleanup, extra trim/bed visits
    }

    // Final per-visit price
    const perVisit = Math.round(basePrice * serviceFactor.price * condFactor * obstFactor * freqPriceFactor);

    // Time on site
    const timeOnSite = Math.round(baseTime * serviceFactor.time * condFactor * obstFactor);

    // Annual revenue
    const annualRevenue = perVisit * visitsPerYear;

    // Monthly price (12-month billing)
    const monthlyPrice = Math.round(annualRevenue / 12);

    // Revenue per hour (on-site time)
    const revenuePerHour = timeOnSite > 0 ? Math.round((perVisit / timeOnSite) * 60) : 0;

    // Revenue per sq ft
    const revenuePerSqFt = sqft > 0 ? (perVisit / sqft) : 0;

    const fmt = (n: number): string => '$' + n.toLocaleString();

    document.getElementById('result-per-visit')!.textContent = fmt(perVisit);
    document.getElementById('result-monthly')!.textContent = fmt(monthlyPrice);
    document.getElementById('result-annual')!.textContent = fmt(annualRevenue);
    document.getElementById('result-visits')!.textContent = visitsPerYear.toString();
    document.getElementById('result-time')!.textContent = timeOnSite.toString();
    document.getElementById('result-per-hour')!.textContent = fmt(revenuePerHour);
    document.getElementById('result-per-sqft')!.textContent = '$' + revenuePerSqFt.toFixed(3);
  }

  // Auto-calculate on any input change
  document.querySelectorAll('#service-calc select, #service-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
