---
// Internal-only preview of the post-submit results screen on /hvac/load-calculator
// for each of the five personas captured by the qualifying questions
// (segment + is_diy + contractor_stage). Not linked from anywhere on the site;
// noindex; excluded from sitemap. Built so Alison @ Angi can see what users
// currently see — desktop and mobile, side by side.
//
// Note: iframes were considered but blocked by the site-wide CSP
// `frame-ancestors 'none'` + Cloudflare _headers' additive (not override)
// behavior. Instead, we inline the markup at two device widths via the
// InternalHvacResultsPreview component.
import '../styles/global.css';
import InternalHvacResultsPreview from '../components/InternalHvacResultsPreview.astro';

const personas = [
  {
    id: 'not_yet',
    label: 'Home + Hiring + "Not yet started"',
    badge: '🟢🟢🟢',
    note: 'Highest-intent bucket — homeowner ready to hire, has not yet contacted any pro. Routes to Angi HVAC service request (category 10211).',
    cta: {
      headline: 'Ready to hire? Get quotes from Angi-vetted HVAC pros.',
      body: 'Share your zip, system size, and project scope, and Angi will connect you with background-checked pros near you who can quote the job.',
      button: 'Get My Free Quotes',
      href: 'https://request.angi.com/service-request/category/10211?utm_source=nailthequote&utm_medium=calculator&utm_campaign=load_calc&utm_content=home_hiring_not_yet',
    },
  },
  {
    id: 'has_estimates',
    label: 'Home + Hiring + "Already have estimates"',
    badge: '🟡',
    note: 'Mid-intent — homeowner has at least one quote, may be comparison-shopping. Routes to Angi HVAC.',
    cta: {
      headline: "Before you pick a quote, make sure it's fair.",
      body: 'Quotes for the same HVAC job can vary a lot between contractors. The most reliable way to know yours is reasonable is to compare it with more quotes for the same job.',
      button: 'Get More Quotes',
      href: 'https://request.angi.com/service-request/category/10211?utm_source=nailthequote&utm_medium=calculator&utm_campaign=load_calc&utm_content=home_hiring_has_estimates',
    },
  },
  {
    id: 'researching',
    label: 'Home + Hiring + "Just researching"',
    badge: '🟡',
    note: 'Mid-intent — homeowner browsing pros, not actively hiring yet. Routes to Angi HVAC.',
    cta: {
      headline: 'Browse Angi-vetted HVAC pros in your area.',
      body: "See profiles, reviews, and typical project photos from local contractors. Request a quote only when you're ready.",
      button: 'Browse HVAC Pros',
      href: 'https://request.angi.com/service-request/category/10211?utm_source=nailthequote&utm_medium=calculator&utm_campaign=load_calc&utm_content=home_hiring_researching',
    },
  },
  {
    id: 'diy',
    label: 'Home + DIY',
    badge: '🔴',
    note: 'Lower HVAC intent (won’t hire an HVAC pro), but the 240V hookup still needs an electrician → routes to Angi Electrical (category 12026).',
    cta: {
      headline: 'Doing it yourself? The 240V hookup still needs a licensed electrician.',
      body: 'A new HVAC system requires a dedicated 240V circuit. Most states require a licensed electrician for the wiring, and most manufacturers require it for warranty validity.',
      button: 'Get a Free Electrician Quote',
      href: 'https://request.angi.com/service-request/category/12026?utm_source=nailthequote&utm_medium=calculator&utm_campaign=load_calc&utm_content=home_diy_electrical',
    },
  },
  {
    id: 'pro',
    label: 'Pro / Contractor',
    badge: '⚫',
    note: 'HVAC contractor using the tool to size a job → routed to Angi pro signup.',
    cta: {
      headline: 'Need more customers? Join Angi as a pro.',
      body: 'Angi is one of the largest networks connecting homeowners with local contractors. Join to receive homeowner leads in the trades and areas you serve.',
      button: 'Become an Angi Pro',
      href: 'https://signup.angi.com/pro?utm_source=nailthequote&utm_medium=calculator&utm_campaign=load_calc&utm_content=pro_signup',
    },
  },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Internal: HVAC Load Calculator confirmation pages by persona</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-bg-dark text-text-primary min-h-screen">
  <div class="max-w-[1500px] mx-auto px-6 md:px-12 py-10">
    <header class="mb-12">
      <p class="text-text-muted text-xs font-semibold uppercase tracking-wider mb-3">Internal preview &middot; not linked from the site &middot; noindex</p>
      <h1 class="font-heading font-extrabold text-3xl md:text-5xl tracking-tight mb-4">HVAC Load Calculator &mdash; confirmation page by persona</h1>
      <p class="text-text-primary text-base md:text-lg max-w-3xl mb-3">
        After a homeowner or pro submits the wizard on
        <a class="text-accent underline" href="/hvac/load-calculator/" target="_blank" rel="noopener">/hvac/load-calculator</a>,
        the page reveals a results card (cooling/heating load + tonnage) plus a persona-specific Angi CTA.
        The persona is set by the segment + is_diy + contractor_stage answers captured during the wizard.
      </p>
      <p class="text-text-muted text-sm max-w-3xl">
        Sample data shown: 2,000 sqft home, 8&prime; ceilings, mixed climate &rarr; 30,000 BTU cooling / 36,000 BTU heating / 2.5 tons. Numbers vary per submission; layout and CTA copy do not.
      </p>
    </header>

    {personas.map((p) => (
      <section class="mb-16">
        <div class="mb-2 flex items-baseline gap-3 flex-wrap">
          <span class="text-2xl leading-none">{p.badge}</span>
          <h2 class="font-heading font-bold text-2xl md:text-3xl">{p.label}</h2>
        </div>
        <p class="text-text-muted text-sm mb-6 max-w-3xl">{p.note}</p>
        <div class="flex flex-wrap gap-8 items-start">
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-2">Desktop &middot; 720px width</h3>
            <InternalHvacResultsPreview persona={p} device="desktop" />
          </div>
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-2">Mobile &middot; 375px width</h3>
            <InternalHvacResultsPreview persona={p} device="mobile" />
          </div>
        </div>
      </section>
    ))}
  </div>
</body>
</html>
