---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/roofingTools';

const tool = getToolBySlug('flashing-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I calculate flashing for a hip roof?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For hip roofs, calculate hip rafter length using the hip factor for your pitch. Multiply the building depth divided by 2 by the hip factor. For an 8/12 pitch, the hip factor is 1.1744. A 50-foot deep building has a hip run of 25 feet, so each hip rafter is about 29.4 feet long. Multiply by the number of hips (typically 4) for total hip flashing."
      }
    },
    {
      "@type": "Question",
      "name": "How many ridge cap bundles do I need?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "One bundle of ridge cap shingles covers approximately 35 linear feet of ridge or hip. Measure the total ridge and hip length, then divide by 35 and round up. A roof with 30 feet of ridge and 60 feet of hip needs 90 feet total, or 3 bundles of ridge cap."
      }
    },
    {
      "@type": "Question",
      "name": "How much flashing do I need per penetration?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standard allowances: vent pipe boots need about 8 linear feet of flashing each, chimneys need about 15 feet (step + counter flashing), and skylights need about 20 feet each. These are estimates — actual measurements should be verified on-site."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="flash-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="buildingLength">Building Length (ft)</label>
        <input type="number" id="buildingLength" value="50" min="10" max="500" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="buildingDepth">Building Width/Depth (ft)</label>
        <input type="number" id="buildingDepth" value="30" min="10" max="500" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="pitch">Roof Pitch</label>
        <select id="pitch" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="4">4/12</option>
          <option value="5">5/12</option>
          <option value="6" selected>6/12</option>
          <option value="7">7/12</option>
          <option value="8">8/12</option>
          <option value="10">10/12</option>
          <option value="12">12/12</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="roofType">Roof Type</label>
        <select id="roofType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="gable" selected>Gable</option>
          <option value="hip">Hip</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="valleys">Number of Valleys</label>
        <select id="valleys" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="0" selected>0</option>
          <option value="1">1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4+</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="penetrations">Penetrations</label>
        <div class="grid grid-cols-3 gap-2">
          <div>
            <label class="block text-xs text-text-muted mb-1">Vent Pipes</label>
            <input type="number" id="ventPipes" value="3" min="0" max="20" class="w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Chimneys</label>
            <input type="number" id="chimneys" value="1" min="0" max="5" class="w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Skylights</label>
            <input type="number" id="skylights" value="0" min="0" max="10" class="w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" />
          </div>
        </div>
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Ridge Length</div>
          <div id="result-ridge" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">linear feet</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Hip Length (total)</div>
          <div id="result-hip" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">linear feet</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Valley Length (total)</div>
          <div id="result-valley" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">linear feet</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Penetration Flashing</div>
          <div id="result-pen" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">linear feet</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Flashing</div>
          <div id="result-total" class="font-heading font-extrabold text-3xl text-accent">--</div>
          <div class="text-text-muted text-xs mt-1">linear feet</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Ridge Cap Bundles</div>
          <div id="result-ridgecap" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">35 ft/bundle</div>
        </div>
      </div>
      <p class="text-text-muted text-sm italic">Exact measurements should be verified on the roof. Hip/valley factors are based on simplified geometry. This is an estimate for material ordering purposes.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter building dimensions.</strong> Length is the longer side of the building. Width/depth is the shorter side (the direction the roof slopes down).</p>
          <p><strong class="text-text-primary">2. Select the roof pitch.</strong> The pitch affects the hip and valley rafter lengths. Steeper pitches mean longer hip and valley runs.</p>
          <p><strong class="text-text-primary">3. Choose the roof type.</strong> Gable roofs have a ridge but no hips. Hip roofs have both a ridge and 4 hip rafters.</p>
          <p><strong class="text-text-primary">4. Add valleys and penetrations.</strong> Each valley adds a diagonal run of flashing. Vent pipes, chimneys, and skylights each require their own flashing kits.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Flashing Formula Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>The calculator uses hip/valley factors based on pitch to estimate diagonal rafter lengths from the building dimensions.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Hip_Factor = sqrt((Rise^2 + 144) / 144)</p>
            <p>Hip_Run = Building_Depth / 2</p>
            <p>Hip_Rafter_Length = Hip_Run x Hip_Factor</p>
            <p>Valley_Length = Hip_Rafter_Length (same calc)</p>
            <p>Ridge_Cap_Bundles = ceil((Ridge + Hips) / 35)</p>
          </div>
          <p>Penetration flashing is estimated at 8 linear feet per vent pipe, 15 feet per chimney, and 20 feet per skylight. These are standard industry allowances for material ordering.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate flashing for a hip roof?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For hip roofs, calculate hip rafter length using the hip factor for your pitch. Multiply the building depth divided by 2 by the hip factor. For an 8/12 pitch, the hip factor is 1.1744. A 50-foot deep building has a hip run of 25 feet, so each hip rafter is about 29.4 feet long. Multiply by the number of hips (typically 4) for total hip flashing.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many ridge cap bundles do I need?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">One bundle of ridge cap shingles covers approximately 35 linear feet of ridge or hip. Measure the total ridge and hip length, then divide by 35 and round up. A roof with 30 feet of ridge and 60 feet of hip needs 90 feet total, or 3 bundles of ridge cap.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much flashing do I need per penetration?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Standard allowances: vent pipe boots need about 8 linear feet of flashing each, chimneys need about 15 feet (step + counter flashing), and skylights need about 20 feet each. These are estimates — actual measurements should be verified on-site.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const length = parseFloat((document.getElementById('buildingLength') as HTMLInputElement).value) || 50;
    const depth = parseFloat((document.getElementById('buildingDepth') as HTMLInputElement).value) || 30;
    const rise = parseFloat((document.getElementById('pitch') as HTMLSelectElement).value);
    const roofType = (document.getElementById('roofType') as HTMLSelectElement).value;
    const numValleys = parseInt((document.getElementById('valleys') as HTMLSelectElement).value) || 0;
    const ventPipes = parseInt((document.getElementById('ventPipes') as HTMLInputElement).value) || 0;
    const chimneys = parseInt((document.getElementById('chimneys') as HTMLInputElement).value) || 0;
    const skylights = parseInt((document.getElementById('skylights') as HTMLInputElement).value) || 0;

    const hipFactor = Math.sqrt((rise * rise + 144) / 144);
    const hipRun = depth / 2;
    const hipRafterLength = hipRun * hipFactor;

    let ridgeLength: number;
    let totalHipLength: number;

    if (roofType === 'hip') {
      ridgeLength = Math.max(0, length - depth);
      totalHipLength = hipRafterLength * 4;
    } else {
      ridgeLength = length;
      totalHipLength = 0;
    }

    const totalValleyLength = numValleys * hipRafterLength;
    const penFlashing = (ventPipes * 8) + (chimneys * 15) + (skylights * 20);
    const totalFlashing = totalHipLength + totalValleyLength + penFlashing;

    const ridgeCapLength = ridgeLength + totalHipLength;
    const ridgeCapBundles = ridgeCapLength > 0 ? Math.ceil(ridgeCapLength / 35) : 0;

    document.getElementById('result-ridge')!.textContent = ridgeLength.toFixed(1);
    document.getElementById('result-hip')!.textContent = totalHipLength.toFixed(1);
    document.getElementById('result-valley')!.textContent = totalValleyLength.toFixed(1);
    document.getElementById('result-pen')!.textContent = penFlashing.toString();
    document.getElementById('result-total')!.textContent = Math.round(totalFlashing).toLocaleString();
    document.getElementById('result-ridgecap')!.textContent = ridgeCapBundles.toString();
  }

  document.querySelectorAll('#flash-calc input, #flash-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
