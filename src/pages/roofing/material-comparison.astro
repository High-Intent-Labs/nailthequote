---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/roofingTools';

const tool = getToolBySlug('material-comparison')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What roofing material has the best cost per year?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standing seam metal and architectural asphalt shingles typically offer the lowest cost per year when you divide total installed cost by expected lifespan. Architectural shingles run $120-160 per square installed and last 25-30 years, working out to roughly $4-6 per square per year. Standing seam metal costs $300-500 per square but lasts 40-60 years, landing at $5-12 per square per year. The best lifetime value depends on the specific roof size and local pricing."
      }
    },
    {
      "@type": "Question",
      "name": "How many squares is a typical residential roof?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The average residential roof in the United States is 25 to 35 squares, with 30 squares being a common default for estimating. A roofing square equals 100 square feet. A 1,500 square foot ranch-style home typically has 18-22 squares, while a 2,500 square foot two-story home with a steep pitch can run 35-45 squares. Always measure or use satellite tools for accurate square counts before quoting."
      }
    },
    {
      "@type": "Question",
      "name": "How do I explain cost per year to a customer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cost per year divides the total installed price by the expected lifespan of the material. It shows the customer what they are actually paying annually for their roof. For example, a $15,000 architectural shingle roof that lasts 30 years costs $500 per year. A $40,000 standing seam metal roof that lasts 50 years costs $800 per year but requires virtually no maintenance. This metric helps customers see past sticker shock and compare true long-term value."
      }
    },
    {
      "@type": "Question",
      "name": "Should I show customers all seven materials or just two or three?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Show two or three materials that match the customer's budget and goals. Presenting too many options causes decision paralysis. A strong approach is to show a budget option like 3-tab shingles, a mid-range pick like architectural shingles, and one premium option like standing seam metal or synthetic slate. This gives the customer a clear good-better-best framework and keeps the conversation focused."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="material-comp">
    <!-- Roof Size Input -->
    <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
      <h3 class="font-heading font-bold text-lg text-text-primary mb-1">Roof Size</h3>
      <p class="text-text-muted text-xs mb-5">Enter the total roof area in squares (1 square = 100 sq ft)</p>
      <div class="max-w-xs">
        <label class="block text-sm font-medium text-text-secondary mb-1" for="roof-squares">Roof Size (squares)</label>
        <input type="number" id="roof-squares" value="30" min="1" max="200" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Average residential roof is 25-35 squares</p>
      </div>
    </div>

    <!-- Material Selection -->
    <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
      <h3 class="font-heading font-bold text-lg text-text-primary mb-1">Select Materials to Compare</h3>
      <p class="text-text-muted text-xs mb-5">Pick 2 or 3 materials to show the customer side by side</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <label class="flex items-center gap-3 bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent transition-colors">
          <input type="checkbox" id="mat-3tab" value="3tab" class="mat-checkbox w-4 h-4 accent-accent" />
          <span class="text-text-primary text-sm">3-Tab Asphalt Shingles</span>
        </label>
        <label class="flex items-center gap-3 bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent transition-colors">
          <input type="checkbox" id="mat-arch" value="arch" class="mat-checkbox w-4 h-4 accent-accent" checked />
          <span class="text-text-primary text-sm">Architectural Asphalt</span>
        </label>
        <label class="flex items-center gap-3 bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent transition-colors">
          <input type="checkbox" id="mat-metal" value="metal" class="mat-checkbox w-4 h-4 accent-accent" checked />
          <span class="text-text-primary text-sm">Standing Seam Metal</span>
        </label>
        <label class="flex items-center gap-3 bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent transition-colors">
          <input type="checkbox" id="mat-stone" value="stone" class="mat-checkbox w-4 h-4 accent-accent" />
          <span class="text-text-primary text-sm">Stone-Coated Steel</span>
        </label>
        <label class="flex items-center gap-3 bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent transition-colors">
          <input type="checkbox" id="mat-concrete" value="concrete" class="mat-checkbox w-4 h-4 accent-accent" />
          <span class="text-text-primary text-sm">Concrete Tile</span>
        </label>
        <label class="flex items-center gap-3 bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent transition-colors">
          <input type="checkbox" id="mat-cedar" value="cedar" class="mat-checkbox w-4 h-4 accent-accent" />
          <span class="text-text-primary text-sm">Cedar Shake</span>
        </label>
        <label class="flex items-center gap-3 bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent transition-colors">
          <input type="checkbox" id="mat-synslate" value="synslate" class="mat-checkbox w-4 h-4 accent-accent" checked />
          <span class="text-text-primary text-sm">Synthetic Slate</span>
        </label>
      </div>
      <p id="selection-warning" class="text-red-400 text-xs mt-3 hidden">Select 2 or 3 materials to compare.</p>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <!-- Comparison Cards -->
      <h3 class="font-heading font-bold text-xl mb-6">Side-by-Side Comparison</h3>
      <div id="comparison-cards" class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <!-- Cards injected by JS -->
      </div>

      <!-- Cost Bar Chart -->
      <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Total Installed Cost</h4>
        <div id="cost-bars" class="space-y-4">
          <!-- Bars injected by JS -->
        </div>
      </div>

      <!-- Cost Per Year Bar Chart -->
      <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Cost Per Year (Lifetime Value)</h4>
        <div id="yearly-bars" class="space-y-4">
          <!-- Bars injected by JS -->
        </div>
      </div>

      <!-- Summary Cards -->
      <h3 class="font-heading font-bold text-xl mb-6">Quick Numbers</h3>
      <div id="summary-cards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        <!-- Summary injected by JS -->
      </div>

      <p class="text-text-muted text-sm italic">Estimates based on national average installed pricing. Actual costs vary by region, roof complexity, and material availability. Use these figures as a starting point when walking customers through their options.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Tool</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the roof size.</strong> Measure the roof in squares or use a satellite measurement tool. The default is 30 squares, which covers most average-sized residential roofs. Adjust up or down to match the job you are quoting.</p>
          <p><strong class="text-text-primary">2. Pick 2 or 3 materials.</strong> Select the options that fit the customer's budget and goals. A good approach is one budget option, one mid-range, and one premium. Showing more than three usually causes decision paralysis.</p>
          <p><strong class="text-text-primary">3. Walk through the comparison cards.</strong> Each card shows installed cost range, expected lifespan, maintenance level, wind resistance, and the cost-per-year metric. The cost-per-year number is the one that shifts the conversation from sticker price to lifetime value.</p>
          <p><strong class="text-text-primary">4. Use the bar charts during the conversation.</strong> Pull this up on your tablet or laptop at the kitchen table. The visual bars make the cost differences immediately clear without the customer needing to do math.</p>
        </div>
      </section>

      <!-- Understanding Roofing Materials -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Understanding Roofing Material Options</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">3-Tab Asphalt Shingles</strong> are the entry-level option. They get the job done at the lowest upfront cost but have the shortest lifespan and weakest wind resistance. Best for budget-conscious customers, rental properties, or homes being prepped for sale. They lay flat with a uniform look that some customers find dated.</p>
          <p><strong class="text-text-primary">Architectural Asphalt Shingles</strong> are the most popular residential roofing material in the country. The dimensional profile gives a more textured appearance, they handle wind better than 3-tab, and the 25-30 year lifespan makes them a solid mid-range choice. This is your bread-and-butter option for most jobs.</p>
          <p><strong class="text-text-primary">Standing Seam Metal</strong> is the premium performer. The higher upfront cost is offset by a 40-60 year lifespan, virtually zero maintenance, and excellent wind and fire resistance. Energy-conscious customers like it because it reflects heat. The cost-per-year number on metal roofs often surprises customers who only looked at the sticker price.</p>
          <p><strong class="text-text-primary">Stone-Coated Steel, Concrete Tile, Cedar Shake, and Synthetic Slate</strong> each serve specific niches. Stone-coated steel gives a tile look with metal durability. Concrete tile dominates in the Southwest. Cedar shake appeals to customers wanting a natural aesthetic but requires real maintenance commitment. Synthetic slate delivers the look of natural slate at a fraction of the weight and cost.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">During the estimate, at the kitchen table.</strong> Pull this up on your tablet while sitting with the homeowner. Enter their roof size, check two or three materials, and let the side-by-side comparison do the talking. Customers respond to visuals more than verbal explanations, and the bar charts make the value proposition instantly clear.</p>
          <p><strong class="text-text-primary">When a customer has sticker shock on premium materials.</strong> The cost-per-year metric is your best tool for reframing the conversation. A $40,000 metal roof sounds expensive until the customer sees it costs $800 per year over 50 years versus $500 per year for shingles that need replacing twice in the same period. Factor in the second tear-off and the math shifts fast.</p>
          <p><strong class="text-text-primary">When building good-better-best proposals.</strong> Select 3-tab, architectural, and one premium option. Screenshot the comparison and attach it to your written proposal. It gives the customer a clear framework for their decision and positions you as the contractor who actually helped them think it through.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What roofing material has the best cost per year?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Standing seam metal and architectural asphalt shingles typically offer the lowest cost per year when you divide total installed cost by expected lifespan. Architectural shingles run $120-160 per square installed and last 25-30 years, working out to roughly $4-6 per square per year. Standing seam metal costs $300-500 per square but lasts 40-60 years, landing at $5-12 per square per year. The best lifetime value depends on the specific roof size and local pricing.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many squares is a typical residential roof?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The average residential roof in the United States is 25 to 35 squares, with 30 squares being a common default for estimating. A roofing square equals 100 square feet. A 1,500 square foot ranch-style home typically has 18-22 squares, while a 2,500 square foot two-story home with a steep pitch can run 35-45 squares. Always measure or use satellite tools for accurate square counts before quoting.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I explain cost per year to a customer?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Cost per year divides the total installed price by the expected lifespan of the material. It shows the customer what they are actually paying annually for their roof. For example, a $15,000 architectural shingle roof that lasts 30 years costs $500 per year. A $40,000 standing seam metal roof that lasts 50 years costs $800 per year but requires virtually no maintenance. This metric helps customers see past sticker shock and compare true long-term value.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I show customers all seven materials or just two or three?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Show two or three materials that match the customer's budget and goals. Presenting too many options causes decision paralysis. A strong approach is to show a budget option like 3-tab shingles, a mid-range pick like architectural shingles, and one premium option like standing seam metal or synthetic slate. This gives the customer a clear good-better-best framework and keeps the conversation focused.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  interface RoofingMaterial {
    key: string;
    name: string;
    costLow: number;
    costHigh: number;
    lifespanLow: number;
    lifespanHigh: number;
    maintenance: string;
    windResistance: string;
    fireResistance: string;
    energyEfficiency: string;
    color: string;
  }

  const materials: Record<string, RoofingMaterial> = {
    '3tab': {
      key: '3tab',
      name: '3-Tab Asphalt',
      costLow: 90,
      costHigh: 110,
      lifespanLow: 15,
      lifespanHigh: 20,
      maintenance: 'Low',
      windResistance: 'Poor (60-70 mph)',
      fireResistance: 'Class A',
      energyEfficiency: 'Standard',
      color: '#6b7280',
    },
    arch: {
      key: 'arch',
      name: 'Architectural Asphalt',
      costLow: 120,
      costHigh: 160,
      lifespanLow: 25,
      lifespanHigh: 30,
      maintenance: 'Low',
      windResistance: 'Good (110-130 mph)',
      fireResistance: 'Class A',
      energyEfficiency: 'Standard',
      color: '#3b82f6',
    },
    metal: {
      key: 'metal',
      name: 'Standing Seam Metal',
      costLow: 300,
      costHigh: 500,
      lifespanLow: 40,
      lifespanHigh: 60,
      maintenance: 'Minimal',
      windResistance: 'Excellent (140+ mph)',
      fireResistance: 'Class A',
      energyEfficiency: 'High (reflects heat)',
      color: '#f97316',
    },
    stone: {
      key: 'stone',
      name: 'Stone-Coated Steel',
      costLow: 350,
      costHigh: 450,
      lifespanLow: 40,
      lifespanHigh: 50,
      maintenance: 'Low',
      windResistance: 'Excellent (120+ mph)',
      fireResistance: 'Class A',
      energyEfficiency: 'High',
      color: '#a855f7',
    },
    concrete: {
      key: 'concrete',
      name: 'Concrete Tile',
      costLow: 350,
      costHigh: 500,
      lifespanLow: 40,
      lifespanHigh: 50,
      maintenance: 'Moderate',
      windResistance: 'Excellent (125+ mph)',
      fireResistance: 'Class A',
      energyEfficiency: 'High (thermal mass)',
      color: '#ef4444',
    },
    cedar: {
      key: 'cedar',
      name: 'Cedar Shake',
      costLow: 400,
      costHigh: 600,
      lifespanLow: 20,
      lifespanHigh: 30,
      maintenance: 'High',
      windResistance: 'Moderate (80-110 mph)',
      fireResistance: 'Class C (untreated)',
      energyEfficiency: 'Good (natural insulation)',
      color: '#84cc16',
    },
    synslate: {
      key: 'synslate',
      name: 'Synthetic Slate',
      costLow: 400,
      costHigh: 550,
      lifespanLow: 40,
      lifespanHigh: 50,
      maintenance: 'Low',
      windResistance: 'Good (110+ mph)',
      fireResistance: 'Class A',
      energyEfficiency: 'Standard',
      color: '#14b8a6',
    },
  };

  function formatCurrency(val: number): string {
    return '$' + val.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function getSelectedMaterials(): RoofingMaterial[] {
    const selected: RoofingMaterial[] = [];
    document.querySelectorAll<HTMLInputElement>('.mat-checkbox:checked').forEach((cb) => {
      const mat = materials[cb.value];
      if (mat) selected.push(mat);
    });
    return selected;
  }

  function calculate(): void {
    const squares = parseFloat((document.getElementById('roof-squares') as HTMLInputElement).value) || 30;
    const selected = getSelectedMaterials();

    const warning = document.getElementById('selection-warning') as HTMLElement;
    if (selected.length < 2 || selected.length > 3) {
      warning.classList.remove('hidden');
    } else {
      warning.classList.add('hidden');
    }

    if (selected.length < 2) {
      (document.getElementById('comparison-cards') as HTMLElement).innerHTML =
        '<p class="text-text-muted text-sm col-span-full">Select at least 2 materials above to see the comparison.</p>';
      (document.getElementById('cost-bars') as HTMLElement).innerHTML = '';
      (document.getElementById('yearly-bars') as HTMLElement).innerHTML = '';
      (document.getElementById('summary-cards') as HTMLElement).innerHTML = '';
      return;
    }

    const displayMaterials = selected.slice(0, 3);

    // Update grid columns based on selection count
    const cardsContainer = document.getElementById('comparison-cards') as HTMLElement;
    cardsContainer.className = displayMaterials.length === 2
      ? 'grid grid-cols-1 md:grid-cols-2 gap-6 mb-8'
      : 'grid grid-cols-1 md:grid-cols-3 gap-6 mb-8';

    // Build comparison cards
    let cardsHtml = '';
    displayMaterials.forEach((mat, idx) => {
      const totalLow = mat.costLow * squares;
      const totalHigh = mat.costHigh * squares;
      const avgTotal = (totalLow + totalHigh) / 2;
      const avgLifespan = (mat.lifespanLow + mat.lifespanHigh) / 2;
      const costPerYear = Math.round(avgTotal / avgLifespan);
      const isFirst = idx === 0;

      cardsHtml += `
        <div class="bg-bg-card border rounded-xl p-6" style="border-color: ${mat.color}40;">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-3 h-3 rounded-full" style="background: ${mat.color};"></div>
            <h4 class="font-heading font-bold text-lg text-text-primary">${mat.name}</h4>
          </div>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Cost per Square</span>
              <span class="font-heading font-bold text-text-primary">${formatCurrency(mat.costLow)}-${formatCurrency(mat.costHigh)}</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Total Installed</span>
              <span class="font-heading font-bold text-text-primary">${formatCurrency(totalLow)}-${formatCurrency(totalHigh)}</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Lifespan</span>
              <span class="font-heading font-bold text-text-primary">${mat.lifespanLow}-${mat.lifespanHigh} yrs</span>
            </div>
            <div class="border-t border-border pt-3 flex justify-between items-center">
              <span class="text-text-primary font-medium">Cost Per Year</span>
              <span class="font-heading font-extrabold text-2xl" style="color: ${mat.color};">${formatCurrency(costPerYear)}/yr</span>
            </div>
            <div class="border-t border-border pt-3 space-y-2">
              <div class="flex justify-between items-center">
                <span class="text-text-muted text-xs">Maintenance</span>
                <span class="text-text-secondary text-xs font-medium">${mat.maintenance}</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-text-muted text-xs">Wind Resistance</span>
                <span class="text-text-secondary text-xs font-medium">${mat.windResistance}</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-text-muted text-xs">Fire Rating</span>
                <span class="text-text-secondary text-xs font-medium">${mat.fireResistance}</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-text-muted text-xs">Energy Efficiency</span>
                <span class="text-text-secondary text-xs font-medium">${mat.energyEfficiency}</span>
              </div>
            </div>
          </div>
        </div>
      `;
    });
    cardsContainer.innerHTML = cardsHtml;

    // Build total cost bars
    const maxTotal = Math.max(...displayMaterials.map((m) => m.costHigh * squares), 1);
    let costBarsHtml = '';
    displayMaterials.forEach((mat) => {
      const avgTotal = ((mat.costLow + mat.costHigh) / 2) * squares;
      const pct = (avgTotal / maxTotal) * 100;
      costBarsHtml += `
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-text-secondary">${mat.name}</span>
            <span class="text-text-primary font-medium">${formatCurrency(mat.costLow * squares)} - ${formatCurrency(mat.costHigh * squares)}</span>
          </div>
          <div class="w-full bg-bg-dark rounded-full h-8 overflow-hidden">
            <div class="h-full rounded-full transition-all duration-700 ease-out" style="width: ${pct}%; background: linear-gradient(90deg, ${mat.color}cc, ${mat.color});"></div>
          </div>
        </div>
      `;
    });
    (document.getElementById('cost-bars') as HTMLElement).innerHTML = costBarsHtml;

    // Build cost-per-year bars
    const maxCpy = Math.max(
      ...displayMaterials.map((m) => {
        const avg = ((m.costLow + m.costHigh) / 2) * squares;
        const life = (m.lifespanLow + m.lifespanHigh) / 2;
        return avg / life;
      }),
      1
    );
    let yearlyBarsHtml = '';
    displayMaterials.forEach((mat) => {
      const avgTotal = ((mat.costLow + mat.costHigh) / 2) * squares;
      const avgLifespan = (mat.lifespanLow + mat.lifespanHigh) / 2;
      const cpy = avgTotal / avgLifespan;
      const pct = (cpy / maxCpy) * 100;
      yearlyBarsHtml += `
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-text-secondary">${mat.name}</span>
            <span class="text-text-primary font-medium">${formatCurrency(Math.round(cpy))}/yr</span>
          </div>
          <div class="w-full bg-bg-dark rounded-full h-8 overflow-hidden">
            <div class="h-full rounded-full transition-all duration-700 ease-out" style="width: ${pct}%; background: linear-gradient(90deg, ${mat.color}cc, ${mat.color});"></div>
          </div>
        </div>
      `;
    });
    (document.getElementById('yearly-bars') as HTMLElement).innerHTML = yearlyBarsHtml;

    // Build summary cards
    // Find cheapest upfront, best cost-per-year, longest lifespan
    let cheapest = displayMaterials[0];
    let bestValue = displayMaterials[0];
    let longestLife = displayMaterials[0];

    displayMaterials.forEach((mat) => {
      const avgCost = ((mat.costLow + mat.costHigh) / 2) * squares;
      const cheapAvg = ((cheapest.costLow + cheapest.costHigh) / 2) * squares;
      if (avgCost < cheapAvg) cheapest = mat;

      const matCpy = avgCost / ((mat.lifespanLow + mat.lifespanHigh) / 2);
      const bestCpy = (((bestValue.costLow + bestValue.costHigh) / 2) * squares) / ((bestValue.lifespanLow + bestValue.lifespanHigh) / 2);
      if (matCpy < bestCpy) bestValue = mat;

      const matLife = (mat.lifespanLow + mat.lifespanHigh) / 2;
      const longLife = (longestLife.lifespanLow + longestLife.lifespanHigh) / 2;
      if (matLife > longLife) longestLife = mat;
    });

    const cheapTotal = ((cheapest.costLow + cheapest.costHigh) / 2) * squares;
    const bestCpy = (((bestValue.costLow + bestValue.costHigh) / 2) * squares) / ((bestValue.lifespanLow + bestValue.lifespanHigh) / 2);
    const longLifeAvg = (longestLife.lifespanLow + longestLife.lifespanHigh) / 2;

    let summaryHtml = `
      <div class="bg-bg-dark rounded-xl p-5 text-center border-2" style="border-color: rgba(255,107,43,0.4);">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Lowest Upfront Cost</div>
        <div class="font-heading font-extrabold text-2xl text-accent">${formatCurrency(Math.round(cheapTotal))}</div>
        <div class="text-text-muted text-xs mt-1">${cheapest.name}</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Best Cost Per Year</div>
        <div class="font-heading font-extrabold text-2xl text-text-primary">${formatCurrency(Math.round(bestCpy))}/yr</div>
        <div class="text-text-muted text-xs mt-1">${bestValue.name}</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Longest Lifespan</div>
        <div class="font-heading font-extrabold text-2xl text-text-primary">${Math.round(longLifeAvg)} yrs</div>
        <div class="text-text-muted text-xs mt-1">${longestLife.name}</div>
      </div>
    `;
    (document.getElementById('summary-cards') as HTMLElement).innerHTML = summaryHtml;
  }

  // Enforce max 3 selections
  document.querySelectorAll<HTMLInputElement>('.mat-checkbox').forEach((cb) => {
    cb.addEventListener('change', () => {
      const checked = document.querySelectorAll<HTMLInputElement>('.mat-checkbox:checked');
      if (checked.length > 3) {
        cb.checked = false;
      }
      calculate();
    });
  });

  // Recalculate on roof size change
  document.getElementById('roof-squares')!.addEventListener('input', calculate);
  document.getElementById('roof-squares')!.addEventListener('change', calculate);

  // Calculate on load
  calculate();
</script>
