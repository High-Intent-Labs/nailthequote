---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/paintingTools';
const tool = getToolBySlug('safety-checklist')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What should a painting safety checklist cover?", "acceptedAnswer": { "@type": "Answer", "text": "A complete painting safety checklist should cover PPE requirements (respirators, goggles, gloves), ladder and scaffold safety, fall protection, ventilation for enclosed spaces, hazardous material handling (lead paint, VOCs, solvents), fire prevention, drop cloth and floor protection, electrical hazard awareness near outlets and fixtures, and proper chemical storage and disposal procedures." } },
    { "@type": "Question", "name": "What PPE is required for painting?", "acceptedAnswer": { "@type": "Answer", "text": "Required PPE depends on the job. At minimum, painters need safety glasses, nitrile or chemical-resistant gloves, and appropriate footwear. Spray painting requires a half-face respirator with organic vapor cartridges (P100/OV). Sanding and scraping require a dust mask rated N95 or higher. Lead paint abatement requires a full-face respirator, Tyvek suit, and lead-safe work area containment." } },
    { "@type": "Question", "name": "What are the OSHA requirements for painting?", "acceptedAnswer": { "@type": "Answer", "text": "OSHA requires fall protection at 6 feet for construction (including painting). Ladders must be inspected before each use and set at a 4:1 ratio. Scaffolds need guardrails, mid-rails, and toe boards. Enclosed spaces require ventilation when using solvent-based products. Lead paint disturbance requires EPA RRP certification. All hazardous chemicals need Safety Data Sheets (SDS) on site." } },
    { "@type": "Question", "name": "How do you ensure ventilation when painting indoors?", "acceptedAnswer": { "@type": "Answer", "text": "Open all windows and doors to create cross-ventilation. Use box fans to push fumes out rather than recirculate. For solvent-based paints or epoxies, set up a forced-air exhaust system. Monitor air quality if working in enclosed areas for extended periods. Take breaks in fresh air every 30-60 minutes. Never use gas-powered equipment indoors for ventilation." } }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="checklist-app">
    <!-- Progress Bar -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-text-secondary">Progress</span>
        <span id="progress-text" class="text-sm font-bold text-accent">0 of 0 items checked</span>
      </div>
      <div class="w-full bg-bg-dark rounded-full h-3 overflow-hidden">
        <div id="progress-bar" class="bg-accent h-3 rounded-full transition-all duration-300" style="width: 0%"></div>
      </div>
    </div>

    <!-- Tab Toggle -->
    <div class="flex gap-2 mb-8">
      <button id="tab-cooling" class="flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white" data-tab="cooling">
        Interior Projects
      </button>
      <button id="tab-heating" class="flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary" data-tab="heating">
        Exterior Projects
      </button>
    </div>

    <!-- ============ INTERIOR PROJECTS ============ -->
    <div id="panel-cooling">

      <!-- PPE -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Personal Protective Equipment
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Safety glasses on for scraping and sanding</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Respirator on for spray work or solvent-based products</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Chemical-resistant gloves for primers and strippers</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Appropriate footwear (closed-toe, non-slip)</span>
          </label>
        </div>
      </div>

      <!-- Ventilation -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Ventilation
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Open windows and doors for cross-ventilation</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Set up fans to push fumes out (not recirculate)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Forced exhaust for spray or epoxy applications</span>
          </label>
        </div>
      </div>

      <!-- Lead Paint / Hazmat -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Lead Paint &amp; Hazmat
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Test for lead paint if pre-1978 home</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">EPA RRP certification verified if lead present</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">SDS sheets on site for all chemicals</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">VOC precautions reviewed with crew</span>
          </label>
        </div>
      </div>

      <!-- Ladder Safety -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Ladder &amp; Fall Protection
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Inspect ladder for damage before use</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Stepladder fully open and locked</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Never stand on top two rungs of stepladder</span>
          </label>
        </div>
      </div>

      <!-- Surface Protection -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Surface Protection
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Drop cloths down and secured (no trip hazards)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Furniture covered or moved</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Fixtures, hardware, and outlets protected</span>
          </label>
        </div>
      </div>

      <!-- Fire Prevention -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Fire Prevention
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Solvent rags in sealed metal container</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Fire extinguisher on site and accessible</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No open flames near solvent-based products</span>
          </label>
        </div>
      </div>

    </div>

    <!-- ============ EXTERIOR PROJECTS ============ -->
    <div id="panel-heating" class="hidden">

      <!-- PPE (Exterior) -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Personal Protective Equipment
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Safety glasses for scraping, sanding, and power washing</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Respirator for spray applications</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Hard hat when working below overhead activities</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Sun protection (hat, sunscreen, hydration)</span>
          </label>
        </div>
      </div>

      <!-- Ladder & Scaffold (Exterior) -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Ladder &amp; Scaffold Safety
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Extension ladder at 4:1 angle ratio</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Ladder feet on firm, level ground</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Scaffold guardrails, mid-rails, and toe boards in place</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Fall protection at 6 ft or higher (OSHA requirement)</span>
          </label>
        </div>
      </div>

      <!-- Lead Paint (Exterior) -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Lead Paint &amp; Containment
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Lead test completed if pre-1978 structure</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Ground containment in place (plastic sheeting 10 ft out)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">HEPA vacuum available for lead-safe cleanup</span>
          </label>
        </div>
      </div>

      <!-- Power Washing & Surface Prep -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Power Washing &amp; Surface Prep
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Windows and doors closed before power washing</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Electrical outlets and fixtures covered</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Landscaping protected from overspray and chemicals</span>
          </label>
        </div>
      </div>

      <!-- Weather & Environmental -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Weather &amp; Environmental
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Temperature within product application range</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No rain expected during application and dry time</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wind speed safe for spray application</span>
          </label>
        </div>
      </div>

    </div>

    <!-- Results Summary -->
    <div id="results-summary" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Safety Compliance Summary</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Items Checked</div>
          <div id="summary-checked" class="font-heading font-extrabold text-3xl text-accent">0 / 0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Completion</div>
          <div id="summary-pct" class="font-heading font-extrabold text-3xl text-text-primary">0%</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Flagged Readings</div>
          <div id="summary-flags" class="font-heading font-extrabold text-3xl text-text-primary">0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Health Grade</div>
          <div id="summary-grade" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>
      <div id="flag-list" class="hidden mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Flagged Items</h4>
        <div id="flag-items" class="space-y-2"></div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-wrap gap-3 mt-6">
      <button id="generate-report" class="bg-accent text-white font-heading font-bold text-sm uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
        Generate Report &rarr;
      </button>
      <button id="reset-checklist" class="bg-bg-dark text-text-secondary border border-border font-heading font-bold text-sm uppercase tracking-wider px-8 py-3.5 rounded-lg hover:border-accent hover:text-text-primary transition-all cursor-pointer">
        Reset Checklist
      </button>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Checklist</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Choose your project type.</strong> Toggle between Interior and Exterior tabs at the top. Each tab has its own safety checklist tailored to the hazards and PPE requirements for that work environment.</p>
          <p><strong class="text-text-primary">2. Work through each section.</strong> Check off items as you verify them before starting work. Confirm PPE is on, ventilation is set up, ladders are inspected, drop cloths are down, and hazardous materials are identified. The tool flags any skipped safety items.</p>
          <p><strong class="text-text-primary">3. Monitor your progress.</strong> The progress bar updates in real time. The summary section shows your completion percentage and a safety readiness grade based on items checked and any flagged concerns.</p>
          <p><strong class="text-text-primary">4. Generate a report.</strong> When finished, hit Generate Report to create a printable safety compliance record. This documents that all safety checks were completed before work started — essential for OSHA compliance and liability protection. Your progress auto-saves.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What a Complete Painting Safety Check Covers</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Personal protective equipment.</strong> Every job starts with the right PPE. Safety glasses for scraping and sanding, respirators for spray work and solvent-based products, chemical-resistant gloves for strippers and primers, and appropriate footwear for ladder work. The checklist confirms each crew member has the right gear before anyone picks up a brush.</p>
          <p><strong class="text-text-primary">Ladder and scaffold safety.</strong> Falls are the number one cause of serious injury in painting. Inspect every ladder for bent rails, cracked rungs, and functioning locks before each use. Set extension ladders at a 4:1 angle ratio. Scaffolds need guardrails, toe boards, and level footing. Never stand on the top two rungs of a stepladder.</p>
          <p><strong class="text-text-primary">Ventilation and air quality.</strong> Solvent-based paints, epoxies, and strippers release volatile organic compounds that cause headaches, dizziness, and long-term health problems. Open windows and set up cross-ventilation with fans before applying any product indoors. For spray applications, a forced-air exhaust system is required.</p>
          <p><strong class="text-text-primary">Lead paint awareness.</strong> Any home built before 1978 may contain lead paint. Disturbing lead paint through scraping, sanding, or heat stripping creates toxic dust. EPA RRP certification is required for renovation work in pre-1978 homes. Test before disturbing any existing paint, and follow lead-safe work practices including containment, HEPA vacuuming, and wet methods.</p>
          <p><strong class="text-text-primary">Fire prevention.</strong> Solvent-soaked rags are a spontaneous combustion hazard. Store them in sealed metal containers or hang them flat to dry outdoors. Keep open flames and spark sources away from solvent-based products. Have a fire extinguisher on site and know where it is.</p>
          <p><strong class="text-text-primary">Drop cloth and surface protection.</strong> Secure drop cloths so they do not create trip hazards on ladders or stairs. Tape plastic sheeting to protect fixtures, hardware, and flooring. Cover furniture completely. Proper protection prevents damage claims and saves time on cleanup.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Before every job.</strong> Run through this checklist at the start of each project, not just when the job feels dangerous. The routine itself is the safety system. When your crew checks PPE, ladders, ventilation, and hazmat on autopilot, accidents drop and you protect your business from OSHA fines and liability claims.</p>
          <p><strong class="text-text-primary">New crew member onboarding.</strong> Hand this checklist to every new painter on their first day. It teaches them your safety standards and creates accountability from the start. When safety is built into the process rather than treated as an afterthought, it becomes part of your company culture.</p>
          <p><strong class="text-text-primary">Commercial and institutional projects.</strong> General contractors, property managers, and facility managers often require documented safety compliance before allowing subcontractors on site. This checklist generates the safety documentation they need, and having it ready before they ask sets you apart from other painting subs.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should a painting safety checklist cover?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete painting safety checklist should cover PPE requirements (respirators, goggles, gloves), ladder and scaffold safety, fall protection, ventilation for enclosed spaces, hazardous material handling (lead paint, VOCs, solvents), fire prevention, drop cloth and floor protection, electrical hazard awareness near outlets and fixtures, and proper chemical storage and disposal procedures.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What PPE is required for painting?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Required PPE depends on the job. At minimum, painters need safety glasses, nitrile or chemical-resistant gloves, and appropriate footwear. Spray painting requires a half-face respirator with organic vapor cartridges (P100/OV). Sanding and scraping require a dust mask rated N95 or higher. Lead paint abatement requires a full-face respirator, Tyvek suit, and lead-safe work area containment.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What are the OSHA requirements for painting?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">OSHA requires fall protection at 6 feet for construction (including painting). Ladders must be inspected before each use and set at a 4:1 ratio. Scaffolds need guardrails, mid-rails, and toe boards. Enclosed spaces require ventilation when using solvent-based products. Lead paint disturbance requires EPA RRP certification. All hazardous chemicals need Safety Data Sheets (SDS) on site.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do you ensure ventilation when painting indoors?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Open all windows and doors to create cross-ventilation. Use box fans to push fumes out rather than recirculate. For solvent-based paints or epoxies, set up a forced-air exhaust system. Monitor air quality if working in enclosed areas for extended periods. Take breaks in fresh air every 30-60 minutes. Never use gas-powered equipment indoors for ventilation.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // ===== STATE =====
  const STORAGE_KEY = 'painting-safety-checklist';
  let activeTab: 'cooling' | 'heating' = 'cooling';

  interface SavedState {
    activeTab: string;
    checks: Record<string, boolean>;
    fields: Record<string, string>;
  }

  // ===== PERSISTENCE =====
  function saveState(): void {
    const checks: Record<string, boolean> = {};
    document.querySelectorAll('.cl-check').forEach((cb, i) => {
      checks[`check-${i}`] = (cb as HTMLInputElement).checked;
    });
    const fields: Record<string, string> = {};
    document.querySelectorAll('[data-field]').forEach(el => {
      const key = (el as HTMLElement).dataset.field!;
      fields[key] = (el as HTMLInputElement | HTMLSelectElement).value;
    });
    const state: SavedState = { activeTab, checks, fields };
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
  }

  function loadState(): void {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const state: SavedState = JSON.parse(raw);
      if (state.activeTab === 'heating') switchTab('heating');
      if (state.checks) {
        document.querySelectorAll('.cl-check').forEach((cb, i) => {
          (cb as HTMLInputElement).checked = !!state.checks[`check-${i}`];
        });
      }
      if (state.fields) {
        document.querySelectorAll('[data-field]').forEach(el => {
          const key = (el as HTMLElement).dataset.field!;
          if (state.fields[key] !== undefined) {
            (el as HTMLInputElement | HTMLSelectElement).value = state.fields[key];
          }
        });
      }
    } catch {}
  }

  // ===== TABS =====
  function switchTab(tab: 'cooling' | 'heating'): void {
    activeTab = tab;
    const coolingPanel = document.getElementById('panel-cooling')!;
    const heatingPanel = document.getElementById('panel-heating')!;
    const coolingBtn = document.getElementById('tab-cooling')!;
    const heatingBtn = document.getElementById('tab-heating')!;

    if (tab === 'cooling') {
      coolingPanel.classList.remove('hidden');
      heatingPanel.classList.add('hidden');
      coolingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white';
      heatingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary';
    } else {
      coolingPanel.classList.add('hidden');
      heatingPanel.classList.remove('hidden');
      heatingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white';
      coolingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary';
    }
    updateProgress();
    saveState();
  }

  document.getElementById('tab-cooling')?.addEventListener('click', () => switchTab('cooling'));
  document.getElementById('tab-heating')?.addEventListener('click', () => switchTab('heating'));

  // ===== PROGRESS & SUMMARY =====
  function getActiveChecks(): NodeListOf<HTMLInputElement> {
    const panel = activeTab === 'cooling' ? '#panel-cooling' : '#panel-heating';
    return document.querySelectorAll(`${panel} .cl-check`);
  }

  function evaluateFlags(): { count: number; items: string[] } {
    const flags: string[] = [];
    return { count: flags.length, items: flags };
  }

  function getGrade(pct: number, flagCount: number): string {
    if (pct === 0) return '--';
    const penalty = flagCount * 10;
    const score = Math.max(0, pct - penalty);
    if (score >= 90) return 'A';
    if (score >= 80) return 'B';
    if (score >= 70) return 'C';
    if (score >= 60) return 'D';
    return 'F';
  }

  function gradeColor(grade: string): string {
    if (grade === 'A') return 'text-[#34D399]';
    if (grade === 'B') return 'text-[#60A5FA]';
    if (grade === 'C') return 'text-[#FBBF24]';
    if (grade === 'D') return 'text-[#FB923C]';
    if (grade === 'F') return 'text-[#F87171]';
    return 'text-text-primary';
  }

  function updateProgress(): void {
    const checks = getActiveChecks();
    const total = checks.length;
    const checked = Array.from(checks).filter(c => c.checked).length;
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;

    document.getElementById('progress-text')!.textContent = `${checked} of ${total} items checked`;
    (document.getElementById('progress-bar') as HTMLElement).style.width = `${pct}%`;

    const flags = evaluateFlags();
    const grade = getGrade(pct, flags.count);

    document.getElementById('summary-checked')!.textContent = `${checked} / ${total}`;
    document.getElementById('summary-pct')!.textContent = `${pct}%`;
    document.getElementById('summary-flags')!.textContent = flags.count.toString();

    const gradeEl = document.getElementById('summary-grade')!;
    gradeEl.textContent = grade;
    gradeEl.className = `font-heading font-extrabold text-3xl ${gradeColor(grade)}`;

    if (flags.count > 0) {
      document.getElementById('summary-flags')!.className = 'font-heading font-extrabold text-3xl text-[#FBBF24]';
    } else {
      document.getElementById('summary-flags')!.className = 'font-heading font-extrabold text-3xl text-[#34D399]';
    }

    const flagList = document.getElementById('flag-list')!;
    const flagItems = document.getElementById('flag-items')!;
    if (flags.count > 0) {
      flagList.classList.remove('hidden');
      flagItems.innerHTML = flags.items.map(f => `<div class="bg-[rgba(251,191,36,0.1)] border border-[rgba(251,191,36,0.3)] rounded-lg px-4 py-2 text-sm text-[#FBBF24]">${f}</div>`).join('');
    } else {
      flagList.classList.add('hidden');
      flagItems.innerHTML = '';
    }
  }

  // ===== COLOR INDICATORS =====
  function updateIndicators(): void {
    // Painting safety checklist uses completion-based grading, no numeric indicators
  }

  // ===== EVENT LISTENERS =====
  document.querySelectorAll('.cl-check').forEach(cb => {
    cb.addEventListener('change', () => {
      updateProgress();
      saveState();
    });
  });

  document.querySelectorAll('[data-field]').forEach(el => {
    el.addEventListener('input', () => {
      updateIndicators();
      updateProgress();
      saveState();
    });
    el.addEventListener('change', () => {
      updateIndicators();
      updateProgress();
      saveState();
    });
  });

  // ===== RESET =====
  document.getElementById('reset-checklist')?.addEventListener('click', () => {
    if (!confirm('Reset all checked items and readings? This cannot be undone.')) return;
    document.querySelectorAll('.cl-check').forEach(cb => { (cb as HTMLInputElement).checked = false; });
    document.querySelectorAll('[data-field]').forEach(el => { (el as HTMLInputElement | HTMLSelectElement).value = ''; });
    try { localStorage.removeItem(STORAGE_KEY); } catch {}
    updateIndicators();
    updateProgress();
  });

  // ===== REPORT GENERATION =====
  document.getElementById('generate-report')?.addEventListener('click', () => {
    const seasonLabel = activeTab === 'cooling' ? 'Interior Project' : 'Exterior Project';
    const panel = activeTab === 'cooling' ? '#panel-cooling' : '#panel-heating';
    const checks = document.querySelectorAll(`${panel} .cl-check`);
    const total = checks.length;
    const checked = Array.from(checks).filter(c => (c as HTMLInputElement).checked).length;
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;
    const flags = evaluateFlags();
    const grade = getGrade(pct, flags.count);
    const now = new Date();
    const dateStr = now.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });

    // Gather field readings
    const fields: Record<string, string> = {};
    document.querySelectorAll('[data-field]').forEach(el => {
      const key = (el as HTMLElement).dataset.field!;
      const val = (el as HTMLInputElement | HTMLSelectElement).value;
      if (val) fields[key] = val;
    });

    // Build sections from the active panel
    const sections: { title: string; items: { text: string; checked: boolean }[] }[] = [];
    const sectionEls = document.querySelectorAll(`${panel} > .mb-8`);
    sectionEls.forEach(sec => {
      const h3 = sec.querySelector('h3');
      if (!h3) return;
      const title = h3.textContent?.trim().replace(/^\u25CF\s*/, '') || '';
      const items: { text: string; checked: boolean }[] = [];
      sec.querySelectorAll('.cl-check').forEach(cb => {
        const label = (cb as HTMLElement).closest('label') || (cb as HTMLElement).closest('.flex');
        const span = label?.querySelector('span');
        const text = span?.textContent?.trim() || '';
        items.push({ text, checked: (cb as HTMLInputElement).checked });
      });
      sections.push({ title, items });
    });

    // Build HTML for print
    let html = `<!DOCTYPE html><html><head><meta charset="utf-8"><title>Painting Safety Report - ${seasonLabel}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a1a1a; padding: 40px; max-width: 800px; margin: 0 auto; font-size: 13px; line-height: 1.5; }
      h1 { font-size: 22px; margin-bottom: 4px; }
      h2 { font-size: 16px; margin: 20px 0 8px; border-bottom: 2px solid #e5e7eb; padding-bottom: 4px; }
      .meta { color: #6b7280; font-size: 12px; margin-bottom: 20px; }
      .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
      .summary-box { border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; text-align: center; }
      .summary-box .label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; margin-bottom: 4px; }
      .summary-box .value { font-size: 22px; font-weight: 700; }
      .grade-A { color: #10b981; } .grade-B { color: #3b82f6; } .grade-C { color: #f59e0b; } .grade-D { color: #f97316; } .grade-F { color: #ef4444; }
      .item { padding: 3px 0; display: flex; align-items: center; gap: 8px; }
      .check { width: 14px; height: 14px; border: 1.5px solid #d1d5db; border-radius: 3px; display: inline-flex; align-items: center; justify-content: center; font-size: 10px; flex-shrink: 0; }
      .check.done { background: #10b981; border-color: #10b981; color: white; }
      .readings { margin: 8px 0 8px 22px; padding: 8px 12px; background: #f9fafb; border-radius: 6px; font-size: 12px; }
      .readings span { margin-right: 16px; }
      .flag { background: #fef3c7; border: 1px solid #f59e0b; border-radius: 6px; padding: 6px 12px; margin: 4px 0; font-size: 12px; color: #92400e; }
      @media print { body { padding: 20px; } }
    </style></head><body>`;

    html += `<h1>Painting Safety Report</h1>`;
    html += `<div class="meta">${seasonLabel} &mdash; ${dateStr} at ${timeStr}</div>`;

    html += `<div class="summary-grid">`;
    html += `<div class="summary-box"><div class="label">Checked</div><div class="value">${checked}/${total}</div></div>`;
    html += `<div class="summary-box"><div class="label">Completion</div><div class="value">${pct}%</div></div>`;
    html += `<div class="summary-box"><div class="label">Flags</div><div class="value">${flags.count}</div></div>`;
    html += `<div class="summary-box"><div class="label">Grade</div><div class="value grade-${grade}">${grade}</div></div>`;
    html += `</div>`;

    if (flags.count > 0) {
      html += `<h2>Flagged Readings</h2>`;
      flags.items.forEach(f => { html += `<div class="flag">${f}</div>`; });
    }

    sections.forEach(sec => {
      html += `<h2>${sec.title}</h2>`;
      sec.items.forEach(item => {
        html += `<div class="item"><span class="check ${item.checked ? 'done' : ''}">${item.checked ? '&#10003;' : ''}</span> ${item.text}</div>`;
      });
    });

    // Add readings section if any
    const readingLabels: Record<string, string> = {};
    const activeFields = Object.entries(fields).filter(([_, v]) => v);
    if (activeFields.length > 0) {
      html += `<h2>Recorded Readings</h2><div class="readings">`;
      activeFields.forEach(([k, v]) => {
        const label = readingLabels[k] || k;
        html += `<span><strong>${label}:</strong> ${v}</span>`;
      });

      html += `</div>`;
    }

    html += `</body></html>`;

    const printWin = window.open('', '_blank');
    if (printWin) {
      printWin.document.write(html);
      printWin.document.close();
      setTimeout(() => printWin.print(), 400);
    }
  });

  // ===== INIT =====
  loadState();
  updateIndicators();
  updateProgress();
</script>
