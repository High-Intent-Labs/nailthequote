---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/paintingTools';

const tool = getToolBySlug('home-exterior-estimator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does it cost to paint the exterior of a house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Exterior house painting typically costs between $1.50 and $4.50 per square foot of paintable surface, or $3,000 to $12,000 for a full exterior on a typical home. A 2,000 sq ft single-story ranch with vinyl siding in good condition lands around $4,000 to $6,000. A 3,500 sq ft two-story with wood siding needing significant prep can run $9,000 to $14,000. Siding type, condition, stories, and trim detail are the biggest cost drivers."
      }
    },
    {
      "@type": "Question",
      "name": "How many gallons of paint do I need for an exterior?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "One gallon of exterior paint covers approximately 250 to 350 square feet per coat depending on surface texture and porosity. Rough or porous surfaces like stucco and wood absorb more paint and drop coverage to around 200 to 250 sq ft per gallon. A typical 2,000 sq ft home has roughly 1,500 to 2,000 sq ft of paintable exterior surface and needs 8 to 12 gallons for two coats. Always order 10-15% extra to avoid mid-job shortages."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to paint the exterior of a house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A two-person crew can typically paint the exterior of an average single-story home in 3 to 5 days including prep, priming, two coats, and cleanup. Multi-story homes, heavy prep work, or extensive trim add 1 to 3 additional days. Weather delays are common on exterior jobs so always build buffer time into your schedule. A three-person crew can shave 25-30% off these times."
      }
    },
    {
      "@type": "Question",
      "name": "Should I charge per square foot or per project for exterior painting?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Calculate your price per square foot of paintable surface internally to ensure consistent margins, then present the homeowner with a per-project total. Per square foot pricing keeps your estimating accurate across different home sizes and styles. Most professional painters land between $1.75 and $3.50 per square foot for exteriors depending on siding type, condition, and paint quality. Present it as a project total so the homeowner sees one clear number."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="cost-calc">
    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="homeSqFt">Home Square Footage</label>
        <input type="number" id="homeSqFt" value="2000" min="500" max="15000" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="stories">Number of Stories</label>
        <select id="stories" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1" selected>1 Story</option>
          <option value="1.5">1.5 Stories (split-level)</option>
          <option value="2">2 Stories</option>
          <option value="3">3 Stories</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sidingType">Siding Type</label>
        <select id="sidingType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="vinyl">Vinyl / Aluminum</option>
          <option value="wood" selected>Wood (lap/shingle)</option>
          <option value="hardiboard">HardiPlank / Fiber Cement</option>
          <option value="stucco">Stucco</option>
          <option value="brick">Brick</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="condition">Surface Condition</label>
        <select id="condition" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="good" selected>Good (light wash and scrape)</option>
          <option value="fair">Fair (moderate scraping/sanding)</option>
          <option value="poor">Poor (heavy prep, caulk, prime)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paintQuality">Paint Quality</label>
        <select id="paintQuality" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="standard">Standard ($30-40/gal)</option>
          <option value="mid" selected>Mid-Range ($45-60/gal)</option>
          <option value="premium">Premium ($65-90/gal)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="includeTrim">Include Trim</label>
        <select id="includeTrim" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="no">No (body only)</option>
          <option value="yes" selected>Yes (fascia, soffits, trim)</option>
        </select>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Your Estimate</h3>

      <!-- Cost Range Bar -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <div class="flex justify-between items-end mb-3">
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Low</div>
            <div id="result-low" class="font-heading font-extrabold text-xl text-text-secondary">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Mid Estimate</div>
            <div id="result-mid" class="font-heading font-extrabold text-3xl text-accent">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">High</div>
            <div id="result-high" class="font-heading font-extrabold text-xl text-text-secondary">--</div>
          </div>
        </div>
        <!-- Visual range bar -->
        <div class="relative h-3 bg-bg-card rounded-full overflow-hidden mt-4">
          <div id="range-bar" class="absolute inset-y-0 left-[10%] right-[10%] rounded-full bg-gradient-to-r from-accent/40 via-accent to-accent/40"></div>
          <div id="range-marker" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-accent rounded-full border-2 border-white shadow-lg"></div>
        </div>
      </div>

      <!-- Detail Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Paintable Surface</div>
          <div id="result-sqft" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">sq ft</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Gallons Needed</div>
          <div id="result-gallons" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">gallons (2 coats)</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Est. Labor Hours</div>
          <div id="result-hours" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">crew hours (2-person)</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost per Sq Ft</div>
          <div id="result-persqft" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">labor + materials</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">Ballpark estimate for budgeting and quoting. Actual job costs depend on local labor rates, paint brand, surface texture, accessibility, and on-site conditions. Always measure and quote each job individually.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Estimator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the home's square footage.</strong> Use the living area square footage. The calculator converts this to approximate exterior wall area based on the number of stories and typical window/door openings.</p>
          <p><strong class="text-text-primary">2. Select stories and siding type.</strong> Multi-story homes need ladders or lifts and take longer. Siding type affects paint absorption, coverage rates, and prep requirements. Wood and stucco absorb more paint and need more prep than smooth surfaces like vinyl or HardiPlank.</p>
          <p><strong class="text-text-primary">3. Set the surface condition.</strong> Good condition means a pressure wash and light scrape gets you ready to paint. Fair condition means moderate scraping, sanding, and spot priming. Poor condition means heavy scraping, caulking, wood repair, and full priming before paint goes on.</p>
          <p><strong class="text-text-primary">4. Include trim if applicable.</strong> Trim painting (fascia, soffits, window casings, door frames, shutters) adds 15-25% to the total cost. It is slower, more detail-oriented work that requires cutting in and often uses a different color and sheen than the body.</p>
        </div>
      </section>

      <!-- What Affects Cost -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Affects Exterior Painting Cost</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Prep is where exterior jobs get expensive.</strong> A house in good shape might need a day of pressure washing and light scraping. A house with peeling paint, rotted trim, or failing caulk can eat 2 to 4 days of prep before a single gallon of paint is opened. Accurate prep assessment is the difference between a profitable job and a money loser.</p>
          <p><strong class="text-text-primary">Height and access.</strong> Single-story homes are straightforward ladder work. Two- and three-story homes need extension ladders, scaffolding, or even boom lifts. Each step up in height slows production, increases safety considerations, and adds equipment costs. Price your multi-story work 20-40% higher per square foot than single-story.</p>
          <p><strong class="text-text-primary">Siding type determines coverage and speed.</strong> Smooth vinyl and fiber cement are the fastest to paint and use the least material. Wood lap siding is moderate. Stucco and rough-textured surfaces absorb paint heavily and require more material plus slower application. Brick is the most paint-hungry surface by far.</p>
          <p><strong class="text-text-primary">Paint quality affects longevity and callbacks.</strong> Premium exterior paints last 10-15 years versus 5-7 for standard grades. The higher per-gallon cost is often offset by better coverage and far fewer warranty callbacks. On exteriors, cheap paint is expensive paint in the long run.</p>
          <p><strong class="text-text-primary">Trim and detail work.</strong> Painting trim, soffits, fascia, shutters, and window casings is slower than rolling body walls. It requires more cutting in, often involves different products (higher-sheen enamels), and adds significant labor time. Always quote trim as a separate line item so the homeowner sees the value.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Phone screening and lead qualifying.</strong> When a homeowner calls asking about exterior painting, walk them through the basic specs and give them a ballpark range before you commit to a site visit. This filters out budget shoppers early and sets expectations for homeowners who are ready to move forward.</p>
          <p><strong class="text-text-primary">Fast on-site ballparking.</strong> Pull this up on your phone as you walk the exterior. Plug in the home size, count the stories, assess the siding condition, and show the homeowner a range on the spot. Follow up with a detailed written proposal within 24 hours while the conversation is fresh.</p>
          <p><strong class="text-text-primary">Comparing job profitability.</strong> Run a few recent exterior jobs through this estimator and compare the output to what you actually charged. If you consistently come in below the calculator's range, you may be underpricing your work. If you are consistently above, you have a strong value proposition to lean into.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does it cost to paint the exterior of a house?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Exterior house painting typically costs between $1.50 and $4.50 per square foot of paintable surface, or $3,000 to $12,000 for a full exterior on a typical home. A 2,000 sq ft single-story ranch with vinyl siding in good condition lands around $4,000 to $6,000. A 3,500 sq ft two-story with wood siding needing significant prep can run $9,000 to $14,000. Siding type, condition, stories, and trim detail are the biggest cost drivers.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many gallons of paint do I need for an exterior?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">One gallon of exterior paint covers approximately 250 to 350 square feet per coat depending on surface texture and porosity. Rough or porous surfaces like stucco and wood absorb more paint and drop coverage to around 200 to 250 sq ft per gallon. A typical 2,000 sq ft home has roughly 1,500 to 2,000 sq ft of paintable exterior surface and needs 8 to 12 gallons for two coats. Always order 10-15% extra to avoid mid-job shortages.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How long does it take to paint the exterior of a house?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A two-person crew can typically paint the exterior of an average single-story home in 3 to 5 days including prep, priming, two coats, and cleanup. Multi-story homes, heavy prep work, or extensive trim add 1 to 3 additional days. Weather delays are common on exterior jobs so always build buffer time into your schedule. A three-person crew can shave 25-30% off these times.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I charge per square foot or per project for exterior painting?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Calculate your price per square foot of paintable surface internally to ensure consistent margins, then present the homeowner with a per-project total. Per square foot pricing keeps your estimating accurate across different home sizes and styles. Most professional painters land between $1.75 and $3.50 per square foot for exteriors depending on siding type, condition, and paint quality. Present it as a project total so the homeowner sees one clear number.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate(): void {
    const homeSqFt = parseFloat((document.getElementById('homeSqFt') as HTMLInputElement).value) || 2000;
    const stories = parseFloat((document.getElementById('stories') as HTMLSelectElement).value);
    const sidingType = (document.getElementById('sidingType') as HTMLSelectElement).value;
    const condition = (document.getElementById('condition') as HTMLSelectElement).value;
    const paintQuality = (document.getElementById('paintQuality') as HTMLSelectElement).value;
    const includeTrim = (document.getElementById('includeTrim') as HTMLSelectElement).value === 'yes';

    // Estimate exterior wall area from home sq ft and stories
    // Approximate: perimeter * wall height. For a square footprint: perimeter = 4 * sqrt(footprint)
    const footprint = homeSqFt / Math.max(stories, 1);
    const perimeter = 4 * Math.sqrt(footprint);
    const wallHeight = stories * 9; // ~9 ft per story
    const grossWallArea = perimeter * wallHeight;

    // Subtract ~15% for windows and doors
    const netWallArea = grossWallArea * 0.85;

    // Trim adds ~20% more paintable area
    const trimArea = includeTrim ? netWallArea * 0.20 : 0;
    const totalPaintableArea = Math.round(netWallArea + trimArea);

    // Coverage per gallon varies by siding type
    const coveragePerGallon: Record<string, number> = {
      vinyl: 350,
      wood: 300,
      hardiboard: 325,
      stucco: 225,
      brick: 200,
    };
    const coverage = coveragePerGallon[sidingType] ?? 300;
    const gallonsPerCoat = totalPaintableArea / coverage;
    const totalGallons = Math.ceil(gallonsPerCoat * 2); // 2 coats standard

    // Prep multiplier
    const prepMultiplier: Record<string, number> = { good: 1.0, fair: 1.35, poor: 1.75 };
    const prep = prepMultiplier[condition] ?? 1.0;

    // Height/access multiplier
    const heightMultiplier: Record<string, number> = { '1': 1.0, '1.5': 1.15, '2': 1.30, '3': 1.50 };
    const height = heightMultiplier[String(stories)] ?? 1.0;

    // Siding difficulty multiplier (affects labor speed)
    const sidingMultiplier: Record<string, number> = {
      vinyl: 0.85,
      wood: 1.0,
      hardiboard: 0.90,
      stucco: 1.15,
      brick: 1.25,
    };
    const sidingFactor = sidingMultiplier[sidingType] ?? 1.0;

    // Labor hours: ~80 sq ft per hour per painter for body, 2-person crew
    const bodyHoursPerPainter = (netWallArea / 80) * 2 * prep * height * sidingFactor; // 2 coats
    const trimHoursPerPainter = includeTrim ? (trimArea / 40) * 2 * height : 0; // trim is slower
    const totalCrewHours = Math.round(((bodyHoursPerPainter + trimHoursPerPainter) / 2) * 10) / 10; // 2-person crew

    // Cost per sq ft by paint quality
    const costRanges: Record<string, { low: number; high: number }> = {
      standard: { low: 1.50, high: 2.75 },
      mid: { low: 2.25, high: 3.50 },
      premium: { low: 3.00, high: 4.50 },
    };
    const range = costRanges[paintQuality] ?? costRanges.mid;

    const lowCost = Math.round(totalPaintableArea * range.low * prep * height * sidingFactor);
    const highCost = Math.round(totalPaintableArea * range.high * prep * height * sidingFactor);
    const midCost = Math.round((lowCost + highCost) / 2);

    const fmt = (n: number): string => '$' + n.toLocaleString();

    document.getElementById('result-low')!.textContent = fmt(lowCost);
    document.getElementById('result-mid')!.textContent = fmt(midCost);
    document.getElementById('result-high')!.textContent = fmt(highCost);
    document.getElementById('result-sqft')!.textContent = totalPaintableArea.toLocaleString();
    document.getElementById('result-gallons')!.textContent = totalGallons.toString();
    document.getElementById('result-hours')!.textContent = totalCrewHours.toString();
    document.getElementById('result-persqft')!.textContent = '$' + (midCost / totalPaintableArea).toFixed(2);
  }

  // Auto-calculate on any input change
  document.querySelectorAll('#cost-calc select, #cost-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
