---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/paintingTools';

const tool = getToolBySlug('multi-coat-estimator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many coats of paint do I need?",
      "acceptedAnswer": { "@type": "Answer", "text": "Two coats of paint is standard for most interior jobs. You may need three coats when covering dark colors with light paint, using low-opacity paint, or painting porous surfaces. One coat may work for touch-ups with the same color or when using a high-quality paint-and-primer-in-one product." }
    },
    {
      "@type": "Question",
      "name": "Do I need primer plus paint coats?",
      "acceptedAnswer": { "@type": "Answer", "text": "Primer is recommended for new drywall, bare wood, stain coverage, and dark-to-light color changes. A typical schedule is 1 coat primer + 2 coats paint for interior, and 1 coat primer + 2-3 coats paint for exterior. Skip primer only if painting over a similar color on previously primed walls." }
    },
    {
      "@type": "Question",
      "name": "How long between coats of paint?",
      "acceptedAnswer": { "@type": "Answer", "text": "Latex paint typically needs 2-4 hours between coats at 70 degrees and 50% humidity. Oil-based paint needs 12-24 hours between coats. Cold or humid conditions extend drying time significantly. Always check the manufacturer label for the recommended recoat time." }
    },
    {
      "@type": "Question",
      "name": "Does each coat of paint use the same amount?",
      "acceptedAnswer": { "@type": "Answer", "text": "The first coat on bare or primed surfaces typically uses slightly more paint as the surface absorbs some. Second and third coats go on more evenly and may use 5-10% less paint. For estimating purposes, most pros calculate the same coverage rate for each coat." }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="multicoat-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="area">Total Area (sq ft)</label>
        <input type="number" id="area" value="400" min="1" max="100000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="surfaceType">Surface Type</label>
        <select id="surfaceType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="400">Drywall / Smooth</option>
          <option value="300">Textured Drywall</option>
          <option value="350">Wood</option>
          <option value="250">Masonry / Brick</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="needsPrimer">Primer Needed?</label>
        <select id="needsPrimer" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1" selected>Yes - 1 coat primer</option>
          <option value="2">Yes - 2 coats primer (stains/glossy)</option>
          <option value="0">No primer needed</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paintCoats">Paint Coats</label>
        <select id="paintCoats" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1">1 Coat</option>
          <option value="2" selected>2 Coats</option>
          <option value="3">3 Coats</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paintType">Paint Type</label>
        <select id="paintType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="latex" selected>Latex / Acrylic</option>
          <option value="oil">Oil-Based</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paintCost">Paint Cost per Gallon ($)</label>
        <input type="number" id="paintCost" value="45" min="0" max="500" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="primerCost">Primer Cost per Gallon ($)</label>
        <input type="number" id="primerCost" value="30" min="0" max="200" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Coat-by-Coat Breakdown</h3>

      <!-- Timeline -->
      <div id="timeline" class="space-y-3 mb-8"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Paint</div>
          <div id="result-paint" class="font-heading font-extrabold text-3xl text-accent">--</div>
          <div class="text-text-muted text-xs mt-1">gallons</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Primer</div>
          <div id="result-primer" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">gallons</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Drying Time</div>
          <div id="result-drytime" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Est. Materials Cost</div>
          <div id="result-cost" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>
      <p class="text-text-muted text-sm italic">Drying times assume 70 degrees F and 50% humidity. Use the <a href="/painting/drying-time-calculator" class="text-accent hover:underline">Drying Time Calculator</a> for site-specific conditions.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the area and surface type.</strong> The surface type determines paint coverage rate per gallon.</p>
          <p><strong class="text-text-primary">2. Set primer requirements.</strong> Choose whether primer is needed and how many coats. Two coats of primer are recommended for stain coverage and glossy surfaces.</p>
          <p><strong class="text-text-primary">3. Choose paint coats.</strong> Two coats is industry standard. Three coats for dark-to-light color changes or exterior work.</p>
          <p><strong class="text-text-primary">4. Review the timeline.</strong> The calculator shows a coat-by-coat schedule with drying time between each coat so you can plan your workday.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Multi-Coat Scheduling</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Primer_Gallons = (Area / Primer_Coverage) x Primer_Coats</p>
            <p>Paint_Gallons = (Area / Paint_Coverage) x Paint_Coats</p>
            <p>Total_Dry_Time = Sum of recoat waits between all coats</p>
          </div>
          <p>Interior standard: Primer + 2 coats paint. Exterior standard: Primer + 2-3 coats paint. Primer dries faster than paint (typically 1 hour for latex primer vs 2-4 hours for latex paint recoat time).</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many coats of paint do I need?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Two coats of paint is standard for most interior jobs. You may need three coats when covering dark colors with light paint, using low-opacity paint, or painting porous surfaces. One coat may work for touch-ups with the same color or when using a high-quality paint-and-primer-in-one product.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Do I need primer plus paint coats?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Primer is recommended for new drywall, bare wood, stain coverage, and dark-to-light color changes. A typical schedule is 1 coat primer + 2 coats paint for interior, and 1 coat primer + 2-3 coats paint for exterior. Skip primer only if painting over a similar color on previously primed walls.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How long between coats of paint?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Latex paint typically needs 2-4 hours between coats at 70 degrees and 50% humidity. Oil-based paint needs 12-24 hours between coats. Cold or humid conditions extend drying time significantly. Always check the manufacturer label for the recommended recoat time.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Does each coat of paint use the same amount?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The first coat on bare or primed surfaces typically uses slightly more paint as the surface absorbs some. Second and third coats go on more evenly and may use 5-10% less paint. For estimating purposes, most pros calculate the same coverage rate for each coat.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const area = parseFloat((document.getElementById('area') as HTMLInputElement).value) || 400;
    const paintCoverage = parseFloat((document.getElementById('surfaceType') as HTMLSelectElement).value);
    const primerCoats = parseInt((document.getElementById('needsPrimer') as HTMLSelectElement).value);
    const paintCoats = parseInt((document.getElementById('paintCoats') as HTMLSelectElement).value);
    const paintType = (document.getElementById('paintType') as HTMLSelectElement).value;
    const paintCost = parseFloat((document.getElementById('paintCost') as HTMLInputElement).value) || 0;
    const primerCost = parseFloat((document.getElementById('primerCost') as HTMLInputElement).value) || 0;

    const primerCoverage = 300; // average primer coverage
    const primerGallonsPerCoat = area / primerCoverage;
    const paintGallonsPerCoat = area / paintCoverage;

    const totalPrimer = Math.ceil(primerGallonsPerCoat * primerCoats * 2) / 2;
    const totalPaint = Math.ceil(paintGallonsPerCoat * paintCoats * 2) / 2;

    // Drying times
    const primerDry = paintType === 'oil' ? 4 : 1; // hours
    const paintRecoat = paintType === 'oil' ? 16 : 3; // hours

    // Build timeline
    const timeline: {label: string; gallons: string; dryTime: string; type: string}[] = [];
    let totalDryHours = 0;

    for (let i = 1; i <= primerCoats; i++) {
      const gal = Math.ceil(primerGallonsPerCoat * 2) / 2;
      timeline.push({
        label: primerCoats > 1 ? `Primer Coat ${i}` : 'Primer',
        gallons: gal.toFixed(1) + ' gal',
        dryTime: primerDry + ' hr dry',
        type: 'primer'
      });
      totalDryHours += primerDry;
    }

    for (let i = 1; i <= paintCoats; i++) {
      const gal = Math.ceil(paintGallonsPerCoat * 2) / 2;
      const isLast = i === paintCoats;
      timeline.push({
        label: paintCoats > 1 ? `Paint Coat ${i}` : 'Paint',
        gallons: gal.toFixed(1) + ' gal',
        dryTime: isLast ? 'Final coat' : paintRecoat + ' hr recoat wait',
        type: 'paint'
      });
      if (!isLast) totalDryHours += paintRecoat;
    }

    // Render timeline
    const timelineEl = document.getElementById('timeline')!;
    timelineEl.innerHTML = timeline.map((step, i) => `
      <div class="flex items-center gap-4">
        <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold ${step.type === 'primer' ? 'bg-[#60A5FA]/20 text-[#60A5FA]' : 'bg-accent/20 text-accent'}">
          ${i + 1}
        </div>
        <div class="flex-1 bg-bg-dark rounded-lg px-4 py-3 flex justify-between items-center">
          <div>
            <span class="text-text-primary font-medium">${step.label}</span>
            <span class="text-text-muted text-sm ml-3">${step.gallons}</span>
          </div>
          <span class="text-text-secondary text-sm">${step.dryTime}</span>
        </div>
      </div>
    `).join('');

    // Format dry time
    let dryTimeText = '';
    if (totalDryHours >= 24) {
      const days = Math.floor(totalDryHours / 24);
      const hours = totalDryHours % 24;
      dryTimeText = days + ' day' + (days > 1 ? 's' : '') + (hours > 0 ? ' ' + hours + ' hr' : '');
    } else {
      dryTimeText = totalDryHours + ' hours';
    }

    const totalMaterialCost = (totalPaint * paintCost) + (totalPrimer * primerCost);

    document.getElementById('result-paint')!.textContent = totalPaint.toFixed(1);
    document.getElementById('result-primer')!.textContent = primerCoats > 0 ? totalPrimer.toFixed(1) : '0';
    document.getElementById('result-drytime')!.textContent = dryTimeText;
    document.getElementById('result-cost')!.textContent = (paintCost > 0 || primerCost > 0) ? '$' + totalMaterialCost.toFixed(0) : '--';
  }

  document.querySelectorAll('#multicoat-calc input, #multicoat-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
