  // Bucket-label resolver. Matches the 5-bucket matrix in
  // load-calculator-qualifying-questions.md §5, plus a "Pre-v1 / unknown"
  // catch-all for captures from before the qualifying questions shipped.
  function bucketLabel(segment: any, isDiy: any, stage: any): string {
    if (segment === 'home' && isDiy === true)  return 'Home · DIY';
    if (segment === 'home' && isDiy === false) {
      if (stage === 'not_yet')       return '🟢🟢🟢 Home · Hiring · Not yet';
      if (stage === 'has_estimates') return '🟢🟢 Home · Hiring · Has estimates';
      if (stage === 'researching')   return '🟠 Home · Hiring · Researching';
      return 'Home · Hiring · (no stage)';
    }
    if (segment === 'customer') return 'Pro (customer job)';
    return 'Pre-v1 / unknown';
  }

  function renderBuckets(bucketResp: any) {
    const tbody = document.getElementById('buckets-body')!;
    tbody.innerHTML = '';
    if (bucketResp?.error) {
      tbody.innerHTML = `<tr><td colspan="3" class="py-4 text-center text-text-primary">${escape(bucketResp.error)}</td></tr>`;
      return;
    }
    const rows = bucketResp?.results || [];
    if (!rows.length) {
      tbody.innerHTML = `<tr><td colspan="3" class="py-4 text-center text-text-primary">No email captures in range</td></tr>`;
      return;
    }
    // Collapse rows that map to the same label (e.g. multiple "Pre-v1" rows
    // from different NULL-triple shapes).
    const totals = new Map<string, number>();
    for (const r of rows) {
      const [segment, isDiy, stage, emails] = r;
      const label = bucketLabel(segment, isDiy, stage);
      totals.set(label, (totals.get(label) || 0) + (Number(emails) || 0));
    }
    const grandTotal = Array.from(totals.values()).reduce((a, b) => a + b, 0);
    // Stable display order — 🟢🟢🟢 first, catch-all last.
    const displayOrder = [
      '🟢🟢🟢 Home · Hiring · Not yet',
      '🟢🟢 Home · Hiring · Has estimates',
      '🟠 Home · Hiring · Researching',
      'Home · Hiring · (no stage)',
      'Home · DIY',
      'Pro (customer job)',
      'Pre-v1 / unknown',
    ];
    const sorted = displayOrder
      .filter(l => totals.has(l))
      .concat(Array.from(totals.keys()).filter(l => !displayOrder.includes(l)));
    for (const label of sorted) {
      const emails = totals.get(label) || 0;
      const pct = grandTotal > 0 ? ((emails / grandTotal) * 100).toFixed(1) + '%' : '—';
      tbody.insertAdjacentHTML('beforeend', `
        <tr class="border-b border-border/50">
          <td class="py-2 pr-3">${escape(label)}</td>
          <td class="py-2 pr-3 text-right font-mono">${emails.toLocaleString()}</td>
          <td class="py-2 text-right text-text-primary text-xs">${pct}</td>
        </tr>`);
    }
  }

  // Persona keys come back from PostHog in the form produced by the frontend
  // CTA wiring (see load-calculator.astro showPersonaCta). Map each to a
  // human-readable label + the Angi destination the CTA points at.
  const PERSONA_META: Record<string, { label: string; dest: string; order: number }> = {
    home_hiring_not_yet:       { label: '🟢🟢🟢 Home · Hiring · Not yet',       dest: 'Angi HVAC (10211)',    order: 1 },
    home_hiring_has_estimates: { label: '🟢🟢 Home · Hiring · Has estimates',    dest: 'Angi HVAC (10211)',    order: 2 },
    home_hiring_researching:   { label: '🟠 Home · Hiring · Researching',        dest: 'Angi HVAC (10211)',    order: 3 },
    home_diy:                  { label: '🔴 Home · DIY',                         dest: 'Angi Electrical (12026)', order: 4 },
    pro:                       { label: '⚫ Pro (customer job)',                  dest: 'signup.angi.com/pro',  order: 5 },
    unknown:                   { label: 'Pre-v1 / unknown',                      dest: '—',                    order: 6 },
  };

  function renderPersonaCta(resp: any) {
    const tbody = document.getElementById('persona-cta-body')!;
    tbody.innerHTML = '';
    if (resp?.error) {
      tbody.innerHTML = `<tr><td colspan="5" class="py-4 text-center text-text-primary">${escape(resp.error)}</td></tr>`;
      return;
    }
    const rows = resp?.results || [];
    if (!rows.length) {
      tbody.innerHTML = `<tr><td colspan="5" class="py-4 text-center text-text-primary">No persona CTA activity in range</td></tr>`;
      return;
    }
    // Sort by the meta display order (puts 🟢🟢🟢 first, unknown last); any
    // unmapped persona keys drop to the bottom alphabetically.
    const sorted = rows.slice().sort((a: any, b: any) => {
      const ao = PERSONA_META[a[0]]?.order ?? 99;
      const bo = PERSONA_META[b[0]]?.order ?? 99;
      if (ao !== bo) return ao - bo;
      return String(a[0]).localeCompare(String(b[0]));
    });
    for (const r of sorted) {
      const [persona, emails, clicks, ctrPct] = r;
      const meta = PERSONA_META[persona] || { label: String(persona), dest: '—' };
      const ctr = (emails || 0) > 0 ? (Number(ctrPct || 0).toFixed(2) + '%') : '—';
      tbody.insertAdjacentHTML('beforeend', `
        <tr class="border-b border-border/50">
          <td class="py-2 pr-3">${escape(meta.label)}</td>
          <td class="py-2 pr-3 text-text-primary text-xs">${escape(meta.dest)}</td>
          <td class="py-2 pr-3 text-right font-mono">${Number(emails || 0).toLocaleString()}</td>
          <td class="py-2 pr-3 text-right font-mono">${Number(clicks || 0).toLocaleString()}</td>
          <td class="py-2 text-right font-mono">${ctr}</td>
        </tr>`);
    }
  }


  // Daily email chart
  const PERSONA_COLORS: Record<string, string> = {
    home_hiring_not_yet: '#22c55e',
    home_hiring_has_quotes: '#86efac',
    home_hiring_has_estimates: '#86efac',
    home_hiring_researching: '#f97316',
    home_diy: '#ef4444',
    pro: '#71717a',
  };
  const PERSONA_LABELS: Record<string, string> = {
    home_hiring_not_yet: 'Hiring: not yet',
    home_hiring_has_quotes: 'Has estimates',
    home_hiring_has_estimates: 'Has estimates',
    home_hiring_researching: 'Researching',
    home_diy: 'DIY',
    pro: 'Pro',
  };
  let dailyChartInstance: Chart | null = null;

  function renderDailyEmailChart(data: any, errorMsg?: string) {
    const errEl = document.getElementById('email-daily-chart-error')!;
    const canvas = document.getElementById('email-daily-chart') as HTMLCanvasElement;
    if (errorMsg || !data || data.error) {
      errEl.textContent = errorMsg || data?.error || 'Failed to load chart data';
      errEl.classList.remove('hidden');
      return;
    }
    errEl.classList.add('hidden');

    const sendsByDay: Record<string, Record<string, number>> = data.sendsByDay || {};
    const clicksByDay: Record<string, number> = data.clicksByDay || {};

    const allDays = [...new Set([...Object.keys(sendsByDay), ...Object.keys(clicksByDay)])].sort();
    if (allDays.length === 0) {
      errEl.textContent = 'No send data yet.';
      errEl.classList.remove('hidden');
      return;
    }

    const personas = [...new Set(Object.values(sendsByDay).flatMap(d => Object.keys(d)))].sort();

    const barDatasets = personas.map(p => ({
      label: PERSONA_LABELS[p] || p,
      data: allDays.map(d => sendsByDay[d]?.[p] || 0),
      backgroundColor: PERSONA_COLORS[p] || '#a1a1aa',
      stack: 'sends',
      order: 2,
    }));

    const clickData = allDays.map(d => clicksByDay[d] || 0);
    const lineDataset = {
      label: 'Clicks',
      data: clickData,
      type: 'line' as const,
      borderColor: '#f59e0b',
      backgroundColor: 'rgba(245, 158, 11, 0.15)',
      borderWidth: 2.5,
      pointRadius: 4,
      pointBackgroundColor: '#f59e0b',
      fill: false,
      yAxisID: 'y1',
      order: 1,
    };

    dailyChartInstance?.destroy();
    dailyChartInstance = new Chart(canvas, {
      type: 'bar',
      data: {
        labels: allDays.map(d => {
          const parts = d.split('-');
          return `${parts[1]}/${parts[2]}`;
        }),
        datasets: [...barDatasets, lineDataset],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: {
            position: 'bottom',
            labels: { boxWidth: 12, padding: 10, color: '#9ca3af', font: { size: 11 } },
          },
          tooltip: {
            backgroundColor: '#1a1a2e',
            titleFont: { size: 12 },
            bodyFont: { size: 12 },
            padding: 10,
            cornerRadius: 6,
          },
        },
        scales: {
          x: {
            stacked: true,
            grid: { display: false },
            ticks: { color: '#9ca3af', font: { size: 11 } },
          },
          y: {
            stacked: true,
            beginAtZero: true,
            title: { display: true, text: 'Emails sent', color: '#9ca3af', font: { size: 11 } },
            ticks: { color: '#9ca3af', font: { size: 11 }, stepSize: 10 },
            grid: { color: 'rgba(255,255,255,0.06)' },
          },
          y1: {
            position: 'right',
            beginAtZero: true,
            title: { display: true, text: 'Clicks', color: '#f59e0b', font: { size: 11 } },
            ticks: { color: '#f59e0b', font: { size: 11 }, stepSize: 1 },
            grid: { display: false },
          },
        },
      },
    });
  }

  // Email sequence panel — Tier C.
  const EMAIL_DAY_LABEL = ['Day 0', 'Day 3', 'Day 7', 'Day 14'];
  const EMAIL_PERSONA_LABEL: Record<string, string> = {
    home_hiring_not_yet: '🟢🟢🟢 Hiring · not yet',
    home_hiring_has_estimates: '🟢🟢 Has estimates',
    home_hiring_researching: '🟠 Researching',
    home_diy: '🔴 DIY',
    pro: '⚫ Pro',
  };
  const STATUS_TILE_CLASS: Record<string, string> = {
    pending:      'border-blue-500/30 bg-blue-500/10 text-blue-200',
    sending:      'border-yellow-500/30 bg-yellow-500/10 text-yellow-200',
    sent:         'border-emerald-500/30 bg-emerald-500/10 text-emerald-200',
    failed:       'border-red-500/30 bg-red-500/10 text-red-200',
    unsubscribed: 'border-orange-500/30 bg-orange-500/10 text-orange-200',
    cancelled:    'border-zinc-500/30 bg-zinc-500/10 text-zinc-200',
  };
  const STATUS_ORDER = ['pending', 'sending', 'sent', 'failed', 'unsubscribed', 'cancelled'];

  function fmtUtc(ts?: string | null): string {
    if (!ts) return '—';
    return new Date(ts).toISOString().replace('T', ' ').slice(0, 16);
  }

  function renderEmailSequence(data: any, errorMsg?: string) {
    const summaryEl = document.getElementById('es-status-summary')!;
    const metaEl = document.getElementById('es-meta')!;
    const perEmailBody = document.getElementById('es-per-email-body')!;
    const failuresBody = document.getElementById('es-failures-body')!;
    const killBtn = document.getElementById('es-killswitch-btn') as HTMLButtonElement;

    if (errorMsg || !data) {
      const msg = errorMsg || 'No data';
      summaryEl.innerHTML = `<div class="col-span-full text-text-primary text-xs">${escape(msg)}</div>`;
      metaEl.innerHTML = '&nbsp;';
      perEmailBody.innerHTML = `<tr><td colspan="13" class="py-4 text-center text-text-primary">${escape(msg)}</td></tr>`;
      failuresBody.innerHTML = `<tr><td colspan="4" class="py-3 text-center text-text-primary">—</td></tr>`;
      killBtn.disabled = true;
      killBtn.textContent = 'Unavailable';
      return;
    }

    // 1. Status summary tiles
    const byStatus: Record<string, number> = {};
    (data.queueByStatus || []).forEach((r: any) => { byStatus[r.status] = Number(r.count || 0); });
    summaryEl.innerHTML = STATUS_ORDER.map((s) => {
      const c = byStatus[s] || 0;
      const cls = STATUS_TILE_CLASS[s] || 'border-border bg-bg-dark/40';
      return `<div class="rounded-lg border px-3 py-2 ${cls}">
        <div class="text-[10px] uppercase tracking-wider opacity-80">${s}</div>
        <div class="text-lg font-semibold tabular-nums">${c.toLocaleString()}</div>
      </div>`;
    }).join('');

    // 2. Meta line — unsubscribe count, oldest pending, newest sent
    const unsubCount = Number(data.unsubscribeCount || 0);
    const oldestPending = data.oldestPendingDue;
    const newestSent = data.newestSent;
    const metaParts = [
      `<strong>Unsubscribed:</strong> ${unsubCount.toLocaleString()}`,
      newestSent ? `<strong>Newest send:</strong> ${fmtUtc(newestSent)} UTC` : null,
      oldestPending ? `<strong>Oldest pending due:</strong> ${fmtUtc(oldestPending)} UTC <span class="text-orange-400">(scheduler may be lagging)</span>` : null,
    ].filter(Boolean).join(' &nbsp; · &nbsp; ');
    metaEl.innerHTML = metaParts || '&nbsp;';

    // 3. Per-email table
    const rows = (data.queueByPersonaDay || []) as any[];
    if (rows.length === 0) {
      perEmailBody.innerHTML = `<tr><td colspan="13" class="py-4 text-center text-text-primary">No queue rows yet — no qualifying captures since enrollment shipped.</td></tr>`;
    } else {
      const totals = { pending: 0, sent: 0, failed: 0, unsub: 0, delivered: 0, opened: 0, clicked: 0, bounced: 0 };
      const fmtPct = (num: number, denom: number) => denom > 0 ? `${Math.round((100 * num) / denom)}%` : '—';

      const rowsHtml = rows.map((r) => {
        const personaLabel = EMAIL_PERSONA_LABEL[r.persona] || r.persona;
        const emailLabel = EMAIL_DAY_LABEL[r.email_number] ?? `#${r.email_number}`;
        const pending = Number(r.pending || 0);
        const sent = Number(r.sent || 0);
        const failed = Number(r.failed || 0);
        const unsub = Number(r.unsubscribed || 0);
        const delivered = Number(r.delivered || 0);
        const opened = Number(r.opened || 0);
        const clicked = Number(r.clicked || 0);
        const bounced = Number(r.bounced || 0);
        totals.pending += pending;
        totals.sent += sent;
        totals.failed += failed;
        totals.unsub += unsub;
        totals.delivered += delivered;
        totals.opened += opened;
        totals.clicked += clicked;
        totals.bounced += bounced;
        const failedClass = failed > 0 ? 'text-red-300 font-semibold' : '';
        const bouncedClass = bounced > 0 ? 'text-red-300 font-semibold' : '';
        return `<tr class="border-b border-border/60">
          <td class="py-2 pr-3">${escape(personaLabel)}</td>
          <td class="py-2 pr-3">${emailLabel}</td>
          <td class="py-2 pr-3 text-right tabular-nums">${pending}</td>
          <td class="py-2 pr-3 text-right tabular-nums">${sent}</td>
          <td class="py-2 pr-3 text-right tabular-nums ${failedClass}">${failed}</td>
          <td class="py-2 pr-3 text-right tabular-nums">${unsub}</td>
          <td class="py-2 pr-3 text-right tabular-nums">${fmtPct(unsub, delivered)}</td>
          <td class="py-2 pr-3 text-right tabular-nums">${delivered}</td>
          <td class="py-2 pr-3 text-right tabular-nums">${opened}</td>
          <td class="py-2 pr-3 text-right tabular-nums">${fmtPct(opened, delivered)}</td>
          <td class="py-2 pr-3 text-right tabular-nums">${clicked}</td>
          <td class="py-2 pr-3 text-right tabular-nums">${fmtPct(clicked, delivered)}</td>
          <td class="py-2 text-right tabular-nums ${bouncedClass}">${bounced}</td>
        </tr>`;
      }).join('');

      const totalsRow = `<tr class="border-t-2 border-border font-semibold">
        <td class="py-2 pr-3" colspan="2">Total</td>
        <td class="py-2 pr-3 text-right tabular-nums">${totals.pending}</td>
        <td class="py-2 pr-3 text-right tabular-nums">${totals.sent}</td>
        <td class="py-2 pr-3 text-right tabular-nums">${totals.failed}</td>
        <td class="py-2 pr-3 text-right tabular-nums">${totals.unsub}</td>
        <td class="py-2 pr-3 text-right tabular-nums">${fmtPct(totals.unsub, totals.delivered)}</td>
        <td class="py-2 pr-3 text-right tabular-nums">${totals.delivered}</td>
        <td class="py-2 pr-3 text-right tabular-nums">${totals.opened}</td>
        <td class="py-2 pr-3 text-right tabular-nums">${fmtPct(totals.opened, totals.delivered)}</td>
        <td class="py-2 pr-3 text-right tabular-nums">${totals.clicked}</td>
        <td class="py-2 pr-3 text-right tabular-nums">${fmtPct(totals.clicked, totals.delivered)}</td>
        <td class="py-2 text-right tabular-nums">${totals.bounced}</td>
      </tr>`;

      perEmailBody.innerHTML = rowsHtml + totalsRow;
    }

    // 4. Recent failures
    const failures = ((data.recentFailures || []) as any[]).slice(0, 10);
    if (failures.length === 0) {
      failuresBody.innerHTML = `<tr><td colspan="4" class="py-3 text-center text-text-primary">No failures yet.</td></tr>`;
    } else {
      failuresBody.innerHTML = failures.map((f) => `
        <tr class="border-b border-border/60">
          <td class="py-2 pr-3 font-mono">${escape(f.email)}</td>
          <td class="py-2 pr-3">${EMAIL_DAY_LABEL[f.email_number] ?? f.email_number}</td>
          <td class="py-2 pr-3 tabular-nums">${fmtUtc(f.claimed_at)}</td>
          <td class="py-2 text-red-300">${escape(f.error_message || '—')}</td>
        </tr>`).join('');
    }

    // 5. Kill switch
    const paused = !!data.schedulerPaused;
    killBtn.disabled = false;
    killBtn.dataset.paused = String(paused);
    if (paused) {
      killBtn.textContent = '▶  Resume scheduler';
      killBtn.className = 'text-xs px-3 py-1.5 rounded-lg border whitespace-nowrap bg-emerald-500/15 border-emerald-500/40 text-emerald-200 hover:bg-emerald-500/25';
    } else {
      killBtn.textContent = '⏸  Pause scheduler';
      killBtn.className = 'text-xs px-3 py-1.5 rounded-lg border whitespace-nowrap bg-bg-card hover:bg-bg-dark border-border text-text-primary';
    }
  }

  function renderCaptures(rows: any[]) {
    const tbody = document.getElementById('captures-body')!;
    const count = document.getElementById('captures-count')!;
    tbody.innerHTML = '';
    count.textContent = `${rows.length} ${rows.length === 1 ? 'row' : 'rows'}`;
    if (!rows.length) {
      tbody.innerHTML = `<tr><td colspan="19" class="py-4 text-center text-text-primary">No email captures match the filters</td></tr>`;
      return;
    }
    for (const row of rows) {
      const cd = row.calculation_data || {};
      const when = row.created_at ? new Date(row.created_at).toLocaleString() : '';
      const zipState = [cd.zip, cd.state, cd.region].filter(Boolean).join(' · ');
      // Kitchen is stored as a boolean in calculation_data.kitchen (from the
      // mini-split-sizing pattern: the frontend converts 'yes'/'no' → boolean
      // before sending). Display as Y/N.
      const kitchen = cd.kitchen === true ? 'Y' : cd.kitchen === false ? 'N' : '';
      tbody.insertAdjacentHTML('beforeend', `
        <tr class="border-b border-border/50 whitespace-nowrap">
          <td class="py-2 pr-3 text-xs">${escape(when)}</td>
          <td class="py-2 pr-3">${escape(row.email || '')}</td>
          <td class="py-2 pr-3">${escape(row.segment || '—')}</td>
          <td class="py-2 pr-3 font-mono">${row.is_diy === true ? 'Y' : row.is_diy === false ? 'N' : '—'}</td>
          <td class="py-2 pr-3 text-xs">${escape(row.contractor_stage || '—')}</td>
          <td class="py-2 pr-3 font-mono">${escape(row.ab_variant || '—')}</td>
          <td class="py-2 pr-3 text-xs">${escape(zipState)}</td>
          <td class="py-2 pr-3 font-mono">${cd.sqft != null ? Number(cd.sqft).toLocaleString() : ''}</td>
          <td class="py-2 pr-3 font-mono">${escape(String(cd.ceilingHeight ?? ''))}</td>
          <td class="py-2 pr-3">${escape(String(cd.insulation ?? ''))}</td>
          <td class="py-2 pr-3">${escape(String(cd.sun ?? ''))}</td>
          <td class="py-2 pr-3">${escape(String(cd.windows ?? ''))}</td>
          <td class="py-2 pr-3">${escape(String(cd.tightness ?? ''))}</td>
          <td class="py-2 pr-3 font-mono">${escape(String(cd.occupants ?? ''))}</td>
          <td class="py-2 pr-3 font-mono">${escape(String(cd.deviceWatts ?? ''))}</td>
          <td class="py-2 pr-3 font-mono">${escape(kitchen)}</td>
          <td class="py-2 pr-3 font-mono">${cd.coolingBTU != null ? Number(cd.coolingBTU).toLocaleString() : ''}</td>
          <td class="py-2 pr-3 font-mono">${cd.heatingBTU != null ? Number(cd.heatingBTU).toLocaleString() : ''}</td>
          <td class="py-2 font-mono">${escape(String(cd.tonnage ?? ''))}</td>
        </tr>`);
    }
  }

  function escape(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    } as Record<string, string>)[c]);
  }

  async function loadData() {
    if (!adminPassword) { showLogin(); return; }
    errorEl.classList.add('hidden');
    loadingEl.classList.remove('hidden');

    const preset = dateRangeSel.value;
    const { startDate, endDate } = getDateRange(preset);
    const segmentFilter = segmentSel.value;

    try {
      const [capturesP, analyticsP, emailSeqP, dailyChartP] = await Promise.allSettled([
        callCaptures(adminPassword, startDate, endDate, segmentFilter),
        callAnalytics(adminPassword, startDate, endDate),
        callEmailSequence(adminPassword),
        callDailyEmailChart(adminPassword),
      ]);

      if (capturesP.status === 'fulfilled') {
        const rows = Array.isArray(capturesP.value) ? capturesP.value : [];
        renderCaptures(rows);
      } else {
        const msg = String(capturesP.reason);
        if (msg.includes('Unauthorized')) {
          sessionStorage.removeItem('ntq_admin_pw');
          adminPassword = '';
          showLogin();
          return;
        }
        renderCaptures([]);
        errorEl.textContent = `Captures error: ${msg}`;
        errorEl.classList.remove('hidden');
      }

      if (analyticsP.status === 'fulfilled') {
        const { funnel, help, ab, buckets, personaCta } = analyticsP.value;
        renderFunnel(funnel);
        renderAB(ab);
        renderHelp(help);
        renderBuckets(buckets);
        renderPersonaCta(personaCta);
      } else {
        const msg = String(analyticsP.reason);
        const prefix = errorEl.textContent ? errorEl.textContent + ' · ' : '';
        errorEl.textContent = `${prefix}Analytics error: ${msg}`;
        errorEl.classList.remove('hidden');
        renderFunnel({ error: msg });
        renderAB({ error: msg });
        renderHelp({ error: msg });
        renderBuckets({ error: msg });
        renderPersonaCta({ error: msg });
      }

      if (emailSeqP.status === 'fulfilled') {
        renderEmailSequence(emailSeqP.value);
      } else {
        renderEmailSequence(null, String(emailSeqP.reason));
      }

      if (dailyChartP.status === 'fulfilled') {
        renderDailyEmailChart(dailyChartP.value);
      } else {
        renderDailyEmailChart(null, String(dailyChartP.reason));
      }

      showContent();
    } finally {
      loadingEl.classList.add('hidden');
    }
  }

  async function attemptLogin() {
    const pw = passwordInput.value.trim();
    if (!pw) return;
    loginBtn.textContent = 'Checking...';
    loginError.classList.add('hidden');
    try {
      await callCaptures(pw);
      adminPassword = pw;
      sessionStorage.setItem('ntq_admin_pw', pw);
      await loadData();
    } catch (e: any) {
      loginError.textContent = e?.message || 'Login failed. Check the password.';
      loginError.classList.remove('hidden');
      loginBtn.textContent = 'Log in';
    }
  }

  loginBtn.addEventListener('click', attemptLogin);
  passwordInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') attemptLogin(); });
  dateRangeSel.addEventListener('change', loadData);
  segmentSel.addEventListener('change', loadData);
  refreshBtn.addEventListener('click', loadData);

  // Kill-switch toggle. Reads current state from the button's data attribute
  // (set by renderEmailSequence after each load), flips it, and refreshes the
  // panel. Confirms before pausing — easy to fat-finger.
  document.getElementById('es-killswitch-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('es-killswitch-btn') as HTMLButtonElement;
    if (btn.disabled) return;
    const wasPaused = btn.dataset.paused === 'true';
    const newState = !wasPaused;
    if (newState && !confirm('Pause the email scheduler? The cron will keep running but skip all sends until you resume.')) {
      return;
    }
    const prevText = btn.textContent;
    btn.disabled = true;
    btn.textContent = newState ? 'Pausing…' : 'Resuming…';
    try {
      await callSetSchedulerPaused(adminPassword, newState);
      const data = await callEmailSequence(adminPassword);
      renderEmailSequence(data);
    } catch (e: any) {
      btn.textContent = prevText;
      btn.disabled = false;
      alert(`Toggle failed: ${e?.message || e}`);
    }
  });

  if (adminPassword) {
    loadData();
  } else {
    showLogin();
  }
</script>
</BaseLayout>