---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/electricalTools';

const tool = getToolBySlug('upgrade-cost-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a 200 amp panel upgrade cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 200 amp electrical panel upgrade typically costs $1,500 to $4,000 for a standard swap where the existing service entrance and meter base are adequate. If the meter base, weatherhead, and service entrance cable also need replacement, expect $3,000 to $5,500. Adding a grounding electrode update and whole-house surge protection can push the total to $4,000-$6,500."
      }
    },
    {
      "@type": "Question",
      "name": "When do I need a panel upgrade?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A panel upgrade is needed when the existing service is undersized for current loads (common with 60A or 100A services in older homes), when adding major appliances like EV chargers, heat pumps, or hot tubs, when the existing panel is a recalled brand (Federal Pacific, Zinsco), when the panel is full and you need additional circuits, or when insurance or home inspection requires it."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a panel upgrade take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A straightforward panel swap (same location, adequate service entrance) takes 6 to 10 hours for one electrician. If the meter base, weatherhead, and service entrance cable also need replacement, plan for a full day plus coordination with the utility for a service disconnect and reconnect. The utility typically needs 1 to 3 business days advance notice for the disconnect."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need a permit for a panel upgrade?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Panel upgrades and service changes require an electrical permit in every jurisdiction. The inspector will verify proper installation, grounding, bonding, labeling, and code compliance. Some jurisdictions also require the utility to inspect the meter base and service entrance. Permit costs typically range from $100 to $400. Never skip the permit — it protects both you and the homeowner."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="cost-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="currentService">Current Service Size</label>
        <select id="currentService" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="60">60 Amp</option>
          <option value="100" selected>100 Amp</option>
          <option value="150">150 Amp</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="targetService">Target Service Size</label>
        <select id="targetService" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="200" selected>200 Amp</option>
          <option value="400">400 Amp</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="panelType">Panel Type</label>
        <select id="panelType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="main" selected>Main Panel</option>
          <option value="sub">Sub Panel (add-on)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="meterBase">Include Meter Base Replacement</label>
        <select id="meterBase" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="no" selected>No (meter base is adequate)</option>
          <option value="yes">Yes (replace meter base)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="grounding">Include Grounding Update</label>
        <select id="grounding" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="no" selected>No (grounding is current)</option>
          <option value="yes">Yes (update grounding system)</option>
        </select>
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Your Estimate</h3>
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <div class="flex justify-between items-end mb-3">
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Low</div>
            <div id="result-low" class="font-heading font-extrabold text-xl text-text-secondary">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Mid Estimate</div>
            <div id="result-mid" class="font-heading font-extrabold text-3xl text-accent">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">High</div>
            <div id="result-high" class="font-heading font-extrabold text-xl text-text-secondary">--</div>
          </div>
        </div>
        <div class="relative h-3 bg-bg-card rounded-full overflow-hidden mt-4">
          <div id="range-bar" class="absolute inset-y-0 left-[10%] right-[10%] rounded-full bg-gradient-to-r from-accent/40 via-accent to-accent/40"></div>
          <div id="range-marker" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-accent rounded-full border-2 border-white shadow-lg"></div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Est. Labor Time</div>
          <div id="result-hours" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">hours</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center border border-yellow-500/30">
          <div class="text-yellow-400 text-xs font-medium uppercase tracking-wider mb-2">Permit Required</div>
          <div class="font-heading font-extrabold text-2xl text-yellow-400">Yes</div>
          <div class="text-text-muted text-xs mt-1">electrical permit + inspection</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">Ballpark estimate. Actual costs depend on your local utility requirements, permit fees, service entrance routing, and whether the existing wiring from the panel to the meter needs replacement. Always perform an on-site assessment and check utility requirements before finalizing your bid.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Estimator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the current and target service sizes.</strong> Most residential upgrades go from 100A to 200A. Homes with 60A service are increasingly rare but still exist and may need everything from the weatherhead down replaced. 400A service is for large homes or those adding significant electrical loads like EV chargers plus heat pumps.</p>
          <p><strong class="text-text-primary">2. Choose main panel or sub panel.</strong> A main panel upgrade replaces the primary breaker panel and usually involves the service entrance. A sub panel is an add-on panel fed from the main, typically used when you need more circuit spaces without a full service upgrade.</p>
          <p><strong class="text-text-primary">3. Include meter base if needed.</strong> If the meter base is undersized, damaged, or does not meet current utility specs, it needs replacement as part of the upgrade. The utility often has specific meter base requirements that vary by region.</p>
          <p><strong class="text-text-primary">4. Add grounding update if applicable.</strong> Older homes may have inadequate grounding electrode systems. A grounding update adds ground rods, bonding connections, and water pipe bonds to bring the system up to current code.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Affects Panel Upgrade Cost</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Service entrance scope.</strong> A simple panel swap in the same location with an adequate service entrance is the most affordable option. When the meter base, weatherhead, mast, and service entrance cable all need replacement, the job grows significantly. If the service needs to be relocated (e.g., from inside to outside), that adds more labor and material.</p>
          <p><strong class="text-text-primary">Current service size gap.</strong> Going from 60A to 200A is a bigger jump than 100A to 200A. The 60A upgrade usually means everything needs to be upsized — larger service entrance cable, larger conduit, new meter base, and often a new mast. A 100A to 200A often reuses more of the existing service entrance infrastructure.</p>
          <p><strong class="text-text-primary">Utility coordination.</strong> Every service upgrade requires coordination with the local utility. They need to disconnect and reconnect the service, which may require scheduling days in advance. Some utilities charge for this service. In some areas, you need a utility inspection before they will reconnect.</p>
          <p><strong class="text-text-primary">Local code requirements.</strong> Some jurisdictions require additional work during a panel upgrade — whole-house surge protection, AFCI circuits for specific areas, updated grounding systems, or smoke detector circuit upgrades. Know your local code before bidding.</p>
          <p><strong class="text-text-primary">Panel brand and features.</strong> Basic panels are adequate for most residential work. Smart panels with integrated monitoring, generator interlock compatibility, or built-in surge protection cost more but appeal to homeowners interested in energy management and backup power readiness.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Quick phone estimates.</strong> Panel upgrades are one of the most commonly requested electrical services. When a homeowner calls, ask about their current service size and what is driving the upgrade. Plug it in and give them a range on the spot. Fast quoting wins jobs.</p>
          <p><strong class="text-text-primary">EV charger and heat pump add-ons.</strong> Many panel upgrades are driven by the need for a Level 2 EV charger or a heat pump installation. When another contractor tells the homeowner they need a panel upgrade first, being able to quote it quickly makes you the go-to electrician for the follow-up work.</p>
          <p><strong class="text-text-primary">Real estate and inspection situations.</strong> Home inspectors frequently flag outdated panels, recalled brands, or undersized services. Buyers need a fast quote to factor into their purchase decision. Having a reliable estimating tool lets you respond same-day.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does a 200 amp panel upgrade cost?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A 200 amp electrical panel upgrade typically costs $1,500 to $4,000 for a standard swap where the existing service entrance and meter base are adequate. If the meter base, weatherhead, and service entrance cable also need replacement, expect $3,000 to $5,500. Adding a grounding electrode update and whole-house surge protection can push the total to $4,000-$6,500.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">When do I need a panel upgrade?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A panel upgrade is needed when the existing service is undersized for current loads (common with 60A or 100A services in older homes), when adding major appliances like EV chargers, heat pumps, or hot tubs, when the existing panel is a recalled brand (Federal Pacific, Zinsco), when the panel is full and you need additional circuits, or when insurance or home inspection requires it.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How long does a panel upgrade take?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A straightforward panel swap (same location, adequate service entrance) takes 6 to 10 hours for one electrician. If the meter base, weatherhead, and service entrance cable also need replacement, plan for a full day plus coordination with the utility for a service disconnect and reconnect. The utility typically needs 1 to 3 business days advance notice for the disconnect.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Do I need a permit for a panel upgrade?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Panel upgrades and service changes require an electrical permit in every jurisdiction. The inspector will verify proper installation, grounding, bonding, labeling, and code compliance. Some jurisdictions also require the utility to inspect the meter base and service entrance. Permit costs typically range from $100 to $400. Never skip the permit — it protects both you and the homeowner.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate(): void {
    const currentService = parseInt((document.getElementById('currentService') as HTMLSelectElement).value);
    const targetService = parseInt((document.getElementById('targetService') as HTMLSelectElement).value);
    const panelType = (document.getElementById('panelType') as HTMLSelectElement).value;
    const meterBase = (document.getElementById('meterBase') as HTMLSelectElement).value === 'yes';
    const grounding = (document.getElementById('grounding') as HTMLSelectElement).value === 'yes';

    let lowCost = 0;
    let highCost = 0;

    if (panelType === 'sub') {
      // Sub panel: simpler job
      lowCost = 800;
      highCost = 2000;
    } else {
      // Main panel upgrade base costs
      if (targetService === 400) {
        lowCost = 3500;
        highCost = 8000;
      } else {
        // 200A upgrade
        lowCost = 1500;
        highCost = 4000;
      }

      // Current service size affects scope
      if (currentService === 60) {
        lowCost += 800;
        highCost += 1500;
      }
    }

    // Meter base replacement
    if (meterBase) {
      lowCost += 600;
      highCost += 1200;
    }

    // Grounding update
    if (grounding) {
      lowCost += 400;
      highCost += 800;
    }

    const midCost = Math.round((lowCost + highCost) / 2);

    // Labor hours estimate
    let baseHours = panelType === 'sub' ? 4 : 8;
    if (currentService === 60) baseHours += 3;
    if (meterBase) baseHours += 3;
    if (grounding) baseHours += 2;
    if (targetService === 400) baseHours += 4;

    const fmt = (n: number): string => '$' + n.toLocaleString();

    document.getElementById('result-low')!.textContent = fmt(lowCost);
    document.getElementById('result-mid')!.textContent = fmt(midCost);
    document.getElementById('result-high')!.textContent = fmt(highCost);
    document.getElementById('result-hours')!.textContent = baseHours + '-' + (baseHours + 4);
  }

  document.querySelectorAll('#cost-calc select, #cost-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });
  calculate();
</script>
