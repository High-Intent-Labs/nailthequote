---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/electricalTools';

const tool = getToolBySlug('voltage-drop-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an acceptable voltage drop per NEC?",
      "acceptedAnswer": { "@type": "Answer", "text": "NEC recommends a maximum of 3% voltage drop for feeders or branch circuits individually, and 5% total for the combination of feeder plus branch circuit. These are recommendations in the NEC informational notes, not hard code requirements, but most inspectors enforce them." }
    },
    {
      "@type": "Question",
      "name": "How do I calculate voltage drop for a 3-phase circuit?",
      "acceptedAnswer": { "@type": "Answer", "text": "For 3-phase circuits, use VD = (1.732 x I x D x R) / 1000, where I is the line current in amps, D is one-way distance in feet, and R is the conductor resistance per 1000 feet from NEC Chapter 9 Table 8. The 1.732 factor (square root of 3) replaces the factor of 2 used in single-phase calculations." }
    },
    {
      "@type": "Question",
      "name": "Does wire temperature affect voltage drop?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Conductor resistance increases with temperature. NEC Chapter 9 Table 8 values are at 75 degrees F. For higher ambient temperatures, apply a correction factor. Copper resistance increases about 0.4% per degree F above 75 degrees F. This is often negligible for short runs but matters for long feeders." }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="vd-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="loadAmps">Load Current (Amps)</label>
        <input type="number" id="loadAmps" value="20" min="1" max="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="voltage">System Voltage</label>
        <select id="voltage" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="120">120V</option>
          <option value="208">208V</option>
          <option value="240" selected>240V</option>
          <option value="277">277V</option>
          <option value="480">480V</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="circuitType">Circuit Type</label>
        <select id="circuitType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="single" selected>AC Single-Phase</option>
          <option value="three">AC 3-Phase</option>
          <option value="dc">DC</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wireGauge">Wire Gauge (AWG)</label>
        <select id="wireGauge" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="14">#14</option>
          <option value="12" selected>#12</option>
          <option value="10">#10</option>
          <option value="8">#8</option>
          <option value="6">#6</option>
          <option value="4">#4</option>
          <option value="3">#3</option>
          <option value="2">#2</option>
          <option value="1">#1</option>
          <option value="1/0">1/0</option>
          <option value="2/0">2/0</option>
          <option value="3/0">3/0</option>
          <option value="4/0">4/0</option>
          <option value="250">250 kcmil</option>
          <option value="300">300 kcmil</option>
          <option value="350">350 kcmil</option>
          <option value="400">400 kcmil</option>
          <option value="500">500 kcmil</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="material">Conductor Material</label>
        <select id="material" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="copper" selected>Copper</option>
          <option value="aluminum">Aluminum</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="distance">One-Way Distance (ft)</label>
        <input type="number" id="distance" value="150" min="1" max="5000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Voltage Drop</div>
          <div id="result-vdVolts" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">% Drop</div>
          <div id="result-vdPercent" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Voltage at Load</div>
          <div id="result-vLoad" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">NEC Compliance</div>
          <div id="result-compliance" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
      </div>
      <div id="result-suggestion" class="mb-4"></div>
      <p class="text-text-muted text-sm italic">Based on NEC Chapter 9 Tables 8 &amp; 9. Resistance values at 75&deg;F. For higher ambient temperatures, actual voltage drop may be slightly higher.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the load current in amps.</strong> Use the actual expected load, not the breaker rating. For motors, use the nameplate FLA.</p>
          <p><strong class="text-text-primary">2. Set the system voltage and circuit type.</strong> Single-phase uses a factor of 2 in the formula. 3-phase uses 1.732 (square root of 3).</p>
          <p><strong class="text-text-primary">3. Select your wire gauge and material.</strong> The calculator uses NEC Chapter 9 Table 8 resistance values for the selected conductor.</p>
          <p><strong class="text-text-primary">4. Enter the one-way distance.</strong> Measure from the panel or source to the load. The calculator accounts for the round-trip automatically.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Voltage Drop Formula Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>The calculator uses conductor resistance values from <strong class="text-text-primary">NEC Chapter 9 Table 8</strong> (DC resistance) to compute the voltage loss over the wire run length.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Single-Phase: VD = (2 x I x D x R) / 1000</p>
            <p>3-Phase: VD = (1.732 x I x D x R) / 1000</p>
            <p>DC: VD = (2 x I x D x R) / 1000</p>
            <p>VD% = (VD / System_Voltage) x 100</p>
          </div>
          <p>Where I is load current in amps, D is one-way distance in feet, and R is conductor resistance in ohms per 1000 feet. If the drop exceeds 3%, the calculator suggests the next wire size up that would bring the drop within limits.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is an acceptable voltage drop per NEC?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">NEC recommends a maximum of 3% voltage drop for feeders or branch circuits individually, and 5% total for the combination of feeder plus branch circuit. These are recommendations in the NEC informational notes, not hard code requirements, but most inspectors enforce them.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate voltage drop for a 3-phase circuit?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For 3-phase circuits, use VD = (1.732 x I x D x R) / 1000, where I is the line current in amps, D is one-way distance in feet, and R is the conductor resistance per 1000 feet from NEC Chapter 9 Table 8. The 1.732 factor replaces the factor of 2 used in single-phase calculations.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Does wire temperature affect voltage drop?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Conductor resistance increases with temperature. NEC Chapter 9 Table 8 values are at 75 degrees F. For higher ambient temperatures, apply a correction factor. Copper resistance increases about 0.4% per degree F above 75 degrees F.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const loadAmps = parseFloat((document.getElementById('loadAmps') as HTMLInputElement).value) || 20;
    const voltage = parseFloat((document.getElementById('voltage') as HTMLSelectElement).value);
    const circuitType = (document.getElementById('circuitType') as HTMLSelectElement).value;
    const wireGauge = (document.getElementById('wireGauge') as HTMLSelectElement).value;
    const material = (document.getElementById('material') as HTMLSelectElement).value;
    const distance = parseFloat((document.getElementById('distance') as HTMLInputElement).value) || 150;

    const copperR: Record<string, number> = {
      '14':3.07,'12':1.93,'10':1.21,'8':0.764,'6':0.491,'4':0.308,'3':0.245,'2':0.194,
      '1':0.154,'1/0':0.122,'2/0':0.0967,'3/0':0.0766,'4/0':0.0608,
      '250':0.0515,'300':0.0429,'350':0.0367,'400':0.0321,'500':0.0258
    };
    const aluminumR: Record<string, number> = {
      '14':5.06,'12':3.18,'10':2.00,'8':1.26,'6':0.808,'4':0.508,'3':0.403,'2':0.319,
      '1':0.253,'1/0':0.201,'2/0':0.159,'3/0':0.126,'4/0':0.100,
      '250':0.0847,'300':0.0707,'350':0.0605,'400':0.0529,'500':0.0424
    };

    const resTable = material === 'copper' ? copperR : aluminumR;
    const R = resTable[wireGauge] || 1.93;

    let multiplier = 2;
    if (circuitType === 'three') multiplier = 1.732;

    const vdVolts = (multiplier * loadAmps * distance * R) / 1000;
    const vdPercent = (vdVolts / voltage) * 100;
    const voltageAtLoad = voltage - vdVolts;

    document.getElementById('result-vdVolts')!.textContent = vdVolts.toFixed(2) + 'V';
    document.getElementById('result-vdPercent')!.textContent = vdPercent.toFixed(2) + '%';
    document.getElementById('result-vLoad')!.textContent = voltageAtLoad.toFixed(1) + 'V';

    const complianceEl = document.getElementById('result-compliance')!;
    const vdPercentEl = document.getElementById('result-vdPercent')!;
    vdPercentEl.classList.remove('text-[#34D399]', 'text-[#FBBF24]', 'text-[#EF4444]');

    if (vdPercent <= 3) {
      complianceEl.textContent = 'PASS';
      complianceEl.className = 'font-heading font-extrabold text-xl text-[#34D399]';
      vdPercentEl.classList.add('text-[#34D399]');
    } else if (vdPercent <= 5) {
      complianceEl.textContent = 'WARNING';
      complianceEl.className = 'font-heading font-extrabold text-xl text-[#FBBF24]';
      vdPercentEl.classList.add('text-[#FBBF24]');
    } else {
      complianceEl.textContent = 'FAIL';
      complianceEl.className = 'font-heading font-extrabold text-xl text-[#EF4444]';
      vdPercentEl.classList.add('text-[#EF4444]');
    }

    // Suggest next size if over 3%
    const suggEl = document.getElementById('result-suggestion')!;
    if (vdPercent > 3) {
      const gauges = ['14','12','10','8','6','4','3','2','1','1/0','2/0','3/0','4/0','250','300','350','400','500'];
      const curIdx = gauges.indexOf(wireGauge);
      let suggested = '';
      for (let i = curIdx + 1; i < gauges.length; i++) {
        const r = resTable[gauges[i]] || 0;
        const vd = (multiplier * loadAmps * distance * r) / 1000;
        const vdP = (vd / voltage) * 100;
        if (vdP <= 3) {
          const isLarge = ['250','300','350','400','500'].includes(gauges[i]);
          suggested = isLarge ? gauges[i] + ' kcmil' : '#' + gauges[i] + ' AWG';
          break;
        }
      }
      if (suggested) {
        suggEl.innerHTML = `<div class="bg-[rgba(251,191,36,0.1)] border border-[rgba(251,191,36,0.3)] rounded-lg px-4 py-3 text-sm text-[#FCD34D]">To meet 3% voltage drop limit, increase wire to <strong>${suggested}</strong> ${material}.</div>`;
      } else {
        suggEl.innerHTML = `<div class="bg-[rgba(239,68,68,0.1)] border border-[rgba(239,68,68,0.3)] rounded-lg px-4 py-3 text-sm text-[#FCA5A5]">Cannot meet 3% VD limit at this distance. Consider increasing voltage or reducing distance.</div>`;
      }
    } else {
      suggEl.innerHTML = '';
    }
  }

  document.querySelectorAll('#vd-calc input, #vd-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });
  calculate();
</script>
