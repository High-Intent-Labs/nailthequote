---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/electricalTools';

const tool = getToolBySlug('profit-margin-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a good profit margin for electrical contractors?",
      "acceptedAnswer": { "@type": "Answer", "text": "The industry average gross margin for electrical contractors is around 55%. Top-performing shops hit 60% or higher. Service and repair work typically targets 55-65% gross margin, while new construction and larger projects target 35-50%. If your gross margin is consistently below 40%, you are likely underpricing your work." }
    },
    {
      "@type": "Question",
      "name": "What is the difference between margin and markup?",
      "acceptedAnswer": { "@type": "Answer", "text": "Margin is profit as a percentage of revenue (selling price). Markup is profit as a percentage of cost. For example, if a job costs $3,000 and you sell it for $5,000, your profit is $2,000. Your margin is 40% ($2,000 / $5,000) and your markup is 66.7% ($2,000 / $3,000). They describe the same profit from different reference points." }
    },
    {
      "@type": "Question",
      "name": "How do I calculate overhead for an electrical job?",
      "acceptedAnswer": { "@type": "Answer", "text": "Overhead includes all costs to run the business not tied to a specific job: rent, insurance, vehicle payments, office staff, software, marketing, and utilities. Most electrical companies allocate overhead as a percentage of revenue, typically 30-45%. To find yours, divide total annual overhead by total annual revenue." }
    },
    {
      "@type": "Question",
      "name": "Why is my electrical profit margin so low?",
      "acceptedAnswer": { "@type": "Answer", "text": "Common causes include underpricing labor (not accounting for full burden cost), insufficient parts markup on wire, breakers, and components, not tracking overhead allocation, scope creep without change orders, and giving away diagnostic time for free. Use this calculator to test different pricing scenarios." }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="margin-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="revenue">Job Revenue ($)</label>
        <input type="number" id="revenue" value="4200" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="parts">Parts &amp; Materials (wire, breakers, boxes, conduit, fittings)</label>
        <input type="number" id="parts" value="850" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <div class="mb-6">
      <p class="text-sm font-medium text-text-secondary mb-3">Labor</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="techs">Number of Techs</label>
          <input type="number" id="techs" value="2" min="1" max="20" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="hours">Hours</label>
          <input type="number" id="hours" value="8" min="0.5" max="200" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="hourlyRate">Hourly Cost ($)</label>
          <input type="number" id="hourlyRate" value="40" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="materials">Consumables ($)</label>
        <input type="number" id="materials" value="120" min="0" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="overhead">Overhead (%)</label>
        <input type="number" id="overhead" value="35" min="0" max="100" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">% of revenue allocated to overhead (30-45% typical)</p>
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Gross Profit</div>
          <div id="result-profit" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Gross Margin</div>
          <div id="result-margin" class="font-heading font-extrabold text-3xl">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Markup</div>
          <div id="result-markup" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost per $1 Revenue</div>
          <div id="result-costper" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <div class="bg-bg-dark rounded-xl p-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Electrical Industry Benchmarks</h4>
        <div class="space-y-3">
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">Industry Avg Gross Margin</span><span class="text-text-primary font-semibold">55%</span></div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div class="bg-[#60A5FA] h-2 rounded-full" style="width:55%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">Top Performers</span><span class="text-text-primary font-semibold">60%+</span></div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div class="bg-[#34D399] h-2 rounded-full" style="width:60%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">Service &amp; Repair Target</span><span class="text-text-primary font-semibold">55 &ndash; 65%</span></div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div class="bg-[#C084FC] h-2 rounded-full" style="width:60%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">New Construction Target</span><span class="text-text-primary font-semibold">35 &ndash; 50%</span></div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div class="bg-[#FBBF24] h-2 rounded-full" style="width:42%"></div></div>
          </div>
          <div id="benchmark-warning" class="hidden mt-3 bg-[rgba(239,68,68,0.1)] border border-[rgba(239,68,68,0.3)] rounded-lg px-4 py-3 text-sm text-[#FCA5A5]">Your margin is below 40%. You may be underpricing your work.</div>
        </div>
        <div class="mt-4 pt-4 border-t border-border">
          <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary font-medium">Your Gross Margin</span><span id="benchmark-your-margin" class="font-heading font-bold">--</span></div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2.5"><div id="benchmark-bar" class="h-2.5 rounded-full transition-all duration-500" style="width:0%"></div></div>
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter your job revenue.</strong> This is the total amount you charge the customer including all line items.</p>
          <p><strong class="text-text-primary">2. Enter parts and materials cost.</strong> Your wholesale cost for wire, breakers, boxes, conduit, fittings, and components.</p>
          <p><strong class="text-text-primary">3. Fill in labor details.</strong> Number of techs, total hours, and your burdened hourly cost (wages + payroll taxes + workers comp).</p>
          <p><strong class="text-text-primary">4. Add consumables and overhead.</strong> Consumables are tape, connectors, wire nuts, etc. Overhead is typically 30-45% for electrical contractors.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How Profit Margin Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Labor_Cost = Techs x Hours x Hourly_Rate</p>
            <p>Total_Cost = Parts + Labor_Cost + Consumables + (Revenue x Overhead%/100)</p>
            <p>Profit = Revenue - Total_Cost</p>
            <p>Gross_Margin = (Profit / Revenue) x 100</p>
            <p>Markup = (Profit / Total_Cost) x 100</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is a good profit margin for electrical contractors?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The industry average gross margin is around 55%. Top shops hit 60%+. Service work targets 55-65%, new construction targets 35-50%.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is the difference between margin and markup?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Margin is profit as % of revenue. Markup is profit as % of cost. A $5,000 job with $3,000 cost = 40% margin and 66.7% markup.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate overhead for an electrical job?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Divide total annual overhead (rent, insurance, vehicles, office, software, marketing) by total annual revenue. Most electrical companies run 30-45%.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why is my electrical profit margin so low?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Common causes: underpricing labor, insufficient parts markup, untracked overhead, scope creep, and free diagnostics.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const revenue = parseFloat((document.getElementById('revenue') as HTMLInputElement).value) || 0;
    const parts = parseFloat((document.getElementById('parts') as HTMLInputElement).value) || 0;
    const techs = parseFloat((document.getElementById('techs') as HTMLInputElement).value) || 0;
    const hours = parseFloat((document.getElementById('hours') as HTMLInputElement).value) || 0;
    const hourlyRate = parseFloat((document.getElementById('hourlyRate') as HTMLInputElement).value) || 0;
    const materials = parseFloat((document.getElementById('materials') as HTMLInputElement).value) || 0;
    const overheadPct = parseFloat((document.getElementById('overhead') as HTMLInputElement).value) || 0;

    const laborCost = techs * hours * hourlyRate;
    const overheadCost = revenue * (overheadPct / 100);
    const totalCost = parts + laborCost + materials + overheadCost;
    const profit = revenue - totalCost;
    const grossMargin = revenue > 0 ? (profit / revenue) * 100 : 0;
    const markup = totalCost > 0 ? (profit / totalCost) * 100 : 0;
    const costPerDollar = revenue > 0 ? totalCost / revenue : 0;

    const fmt = (n: number) => n >= 0
      ? '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 })
      : '-$' + Math.abs(n).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });

    document.getElementById('result-profit')!.textContent = fmt(profit);
    document.getElementById('result-margin')!.textContent = grossMargin.toFixed(1) + '%';
    document.getElementById('result-markup')!.textContent = markup.toFixed(1) + '%';
    document.getElementById('result-costper')!.textContent = '$' + costPerDollar.toFixed(2);

    const marginEl = document.getElementById('result-margin')!;
    marginEl.classList.remove('text-[#34D399]', 'text-[#FBBF24]', 'text-[#EF4444]');
    if (grossMargin >= 55) marginEl.classList.add('text-[#34D399]');
    else if (grossMargin >= 40) marginEl.classList.add('text-[#FBBF24]');
    else marginEl.classList.add('text-[#EF4444]');

    const profitEl = document.getElementById('result-profit')!;
    profitEl.classList.remove('text-accent', 'text-[#34D399]', 'text-[#EF4444]');
    profitEl.classList.add(profit >= 0 ? 'text-[#34D399]' : 'text-[#EF4444]');

    const clampedMargin = Math.max(0, Math.min(100, grossMargin));
    const bar = document.getElementById('benchmark-bar')!;
    bar.style.width = clampedMargin + '%';
    bar.classList.remove('bg-[#34D399]', 'bg-[#FBBF24]', 'bg-[#EF4444]');
    bar.classList.add(grossMargin >= 55 ? 'bg-[#34D399]' : grossMargin >= 40 ? 'bg-[#FBBF24]' : 'bg-[#EF4444]');

    const ymEl = document.getElementById('benchmark-your-margin')!;
    ymEl.textContent = grossMargin.toFixed(1) + '%';
    ymEl.classList.remove('text-[#34D399]', 'text-[#FBBF24]', 'text-[#EF4444]');
    ymEl.classList.add(grossMargin >= 55 ? 'text-[#34D399]' : grossMargin >= 40 ? 'text-[#FBBF24]' : 'text-[#EF4444]');

    const warnEl = document.getElementById('benchmark-warning')!;
    if (grossMargin < 40) warnEl.classList.remove('hidden');
    else warnEl.classList.add('hidden');
  }

  document.querySelectorAll('#margin-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });
  calculate();
</script>
