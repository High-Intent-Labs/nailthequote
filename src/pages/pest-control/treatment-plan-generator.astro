---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/pestControlTools';

const tool = getToolBySlug('treatment-plan-generator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many gallons of spray solution do I need per 1,000 square feet?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standard coverage rates for pest control spraying are typically 1 gallon of finished solution per 1,000 square feet for interior applications and 1-2 gallons per 1,000 square feet for exterior perimeter treatments. These rates vary by product label, target pest, and surface porosity. Always follow the product label for specific coverage rates."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate the amount of product concentrate needed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "First determine total gallons of finished solution needed based on square footage and coverage rate. Then multiply total gallons by the label application rate in ounces per gallon. For example, if you need 2.5 gallons of solution and the label rate is 1 oz per gallon, you need 2.5 oz of concentrate total."
      }
    },
    {
      "@type": "Question",
      "name": "How many bait stations do I need for a residential home?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For exterior rodent bait stations, the standard is one station every 25-50 feet around the perimeter. A typical 2,000 sq ft home with 180 linear feet of perimeter needs 4-7 stations. For interior insect bait stations, place them every 8-10 linear feet along baseboards in active areas. Adjust spacing based on pest pressure and the product label."
      }
    },
    {
      "@type": "Question",
      "name": "What follow-up interval should I recommend to customers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Follow-up intervals depend on the pest type and treatment method. General pest control with residual sprays typically calls for quarterly service (every 90 days). Ants and roaches in active infestations need 2-4 week follow-ups until controlled, then quarterly maintenance. Bed bugs require follow-ups every 10-14 days. Termites using bait stations need monitoring every 60-90 days. Mosquito treatments are usually monthly during active season."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="tplan-calc">
    <!-- Top row: Pest Type and Property Type -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="pest-type">Pest Type</label>
        <select id="pest-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="general" selected>General Pest / Roaches</option>
          <option value="ants">Ants</option>
          <option value="spiders">Spiders</option>
          <option value="rodents">Rodents</option>
          <option value="termites">Termites</option>
          <option value="bedbugs">Bed Bugs</option>
          <option value="mosquitoes">Mosquitoes</option>
          <option value="wasps">Wasps / Bees</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="property-type">Property Type</label>
        <select id="property-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="residential" selected>Residential</option>
          <option value="commercial">Commercial</option>
          <option value="restaurant">Restaurant / Food Service</option>
          <option value="warehouse">Warehouse / Industrial</option>
        </select>
      </div>
    </div>

    <!-- Area inputs -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sq-footage">Interior Square Footage</label>
        <input type="number" id="sq-footage" value="2000" min="100" max="500000" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Total treatable interior area</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="perimeter-ft">Exterior Perimeter (linear feet)</label>
        <input type="number" id="perimeter-ft" value="180" min="0" max="50000" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Foundation perimeter for exterior treatment</p>
      </div>
    </div>

    <!-- Treatment method and application settings -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="treatment-method">Treatment Method</label>
        <select id="treatment-method" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="perimeter-spray" selected>Perimeter Spray</option>
          <option value="interior-spray">Interior Spray</option>
          <option value="bait-stations">Bait Stations</option>
          <option value="gel-bait">Gel Bait</option>
          <option value="dust">Dust Application</option>
          <option value="fumigation">Fumigation</option>
        </select>
      </div>
      <div id="app-rate-group">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="app-rate">Application Rate (oz / gallon)</label>
        <input type="number" id="app-rate" value="1" min="0.1" max="16" step="0.1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Concentrate per gallon of finished solution</p>
      </div>
      <div id="coverage-rate-group">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="coverage-rate">Coverage Rate (gal / 1,000 sq ft)</label>
        <input type="number" id="coverage-rate" value="1" min="0.1" max="10" step="0.1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Gallons of finished spray per 1,000 sq ft</p>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Treatment Plan Summary</h3>

      <!-- Pest & property context bar -->
      <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
        <div class="flex flex-wrap gap-x-8 gap-y-2 text-sm">
          <div><span class="text-text-muted">Pest:</span> <span id="result-pest" class="text-text-primary font-medium">General Pest / Roaches</span></div>
          <div><span class="text-text-muted">Property:</span> <span id="result-property" class="text-text-primary font-medium">Residential</span></div>
          <div><span class="text-text-muted">Method:</span> <span id="result-method" class="text-text-primary font-medium">Perimeter Spray</span></div>
        </div>
      </div>

      <!-- Primary result cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center border-2" style="border-color: rgba(255,107,43,0.4);">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Solution Needed</div>
          <div id="result-total-gallons" class="font-heading font-extrabold text-3xl text-accent">--</div>
          <div class="text-text-muted text-xs mt-1">gallons</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Product Concentrate</div>
          <div id="result-product-oz" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">fluid ounces</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Bait Stations</div>
          <div id="result-bait-stations" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">stations recommended</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Estimated Time</div>
          <div id="result-time" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">on-site</div>
        </div>
      </div>

      <!-- Secondary detail cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Treatment Area</div>
          <div id="result-area" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div id="result-area-unit" class="text-text-muted text-xs mt-1">sq ft / linear ft</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Follow-Up Interval</div>
          <div id="result-followup" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">recommended</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Product in Quarts</div>
          <div id="result-product-qt" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">of concentrate</div>
        </div>
      </div>

      <!-- Treatment notes -->
      <div id="treatment-notes" class="bg-bg-card border border-border rounded-xl p-5 mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Treatment Notes</h4>
        <ul id="notes-list" class="text-text-secondary text-sm leading-relaxed space-y-2">
        </ul>
      </div>

      <p class="text-text-muted text-sm italic">Estimates based on standard application rates and typical conditions. Always follow the product label for exact rates, re-entry intervals, and PPE requirements. Adjust quantities based on actual pest pressure and site conditions.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Tool</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the pest type and property type.</strong> Choose the target pest you are treating and the type of property. The tool adjusts default recommendations, estimated treatment time, and follow-up intervals based on these selections.</p>
          <p><strong class="text-text-primary">2. Enter the treatment area.</strong> Input interior square footage for indoor treatments and perimeter linear feet for exterior treatments. The tool uses whichever measurement applies to your selected treatment method.</p>
          <p><strong class="text-text-primary">3. Choose the treatment method.</strong> Select how you plan to treat. Perimeter spray uses the exterior linear footage. Interior spray uses the square footage. Bait stations calculate placement counts based on spacing standards. Gel bait, dust, and fumigation each adjust the output accordingly.</p>
          <p><strong class="text-text-primary">4. Set application and coverage rates.</strong> Enter the product label rate in ounces per gallon and the coverage rate in gallons per 1,000 square feet. These two values determine how much finished solution and concentrate you need for the job.</p>
        </div>
      </section>

      <!-- How the Calculations Work -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Calculations Work</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Spray solution volume:</strong> The tool divides your treatable area by 1,000, then multiplies by the coverage rate. For a perimeter spray, it converts linear feet to square feet by assuming a 3-foot treatment band on each side of the foundation. The result is total gallons of finished spray solution needed for the job.</p>
          <p><strong class="text-text-primary">Product concentrate:</strong> Once total solution gallons are known, the tool multiplies by the application rate (ounces per gallon) to determine how many ounces of concentrate to pull from the jug. This is the number you need when loading your tank.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Total_Gallons = (Treatable_Area / 1,000) x Coverage_Rate</p>
            <p>Concentrate_Oz = Total_Gallons x App_Rate_Per_Gallon</p>
            <p>Bait_Stations = Perimeter_LF / Station_Spacing</p>
          </div>
          <p><strong class="text-text-primary">Bait station count:</strong> For bait station treatments, the tool divides the exterior perimeter by the recommended spacing interval (typically 25-50 feet for rodent stations, 8-10 feet for insect stations). The count rounds up so you always have enough stations to close any gaps in your placement.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Pre-loading your truck before a route.</strong> Run each job through the tool the night before to know exactly how much product and how many bait stations to load. No more guessing whether you have enough concentrate for a large commercial account or running back to the shop mid-route.</p>
          <p><strong class="text-text-primary">Quoting jobs with accurate material costs.</strong> When you know the exact ounces of concentrate needed, you can calculate your true material cost per job. Enter the square footage from the inspection, pick the treatment method, and use the product totals to build a profitable price.</p>
          <p><strong class="text-text-primary">Training new technicians on coverage standards.</strong> Hand a new tech the treatment plan before they roll out. It tells them the target pest, method, how much solution to mix, how many stations to place, and the follow-up timeline. It builds consistency across your team and reduces callbacks from under-application.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many gallons of spray solution do I need per 1,000 square feet?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Standard coverage rates for pest control spraying are typically 1 gallon of finished solution per 1,000 square feet for interior applications and 1-2 gallons per 1,000 square feet for exterior perimeter treatments. These rates vary by product label, target pest, and surface porosity. Always follow the product label for specific coverage rates.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate the amount of product concentrate needed?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">First determine total gallons of finished solution needed based on square footage and coverage rate. Then multiply total gallons by the label application rate in ounces per gallon. For example, if you need 2.5 gallons of solution and the label rate is 1 oz per gallon, you need 2.5 oz of concentrate total.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many bait stations do I need for a residential home?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For exterior rodent bait stations, the standard is one station every 25-50 feet around the perimeter. A typical 2,000 sq ft home with 180 linear feet of perimeter needs 4-7 stations. For interior insect bait stations, place them every 8-10 linear feet along baseboards in active areas. Adjust spacing based on pest pressure and the product label.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What follow-up interval should I recommend to customers?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Follow-up intervals depend on the pest type and treatment method. General pest control with residual sprays typically calls for quarterly service (every 90 days). Ants and roaches in active infestations need 2-4 week follow-ups until controlled, then quarterly maintenance. Bed bugs require follow-ups every 10-14 days. Termites using bait stations need monitoring every 60-90 days. Mosquito treatments are usually monthly during active season.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // --- TypeScript types ---
  interface PestProfile {
    label: string;
    followUp: string;
    baseMinutes: number;
    sqftMinutePer1000: number;
    notes: string[];
    baitSpacing: number; // linear feet between stations
  }

  interface PropertyProfile {
    label: string;
    timeMultiplier: number;
  }

  interface MethodProfile {
    label: string;
    usesSpray: boolean;
    usesBait: boolean;
    usesDust: boolean;
    usesFumigation: boolean;
  }

  // --- Data tables ---
  const pestProfiles: Record<string, PestProfile> = {
    general: {
      label: 'General Pest / Roaches',
      followUp: 'Every 90 days (quarterly)',
      baseMinutes: 20,
      sqftMinutePer1000: 8,
      notes: [
        'Apply residual spray along baseboards, under sinks, and around entry points.',
        'Treat exterior perimeter 3 feet up and 3 feet out from foundation.',
        'Focus on kitchens, bathrooms, and utility rooms for interior treatment.',
        'Check weather stripping and door sweeps during inspection.'
      ],
      baitSpacing: 10
    },
    ants: {
      label: 'Ants',
      followUp: 'Every 2-4 weeks until controlled, then quarterly',
      baseMinutes: 25,
      sqftMinutePer1000: 10,
      notes: [
        'Identify species before treatment — bait preference varies by species.',
        'Trace trails to locate entry points and treat at the source.',
        'Apply non-repellent products near trails so foragers carry it back to the colony.',
        'Place bait stations near active trails and entry points.'
      ],
      baitSpacing: 8
    },
    spiders: {
      label: 'Spiders',
      followUp: 'Every 60-90 days',
      baseMinutes: 20,
      sqftMinutePer1000: 7,
      notes: [
        'Remove visible webs during treatment to monitor for re-infestation.',
        'Treat eaves, window frames, door frames, and exterior lighting areas.',
        'Dust voids and undisturbed areas where spiders harbor.',
        'Reducing other insect populations limits the spider food source.'
      ],
      baitSpacing: 10
    },
    rodents: {
      label: 'Rodents',
      followUp: 'Every 30 days until controlled, then every 60-90 days',
      baseMinutes: 30,
      sqftMinutePer1000: 5,
      notes: [
        'Conduct thorough inspection for droppings, rub marks, and gnaw damage.',
        'Seal entry points larger than 1/4 inch for mice or 1/2 inch for rats.',
        'Place tamper-resistant bait stations along walls and travel paths.',
        'Check and service all stations on every follow-up visit.'
      ],
      baitSpacing: 30
    },
    termites: {
      label: 'Termites',
      followUp: 'Every 60-90 days (bait monitoring) or annual (liquid barrier)',
      baseMinutes: 45,
      sqftMinutePer1000: 12,
      notes: [
        'Identify termite species (subterranean vs. drywood) before selecting treatment.',
        'For liquid barrier: trench and rod along the entire foundation perimeter.',
        'For bait systems: install monitoring stations every 10-15 linear feet.',
        'Document all findings and treatment details for the customer record.'
      ],
      baitSpacing: 12
    },
    bedbugs: {
      label: 'Bed Bugs',
      followUp: 'Every 10-14 days (minimum 2-3 follow-ups)',
      baseMinutes: 60,
      sqftMinutePer1000: 25,
      notes: [
        'Inspect mattress seams, box springs, headboards, and baseboards thoroughly.',
        'Treat cracks and crevices with residual spray and dust formulations.',
        'Encase mattresses and box springs after treatment.',
        'Advise customer on preparation: laundering bedding, reducing clutter.'
      ],
      baitSpacing: 0
    },
    mosquitoes: {
      label: 'Mosquitoes',
      followUp: 'Monthly during active season',
      baseMinutes: 20,
      sqftMinutePer1000: 5,
      notes: [
        'Treat shaded resting areas: under eaves, shrubs, tall grass, fences.',
        'Address standing water sources or advise customer to eliminate them.',
        'Apply adulticide to vegetation and structural resting surfaces.',
        'Consider larvicide in water features that cannot be drained.'
      ],
      baitSpacing: 0
    },
    wasps: {
      label: 'Wasps / Bees',
      followUp: 'As needed (one-time treatment typical)',
      baseMinutes: 25,
      sqftMinutePer1000: 3,
      notes: [
        'Locate all active nests before beginning treatment.',
        'Treat nests during early morning or late evening when activity is lowest.',
        'Use dust formulations for wall voids and aerosol for exposed nests.',
        'Remove accessible nests after knockdown and seal entry points.'
      ],
      baitSpacing: 0
    }
  };

  const propertyProfiles: Record<string, PropertyProfile> = {
    residential: { label: 'Residential', timeMultiplier: 1.0 },
    commercial: { label: 'Commercial', timeMultiplier: 1.2 },
    restaurant: { label: 'Restaurant / Food Service', timeMultiplier: 1.4 },
    warehouse: { label: 'Warehouse / Industrial', timeMultiplier: 0.8 }
  };

  const methodProfiles: Record<string, MethodProfile> = {
    'perimeter-spray': { label: 'Perimeter Spray', usesSpray: true, usesBait: false, usesDust: false, usesFumigation: false },
    'interior-spray': { label: 'Interior Spray', usesSpray: true, usesBait: false, usesDust: false, usesFumigation: false },
    'bait-stations': { label: 'Bait Stations', usesSpray: false, usesBait: true, usesDust: false, usesFumigation: false },
    'gel-bait': { label: 'Gel Bait', usesSpray: false, usesBait: true, usesDust: false, usesFumigation: false },
    'dust': { label: 'Dust Application', usesSpray: false, usesBait: false, usesDust: true, usesFumigation: false },
    'fumigation': { label: 'Fumigation', usesSpray: false, usesBait: false, usesDust: false, usesFumigation: true }
  };

  function calculate(): void {
    const pestType = (document.getElementById('pest-type') as HTMLSelectElement).value;
    const propertyType = (document.getElementById('property-type') as HTMLSelectElement).value;
    const sqFootage = parseFloat((document.getElementById('sq-footage') as HTMLInputElement).value) || 2000;
    const perimeterFt = parseFloat((document.getElementById('perimeter-ft') as HTMLInputElement).value) || 180;
    const treatmentMethod = (document.getElementById('treatment-method') as HTMLSelectElement).value;
    const appRate = parseFloat((document.getElementById('app-rate') as HTMLInputElement).value) || 1;
    const coverageRate = parseFloat((document.getElementById('coverage-rate') as HTMLInputElement).value) || 1;

    const pest = pestProfiles[pestType] || pestProfiles['general'];
    const property = propertyProfiles[propertyType] || propertyProfiles['residential'];
    const method = methodProfiles[treatmentMethod] || methodProfiles['perimeter-spray'];

    // Show/hide rate inputs based on method
    const appRateGroup = document.getElementById('app-rate-group') as HTMLElement;
    const coverageRateGroup = document.getElementById('coverage-rate-group') as HTMLElement;

    if (method.usesSpray) {
      appRateGroup.classList.remove('hidden');
      coverageRateGroup.classList.remove('hidden');
    } else if (method.usesDust) {
      appRateGroup.classList.remove('hidden');
      coverageRateGroup.classList.add('hidden');
    } else {
      appRateGroup.classList.add('hidden');
      coverageRateGroup.classList.add('hidden');
    }

    // Determine treatable area based on method
    let treatableAreaSqFt: number = 0;
    let areaDisplay: string = '';
    let areaUnit: string = '';

    if (treatmentMethod === 'perimeter-spray') {
      // 3-foot band on each side = 6 feet wide total perimeter band
      treatableAreaSqFt = perimeterFt * 6;
      areaDisplay = perimeterFt.toLocaleString() + ' LF';
      areaUnit = 'linear feet (perimeter)';
    } else if (treatmentMethod === 'interior-spray') {
      treatableAreaSqFt = sqFootage;
      areaDisplay = sqFootage.toLocaleString() + ' sq ft';
      areaUnit = 'square feet (interior)';
    } else if (treatmentMethod === 'bait-stations' || treatmentMethod === 'gel-bait') {
      treatableAreaSqFt = 0;
      areaDisplay = perimeterFt.toLocaleString() + ' LF';
      areaUnit = 'linear feet (placement area)';
    } else if (treatmentMethod === 'dust') {
      treatableAreaSqFt = sqFootage * 0.1; // dust covers ~10% of area (voids/cracks)
      areaDisplay = sqFootage.toLocaleString() + ' sq ft';
      areaUnit = 'square feet (voids/cracks ~10%)';
    } else if (treatmentMethod === 'fumigation') {
      treatableAreaSqFt = sqFootage;
      areaDisplay = sqFootage.toLocaleString() + ' sq ft';
      areaUnit = 'square feet (full structure)';
    }

    // Calculate spray solution
    let totalGallons: number = 0;
    let concentrateOz: number = 0;

    if (method.usesSpray) {
      totalGallons = (treatableAreaSqFt / 1000) * coverageRate;
      concentrateOz = totalGallons * appRate;
    } else if (method.usesDust) {
      // Dust: app rate is oz of dust product per 1000 sq ft of void area
      concentrateOz = (treatableAreaSqFt / 1000) * appRate;
      totalGallons = 0;
    } else if (method.usesFumigation) {
      // Fumigation: volume-based, rough estimate in solution equivalent
      totalGallons = sqFootage * 0.001; // placeholder ratio
      concentrateOz = totalGallons * appRate;
    }

    // Calculate bait stations
    let baitStationCount: number = 0;
    if (method.usesBait && pest.baitSpacing > 0) {
      if (treatmentMethod === 'gel-bait') {
        // Gel bait placements: roughly every 3-5 feet in active areas
        baitStationCount = Math.ceil(perimeterFt / 5);
      } else {
        baitStationCount = Math.ceil(perimeterFt / pest.baitSpacing);
      }
    }

    // Estimate time
    let estMinutes: number = pest.baseMinutes + (sqFootage / 1000) * pest.sqftMinutePer1000;
    estMinutes *= property.timeMultiplier;
    if (method.usesBait) estMinutes += baitStationCount * 2; // ~2 min per station
    estMinutes = Math.round(estMinutes);

    const hours = Math.floor(estMinutes / 60);
    const mins = estMinutes % 60;
    const timeDisplay = hours > 0 ? hours + 'h ' + mins + 'm' : mins + ' min';

    // Update context bar
    document.getElementById('result-pest')!.textContent = pest.label;
    document.getElementById('result-property')!.textContent = property.label;
    document.getElementById('result-method')!.textContent = method.label;

    // Update primary results
    if (method.usesSpray) {
      document.getElementById('result-total-gallons')!.textContent = totalGallons.toFixed(1);
    } else if (method.usesFumigation) {
      document.getElementById('result-total-gallons')!.textContent = totalGallons.toFixed(1);
    } else {
      document.getElementById('result-total-gallons')!.textContent = 'N/A';
    }

    if (concentrateOz > 0) {
      document.getElementById('result-product-oz')!.textContent = concentrateOz.toFixed(1);
    } else {
      document.getElementById('result-product-oz')!.textContent = 'N/A';
    }

    document.getElementById('result-bait-stations')!.textContent = method.usesBait ? baitStationCount.toString() : 'N/A';
    document.getElementById('result-time')!.textContent = timeDisplay;

    // Update secondary results
    document.getElementById('result-area')!.textContent = areaDisplay;
    document.getElementById('result-area-unit')!.textContent = areaUnit;
    document.getElementById('result-followup')!.textContent = pest.followUp;
    document.getElementById('result-product-qt')!.textContent = concentrateOz > 0 ? (concentrateOz / 32).toFixed(2) + ' qt' : 'N/A';

    // Treatment notes
    const notesList = document.getElementById('notes-list') as HTMLUListElement;
    notesList.innerHTML = '';
    pest.notes.forEach((note: string) => {
      const li = document.createElement('li');
      li.textContent = note;
      notesList.appendChild(li);
    });

    // Add method-specific note
    if (method.usesSpray && totalGallons > 0) {
      const li = document.createElement('li');
      const tankLoads4 = Math.ceil(totalGallons / 4);
      const tankLoads1 = Math.ceil(totalGallons / 1);
      li.textContent = 'Tank loads: ' + tankLoads1 + ' fill(s) with a 1-gal sprayer, or ' + tankLoads4 + ' fill(s) with a 4-gal backpack.';
      notesList.appendChild(li);
    }
    if (method.usesBait) {
      const li = document.createElement('li');
      li.textContent = 'Place stations flush against walls and in areas with evidence of activity.';
      notesList.appendChild(li);
    }
    if (method.usesDust) {
      const li = document.createElement('li');
      li.textContent = 'Apply dust lightly into wall voids, under baseboards, and around pipe penetrations. Avoid visible piles.';
      notesList.appendChild(li);
    }
  }

  // Auto-calculate on any input change
  document.querySelectorAll('#tplan-calc input, #tplan-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
