---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/pestControlTools';

const tool = getToolBySlug('job-pricing-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I price a pest control job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Calculate total cost by adding labor (hours x rate), materials with markup, equipment costs, travel time, and overhead allocation. Then multiply by (1 + desired margin). For example, a termite treatment with $200 labor, $150 materials (marked up), $50 equipment, and 40% margin = ($400 cost) x 1.4 = $560 job price."
      }
    },
    {
      "@type": "Question",
      "name": "How much does a termite fumigation job cost to perform?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A typical residential termite fumigation costs the company $8,000-$15,000 to perform including labor (2-3 days for a 2-person crew), fumigant chemicals, tarping materials, equipment rental, monitoring equipment, and insurance. Companies typically price fumigation jobs at $12,000-$25,000 depending on structure size and market."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="job-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="jobType">Job Type</label>
        <select id="jobType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="general">General Pest Treatment</option>
          <option value="termite-liquid" selected>Termite Liquid Barrier</option>
          <option value="fumigation">Termite Fumigation</option>
          <option value="rodent">Rodent Exclusion + Baiting</option>
          <option value="bedbug">Bed Bug Treatment</option>
          <option value="inspection">Inspection Only</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="laborHours">Estimated Labor Hours</label>
        <input type="number" id="laborHours" value="6" min="0.5" max="200" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="numTechs">Number of Technicians</label>
        <input type="number" id="numTechs" value="2" min="1" max="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="hourlyRate">Billing Rate ($/hr)</label>
        <input type="number" id="hourlyRate" value="85" min="0" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="materialCost">Material Cost ($)</label>
        <input type="number" id="materialCost" value="350" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="markupPct">Material Markup (%)</label>
        <input type="number" id="markupPct" value="60" min="0" max="300" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equipCost">Equipment / Rental ($)</label>
        <input type="number" id="equipCost" value="75" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="travelTime">Travel Time (hours)</label>
        <input type="number" id="travelTime" value="1" min="0" max="8" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="overheadPct">Overhead Allocation (%)</label>
        <input type="number" id="overheadPct" value="15" min="0" max="50" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="desiredMargin">Desired Profit Margin (%)</label>
        <input type="number" id="desiredMargin" value="35" min="0" max="70" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Job Pricing</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Recommended Price</div>
          <div id="result-price" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Cost</div>
          <div id="result-cost" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit</div>
          <div id="result-profit" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Effective Margin</div>
          <div id="result-margin" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost Breakdown</div>
        <div id="result-breakdown" class="text-text-secondary text-sm">--</div>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the job type.</strong> This helps you categorize the work and compare pricing to industry standards.</p>
          <p><strong class="text-text-primary">2. Enter labor details.</strong> Estimate total hours on-site, number of technicians, and your hourly billing rate. Include travel time separately.</p>
          <p><strong class="text-text-primary">3. Add material and equipment costs.</strong> Enter wholesale material cost with your desired markup, plus any equipment rental or specialized tools.</p>
          <p><strong class="text-text-primary">4. Set overhead and margin.</strong> Overhead allocation covers the portion of fixed costs assigned to this job. The margin is your profit target on top of all costs.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I price a pest control job?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Calculate total cost by adding labor (hours x rate), materials with markup, equipment costs, travel time, and overhead allocation. Then multiply by (1 + desired margin). For example, a termite treatment with $200 labor, $150 materials (marked up), $50 equipment, and 40% margin = ($400 cost) x 1.4 = $560 job price.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does a termite fumigation job cost to perform?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A typical residential termite fumigation costs the company $8,000-$15,000 to perform including labor (2-3 days for a 2-person crew), fumigant chemicals, tarping materials, equipment rental, monitoring equipment, and insurance. Companies typically price fumigation jobs at $12,000-$25,000 depending on structure size and market.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const laborHours = parseFloat((document.getElementById('laborHours') as HTMLInputElement).value) || 0;
    const numTechs = parseFloat((document.getElementById('numTechs') as HTMLInputElement).value) || 1;
    const hourlyRate = parseFloat((document.getElementById('hourlyRate') as HTMLInputElement).value) || 0;
    const materialCost = parseFloat((document.getElementById('materialCost') as HTMLInputElement).value) || 0;
    const markupPct = parseFloat((document.getElementById('markupPct') as HTMLInputElement).value) || 0;
    const equipCost = parseFloat((document.getElementById('equipCost') as HTMLInputElement).value) || 0;
    const travelTime = parseFloat((document.getElementById('travelTime') as HTMLInputElement).value) || 0;
    const overheadPct = parseFloat((document.getElementById('overheadPct') as HTMLInputElement).value) || 0;
    const desiredMargin = parseFloat((document.getElementById('desiredMargin') as HTMLInputElement).value) || 0;

    const laborCost = (laborHours * numTechs + travelTime) * hourlyRate;
    const materialWithMarkup = materialCost * (1 + markupPct / 100);
    const subtotal = laborCost + materialWithMarkup + equipCost;
    const overheadCost = subtotal * (overheadPct / 100);
    const totalCost = subtotal + overheadCost;
    const jobPrice = totalCost / (1 - desiredMargin / 100);
    const profit = jobPrice - totalCost;
    const effectiveMargin = jobPrice > 0 ? (profit / jobPrice) * 100 : 0;

    document.getElementById('result-price')!.textContent = '$' + Math.round(jobPrice).toLocaleString();
    document.getElementById('result-cost')!.textContent = '$' + Math.round(totalCost).toLocaleString();
    document.getElementById('result-profit')!.textContent = '$' + Math.round(profit).toLocaleString();
    document.getElementById('result-margin')!.textContent = effectiveMargin.toFixed(1) + '%';

    document.getElementById('result-breakdown')!.textContent =
      `Labor: $${Math.round(laborCost).toLocaleString()} | Materials (w/ markup): $${Math.round(materialWithMarkup).toLocaleString()} | Equipment: $${Math.round(equipCost).toLocaleString()} | Overhead: $${Math.round(overheadCost).toLocaleString()}`;
  }

  document.querySelectorAll('#job-calc input, #job-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
