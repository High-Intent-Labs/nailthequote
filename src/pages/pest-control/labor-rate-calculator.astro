---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/pestControlTools';

const tool = getToolBySlug('labor-rate-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the average hourly rate for pest control technicians?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pest control technician billing rates typically range from $65 to $120 per hour depending on region, service type, and experience level. The technician's actual wage is lower — usually $18-35 per hour — with the billing rate covering wages, burden costs, overhead, and profit."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate a billing rate for pest control?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Add the technician's annual salary plus overhead costs per technician (vehicle, insurance, equipment, training), divide by annual billable hours (typically 1,500-1,800), then multiply by your target profit margin. Formula: Hourly_Rate = (Salary + Overhead) / Billable_Hours x (1 + Margin)."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="labor-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="salary">Annual Technician Salary ($)</label>
        <input type="number" id="salary" value="45000" min="0" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="burdenPct">Burden Rate (%)</label>
        <input type="number" id="burdenPct" value="30" min="0" max="100" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Payroll taxes, workers comp, benefits (typically 25-35%)</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="overheadPerTech">Annual Overhead per Tech ($)</label>
        <input type="number" id="overheadPerTech" value="18000" min="0" step="500" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Vehicle, fuel, insurance, equipment, training, licensing</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="billableHours">Annual Billable Hours</label>
        <input type="number" id="billableHours" value="1600" min="500" max="2500" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Typical range: 1,500-1,800 hours/year</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="marginTarget">Target Profit Margin (%)</label>
        <input type="number" id="marginTarget" value="20" min="0" max="80" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Recommended Billing Rate</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Billing Rate</div>
          <div id="result-rate" class="font-heading font-extrabold text-3xl text-accent">--</div>
          <div class="text-text-muted text-xs mt-1">per hour</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost per Hour</div>
          <div id="result-cost" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Burdened Wage</div>
          <div id="result-burdened" class="font-heading font-extrabold text-xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">per hour</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Revenue Goal</div>
          <div id="result-annual" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Industry Range</div>
        <div class="text-text-secondary text-sm">Pest control billing rates typically range from <strong class="text-text-primary">$65-$120/hr</strong> depending on region, service type, and experience. Fumigation and termite work commands higher rates than general pest service.</div>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the technician's annual salary.</strong> This is the base wage before taxes, benefits, and overhead. A typical pest control technician earns $35,000-$55,000 depending on region and experience.</p>
          <p><strong class="text-text-primary">2. Set the burden rate.</strong> This percentage covers payroll taxes, workers comp insurance, health benefits, and paid time off. Most companies run 25-35% burden on top of base wages.</p>
          <p><strong class="text-text-primary">3. Enter overhead per technician.</strong> This includes the vehicle payment, fuel, insurance, equipment, uniforms, training, and licensing costs allocated to each tech.</p>
          <p><strong class="text-text-primary">4. Set billable hours and margin target.</strong> Billable hours are actual revenue-generating hours on customer sites, not total work hours. Most pest control techs bill 1,500-1,800 hours per year after drive time, training, and admin.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Formula Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Burdened_Salary = Annual_Salary x (1 + Burden_Rate%)</p>
            <p>Total_Annual_Cost = Burdened_Salary + Overhead_Per_Tech</p>
            <p>Cost_Per_Hour = Total_Annual_Cost / Billable_Hours</p>
            <p>Billing_Rate = Cost_Per_Hour x (1 + Margin_Target%)</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is the average hourly rate for pest control technicians?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Pest control technician billing rates typically range from $65 to $120 per hour depending on region, service type, and experience level. The technician's actual wage is lower — usually $18-35 per hour — with the billing rate covering wages, burden costs, overhead, and profit.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate a billing rate for pest control?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Add the technician's annual salary plus overhead costs per technician (vehicle, insurance, equipment, training), divide by annual billable hours (typically 1,500-1,800), then multiply by your target profit margin. Formula: Hourly_Rate = (Salary + Overhead) / Billable_Hours x (1 + Margin).</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const salary = parseFloat((document.getElementById('salary') as HTMLInputElement).value) || 0;
    const burdenPct = parseFloat((document.getElementById('burdenPct') as HTMLInputElement).value) || 0;
    const overheadPerTech = parseFloat((document.getElementById('overheadPerTech') as HTMLInputElement).value) || 0;
    const billableHours = parseFloat((document.getElementById('billableHours') as HTMLInputElement).value) || 1;
    const marginTarget = parseFloat((document.getElementById('marginTarget') as HTMLInputElement).value) || 0;

    const burdenedSalary = salary * (1 + burdenPct / 100);
    const totalAnnualCost = burdenedSalary + overheadPerTech;
    const costPerHour = totalAnnualCost / billableHours;
    const billingRate = costPerHour * (1 + marginTarget / 100);
    const annualRevenue = billingRate * billableHours;

    document.getElementById('result-rate')!.textContent = '$' + billingRate.toFixed(0);
    document.getElementById('result-cost')!.textContent = '$' + costPerHour.toFixed(0);
    document.getElementById('result-burdened')!.textContent = '$' + (burdenedSalary / billableHours).toFixed(0);
    document.getElementById('result-annual')!.textContent = '$' + Math.round(annualRevenue).toLocaleString();
  }

  document.querySelectorAll('#labor-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
