---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/pestControlTools';

const tool = getToolBySlug('bait-spacing-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How far apart should termite bait stations be?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Industry standard spacing for termite bait stations is 10 linear feet apart around the building perimeter. Some systems allow 8-15 foot spacing depending on soil type, termite pressure, and manufacturer guidelines. Tighter spacing (8 ft) is recommended in high-pressure areas."
      }
    },
    {
      "@type": "Question",
      "name": "How many bait stations do I need?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Divide the building perimeter in linear feet by the station spacing (typically 10 feet). A home with a 200-foot perimeter needs approximately 20 perimeter stations. Add interior stations at roughly 1 per 1,000 square feet of floor area for comprehensive monitoring."
      }
    },
    {
      "@type": "Question",
      "name": "How far apart should rodent bait stations be?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For mice, place exterior bait stations every 15 feet. For rats, space stations every 25 feet. Interior stations for mice should be every 8-12 feet in areas of activity. These spacings ensure rodents encounter a station within their normal travel range."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="bait-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="perimeter">Building Perimeter (linear feet)</label>
        <input type="number" id="perimeter" value="200" min="10" max="5000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="pestType">Pest Type</label>
        <select id="pestType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="10" selected>Termite (10 ft spacing)</option>
          <option value="15">Mouse (15 ft spacing)</option>
          <option value="25">Rat (25 ft spacing)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customSpacing">Custom Spacing Override (ft)</label>
        <input type="number" id="customSpacing" value="" min="3" max="50" placeholder="Leave blank for default" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="interiorSqft">Interior Area (sq ft) — for interior stations</label>
        <input type="number" id="interiorSqft" value="0" min="0" max="100000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">1 station per 1,000 sq ft. Enter 0 for perimeter only.</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="costPerStation">Cost per Station ($)</label>
        <input type="number" id="costPerStation" value="25" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Stations</div>
          <div id="result-total" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Perimeter Stations</div>
          <div id="result-perimeter" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Interior Stations</div>
          <div id="result-interior" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Est. Material Cost</div>
          <div id="result-cost" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Station Spacing</div>
        <div id="result-spacing" class="text-text-secondary text-sm">--</div>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the building perimeter.</strong> Measure the total linear footage around the foundation using a measuring wheel or property survey.</p>
          <p><strong class="text-text-primary">2. Select the pest type.</strong> This sets the default spacing: 10 ft for termites, 15 ft for mice, 25 ft for rats. Use the custom override for non-standard spacing.</p>
          <p><strong class="text-text-primary">3. Add interior area if needed.</strong> For comprehensive monitoring, add interior stations at roughly 1 per 1,000 square feet of floor area.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How far apart should termite bait stations be?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Industry standard spacing for termite bait stations is 10 linear feet apart around the building perimeter. Some systems allow 8-15 foot spacing depending on soil type, termite pressure, and manufacturer guidelines. Tighter spacing (8 ft) is recommended in high-pressure areas.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many bait stations do I need?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Divide the building perimeter in linear feet by the station spacing (typically 10 feet). A home with a 200-foot perimeter needs approximately 20 perimeter stations. Add interior stations at roughly 1 per 1,000 square feet of floor area for comprehensive monitoring.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How far apart should rodent bait stations be?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For mice, place exterior bait stations every 15 feet. For rats, space stations every 25 feet. Interior stations for mice should be every 8-12 feet in areas of activity. These spacings ensure rodents encounter a station within their normal travel range.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const perimeter = parseFloat((document.getElementById('perimeter') as HTMLInputElement).value) || 0;
    const pestType = parseFloat((document.getElementById('pestType') as HTMLSelectElement).value);
    const customSpacingVal = (document.getElementById('customSpacing') as HTMLInputElement).value;
    const interiorSqft = parseFloat((document.getElementById('interiorSqft') as HTMLInputElement).value) || 0;
    const costPerStation = parseFloat((document.getElementById('costPerStation') as HTMLInputElement).value) || 0;

    const spacing = customSpacingVal ? parseFloat(customSpacingVal) : pestType;
    const perimeterStations = Math.ceil(perimeter / spacing);
    const interiorStations = Math.ceil(interiorSqft / 1000);
    const totalStations = perimeterStations + interiorStations;
    const cost = totalStations * costPerStation;

    document.getElementById('result-total')!.textContent = totalStations.toString();
    document.getElementById('result-perimeter')!.textContent = perimeterStations.toString();
    document.getElementById('result-interior')!.textContent = interiorStations.toString();
    document.getElementById('result-cost')!.textContent = '$' + cost.toLocaleString();

    // Generate spacing description
    const positions: string[] = [];
    for (let i = 0; i < perimeterStations && i < 30; i++) {
      positions.push(Math.round(i * spacing) + ' ft');
    }
    const spacingText = perimeterStations > 30
      ? `Stations at every ${spacing} ft around the perimeter (${perimeterStations} positions)`
      : `Stations at: ${positions.join(', ')}`;
    document.getElementById('result-spacing')!.textContent = spacingText;
  }

  document.querySelectorAll('#bait-calc input, #bait-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
