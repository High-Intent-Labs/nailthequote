---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/pestControlTools';

const tool = getToolBySlug('coverage-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many gallons of spray do I need per square foot?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most common rate for perimeter spray is 1 gallon per 10 square feet (0.1 gal/sqft). Spot treatments use about 1 gallon per 25 square feet (0.04 gal/sqft). Heavy infestations may require 1 gallon per 5 square feet (0.2 gal/sqft). Always check the product label for specific coverage rates."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate spray coverage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Multiply the total square footage to be treated by the coverage rate in gallons per square foot. For example, 2,000 sq ft of perimeter at 0.1 gal/sqft = 200 gallons of finished spray solution needed."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="cov-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sqft">Square Footage to Treat</label>
        <input type="number" id="sqft" value="2000" min="1" max="100000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="treatType">Treatment Type</label>
        <select id="treatType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="0.1" selected>Perimeter Spray (1 gal / 10 sqft)</option>
          <option value="0.1">Under-Slab Pre-treatment (1 gal / 10 sqft)</option>
          <option value="0.15">Bed Bug Treatment (1 gal / 7 sqft)</option>
          <option value="0.04">Spot Treatment — Interior (1 gal / 25 sqft)</option>
          <option value="0.2">Heavy Infestation (1 gal / 5 sqft)</option>
          <option value="custom">Custom Rate</option>
        </select>
      </div>
      <div id="custom-rate-wrap" class="hidden">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customRate">Custom Rate (gal per sqft)</label>
        <input type="number" id="customRate" value="0.1" min="0.01" max="1" step="0.01" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="costGal">Cost per Gallon ($)</label>
        <input type="number" id="costGal" value="3" min="0" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Gallons</div>
          <div id="result-gallons" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">5-Gallon Buckets</div>
          <div id="result-buckets" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Coverage Rate</div>
          <div id="result-rate" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Est. Cost</div>
          <div id="result-cost" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
      </div>
      <p class="text-text-muted text-sm italic">Coverage rates are industry typical ranges. Always verify against the product label for your specific treatment.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the total square footage.</strong> Measure the area to be treated. For perimeter spray, calculate the band width times the perimeter length.</p>
          <p><strong class="text-text-primary">2. Select the treatment type.</strong> Each option pre-fills the typical coverage rate for that application. Choose "Custom Rate" to enter your own.</p>
          <p><strong class="text-text-primary">3. Enter cost per gallon.</strong> This gives you an estimated material cost for the job.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Coverage Formula Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm">
            <p>Gallons_Needed = Square_Footage x Coverage_Rate_Gal_Per_Sqft</p>
          </div>
          <p>The most common rate is 1 gallon per 10 square feet (0.1 gal/sqft) for standard perimeter and soil treatments. Spot treatments use less product per area, while heavy infestations require more.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many gallons of spray do I need per square foot?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The most common rate for perimeter spray is 1 gallon per 10 square feet (0.1 gal/sqft). Spot treatments use about 1 gallon per 25 square feet (0.04 gal/sqft). Heavy infestations may require 1 gallon per 5 square feet (0.2 gal/sqft). Always check the product label for specific coverage rates.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate spray coverage?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Multiply the total square footage to be treated by the coverage rate in gallons per square foot. For example, 2,000 sq ft of perimeter at 0.1 gal/sqft = 200 gallons of finished spray solution needed.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const sqft = parseFloat((document.getElementById('sqft') as HTMLInputElement).value) || 0;
    const treatType = (document.getElementById('treatType') as HTMLSelectElement).value;
    const customRate = parseFloat((document.getElementById('customRate') as HTMLInputElement).value) || 0.1;
    const costGal = parseFloat((document.getElementById('costGal') as HTMLInputElement).value) || 0;

    document.getElementById('custom-rate-wrap')!.classList.toggle('hidden', treatType !== 'custom');

    const rate = treatType === 'custom' ? customRate : parseFloat(treatType);
    const totalGallons = Math.round(sqft * rate);
    const buckets = Math.ceil(totalGallons / 5);
    const cost = totalGallons * costGal;

    const rateLabel = rate >= 0.1 ? `1 gal / ${Math.round(1/rate)} sqft` : `1 gal / ${Math.round(1/rate)} sqft`;

    document.getElementById('result-gallons')!.textContent = totalGallons.toLocaleString();
    document.getElementById('result-buckets')!.textContent = buckets.toString();
    document.getElementById('result-rate')!.textContent = rateLabel;
    document.getElementById('result-cost')!.textContent = '$' + cost.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  document.querySelectorAll('#cov-calc input, #cov-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
