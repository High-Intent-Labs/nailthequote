---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/gcTools';

const tool = getToolBySlug('excavation-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I calculate cubic yards for excavation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Multiply length (ft) x width (ft) x depth (ft) to get cubic feet, then divide by 27 to convert to cubic yards. For a trench that is 30 feet long, 3 feet wide, and 4 feet deep: 30 x 3 x 4 = 360 cubic feet / 27 = 13.3 cubic yards."
      }
    },
    {
      "@type": "Question",
      "name": "How many tons is a cubic yard of dirt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Loose topsoil weighs approximately 1.3-1.4 tons per cubic yard. Clay is heavier at 1.5-1.8 tons per cubic yard. Rock is approximately 1.5 tons per cubic yard. These weights matter for disposal trucking costs, as dump trucks have weight limits."
      }
    },
    {
      "@type": "Question",
      "name": "How much does excavation cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Excavation costs depend on the material, depth, and access. Typical equipment rates are $75-95/hour for a mini excavator and $85-125/hour for a standard excavator. Disposal costs run $15-50 per cubic yard depending on the material and local dump fees. Total cost per cubic yard ranges from $25-75 for simple digs."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="exc-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="excShape">Excavation Shape</label>
        <select id="excShape" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="rectangular" selected>Rectangular</option>
          <option value="sloped">Sloped Sides (trapezoidal)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="material">Material Type</label>
        <select id="material" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1.35" selected>Soil (loose topsoil)</option>
          <option value="1.65">Clay</option>
          <option value="1.50">Rock (excavated)</option>
          <option value="0.60">Mulch / Organic</option>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="excLength">Length (ft)</label>
        <input type="number" id="excLength" value="30" min="1" max="1000" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="excWidth">Width (ft)</label>
        <input type="number" id="excWidth" value="20" min="1" max="1000" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="excDepth">Depth (ft)</label>
        <input type="number" id="excDepth" value="3" min="0.5" max="50" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equipRate">Equipment Rate ($/hr)</label>
        <input type="number" id="equipRate" value="95" min="0" max="500" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="disposalRate">Disposal Cost ($/CY)</label>
        <input type="number" id="disposalRate" value="25" min="0" max="100" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cubic Yards</div>
          <div id="result-cy" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Weight (tons)</div>
          <div id="result-tons" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Equipment Hours</div>
          <div id="result-hours" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Estimated Cost</div>
          <div id="result-cost" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Cost Breakdown</h4>
        <div id="cost-breakdown" class="text-text-secondary text-sm space-y-2"></div>
      </div>

      <p class="text-text-muted text-sm italic">Equipment productivity assumes a standard excavator at ~8-12 CY/hour. Actual rates vary by machine size, operator skill, and soil conditions.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select excavation shape.</strong> Rectangular for straight-sided digs. Sloped for cuts that need a safety angle (adds volume for 1:1 side slopes).</p>
          <p><strong class="text-text-primary">2. Enter dimensions and material type.</strong> Material type affects weight calculations for trucking and disposal.</p>
          <p><strong class="text-text-primary">3. Set equipment and disposal rates.</strong> Use local rates for accurate cost estimates.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Formula Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Rectangular: CY = (L x W x D) / 27</p>
            <p>Sloped: Top = Bottom + (2 x Depth)</p>
            <p>Avg = (Bottom + Top) / 2</p>
            <p>CY = (Avg_L x Avg_W x D) / 27</p>
          </div>
          <p>For sloped excavations, the calculator adds 1:1 slopes (45 degrees) to all four sides, which is the OSHA minimum for Type C soil. The top dimensions are larger than the bottom, creating a trapezoidal cross-section.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate cubic yards for excavation?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Multiply length x width x depth in feet, then divide by 27 to get cubic yards.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many tons is a cubic yard of dirt?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Loose topsoil weighs approximately 1.3-1.4 tons per cubic yard. Clay is heavier at 1.5-1.8 tons. Rock is approximately 1.5 tons per cubic yard.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does excavation cost?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Equipment rates run $75-125/hour. Disposal costs $15-50 per cubic yard. Total cost per cubic yard ranges from $25-75 depending on conditions.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const shape = (document.getElementById('excShape') as HTMLSelectElement).value;
    const density = parseFloat((document.getElementById('material') as HTMLSelectElement).value);
    const length = parseFloat((document.getElementById('excLength') as HTMLInputElement).value) || 0;
    const width = parseFloat((document.getElementById('excWidth') as HTMLInputElement).value) || 0;
    const depth = parseFloat((document.getElementById('excDepth') as HTMLInputElement).value) || 0;
    const equipRate = parseFloat((document.getElementById('equipRate') as HTMLInputElement).value) || 0;
    const disposalRate = parseFloat((document.getElementById('disposalRate') as HTMLInputElement).value) || 0;

    let cubicYards: number;
    if (shape === 'sloped') {
      const topL = length + 2 * depth;
      const topW = width + 2 * depth;
      const avgL = (length + topL) / 2;
      const avgW = (width + topW) / 2;
      cubicYards = (avgL * avgW * depth) / 27;
    } else {
      cubicYards = (length * width * depth) / 27;
    }

    const tons = cubicYards * density;
    const equipHours = cubicYards / 10;
    const equipCost = equipHours * equipRate;
    const disposalCost = cubicYards * disposalRate;
    const totalCost = equipCost + disposalCost;

    document.getElementById('result-cy')!.textContent = cubicYards.toFixed(1);
    document.getElementById('result-tons')!.textContent = tons.toFixed(1);
    document.getElementById('result-hours')!.textContent = equipHours.toFixed(1);
    document.getElementById('result-cost')!.textContent = '$' + totalCost.toLocaleString(undefined, { maximumFractionDigits: 0 });

    document.getElementById('cost-breakdown')!.innerHTML = `
      <div class="flex justify-between"><span>Equipment (${equipHours.toFixed(1)} hrs x $${equipRate}/hr)</span><span class="text-text-primary font-medium">$${equipCost.toLocaleString(undefined, { maximumFractionDigits: 0 })}</span></div>
      <div class="flex justify-between"><span>Disposal (${cubicYards.toFixed(1)} CY x $${disposalRate}/CY)</span><span class="text-text-primary font-medium">$${disposalCost.toLocaleString(undefined, { maximumFractionDigits: 0 })}</span></div>
      <div class="border-t border-border mt-3 pt-3 flex justify-between font-medium"><span>Total Estimated Cost</span><span class="text-accent">$${totalCost.toLocaleString(undefined, { maximumFractionDigits: 0 })}</span></div>
    `;
  }

  document.querySelectorAll('#exc-calc input, #exc-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
