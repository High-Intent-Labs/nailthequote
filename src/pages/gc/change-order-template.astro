---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/gcTools';

const tool = getToolBySlug('change-order-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should be on a construction change order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A complete construction change order includes the original contract reference, a clear description of the scope change, itemized cost breakdown (materials, labor, subcontractors, markup), schedule impact in working days, required approvals, and signatures from both contractor and client with the date of authorization."
      }
    },
    {
      "@type": "Question",
      "name": "Why do I need detailed cost breakdowns on change orders?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Detailed cost breakdowns document the financial impact of every change. Itemize materials, labor hours, equipment rental, and subcontractor costs separately. This transparency builds client trust, prevents disputes about markup, and creates accurate records for job costing and future project estimating."
      }
    },
    {
      "@type": "Question",
      "name": "Is material tracking required on change orders?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Detailed material tracking on change orders protects both contractor and client. Document every material added, quantities used, and unit costs. Keep receipts and delivery tickets for verification. This creates an audit trail for disputes and helps with accurate job costing on future projects."
      }
    },
    {
      "@type": "Question",
      "name": "How should I handle client-requested upgrades?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Client-requested upgrades should always go through the change order process even if they seem minor. Document the upgrade, cost difference, and any schedule impact. Get the client's signature before ordering materials or starting work. This protects both parties and ensures the project budget stays accurate."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="work-order-form">

    <!-- Section: Change Order Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Change Order Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-number">Change Order #</label>
        <input type="text" id="wo-number" value="CO-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-date">Date</label>
        <input type="date" id="wo-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="contract-ref">Original Contract #</label>
        <input type="text" id="contract-ref" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="pm-name">Project Manager</label>
        <input type="text" id="pm-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="project-name">Project Name</label>
        <input type="text" id="project-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="priority">Priority</label>
        <select id="priority" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Routine" selected>Routine</option>
          <option value="Urgent">Urgent</option>
          <option value="Emergency">Emergency</option>
        </select>
      </div>
    </div>

    <!-- Section: Client Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Client Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-name">Client Name</label>
        <input type="text" id="cust-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-address">Project Address</label>
        <input type="text" id="cust-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-phone">Phone</label>
        <input type="text" id="cust-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-email">Email</label>
        <input type="email" id="cust-email" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Project Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Project Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="project-type">Project Type</label>
        <select id="project-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="New Build">New Build</option>
          <option value="Addition" selected>Addition</option>
          <option value="Remodel">Remodel</option>
          <option value="Renovation">Renovation</option>
          <option value="Restoration">Restoration</option>
          <option value="Tenant Improvement">Tenant Improvement</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="original-value">Original Contract Value ($)</label>
        <input type="number" id="original-value" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="original-completion">Original Completion Date</label>
        <input type="date" id="original-completion" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Change Description -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Change Description</h3>
    <div class="space-y-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="change-reason">Reason for Change</label>
        <select id="change-reason" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Client Request" selected>Client Request</option>
          <option value="Unforeseen Condition">Unforeseen Condition</option>
          <option value="Design Change">Design Change</option>
          <option value="Code Requirement">Code Requirement</option>
          <option value="Material Substitution">Material Substitution</option>
          <option value="Scope Clarification">Scope Clarification</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="change-description">Description of Change</label>
        <textarea id="change-description" rows="4" placeholder="Describe the scope change in detail..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="justification">Justification / Impact if Not Approved</label>
        <textarea id="justification" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <!-- Section: Cost Breakdown -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Cost Breakdown</h3>
    <div class="mb-8">
      <div id="cost-table" class="space-y-3">
        <div class="grid grid-cols-[1fr_120px_100px_120px_40px] gap-3 items-end cost-row">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Item Description</label>
            <input type="text" class="item-desc w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Category</label>
            <select class="item-category w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors">
              <option value="Material">Material</option>
              <option value="Labor">Labor</option>
              <option value="Subcontractor">Sub</option>
              <option value="Equipment">Equipment</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Qty</label>
            <input type="number" value="1" min="1" class="item-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Unit Cost ($)</label>
            <input type="number" min="0" step="0.01" class="item-cost w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">&nbsp;</label>
            <button type="button" class="remove-cost-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove item">&times;</button>
          </div>
        </div>
      </div>
      <button type="button" id="add-cost-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Line Item</button>

      <!-- Markup and totals -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2" for="markup-pct">Markup / OH&amp;P (%)</label>
          <input type="number" id="markup-pct" value="15" min="0" max="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2">Subtotal</label>
          <div id="subtotal-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2">Total with Markup</label>
          <div id="total-display" class="w-full bg-bg-dark border border-accent/50 rounded-lg px-4 py-3 text-lg font-bold text-accent">&mdash;</div>
        </div>
      </div>
    </div>

    <!-- Section: Schedule Impact -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Schedule Impact</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="days-added">Working Days Added</label>
        <input type="number" id="days-added" min="0" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="new-completion">Revised Completion Date</label>
        <input type="date" id="new-completion" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="schedule-notes">Schedule Notes</label>
        <textarea id="schedule-notes" rows="2" placeholder="Which milestones are affected, lead time for materials, etc." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <!-- Section: Authorization -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Authorization</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="contractor-sig">Contractor Name / Signature</label>
        <input type="text" id="contractor-sig" placeholder="Type full name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="client-sig">Client Name / Signature</label>
        <input type="text" id="client-sig" placeholder="Type full name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Generate Button -->
    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
      Generate Change Order &rarr;
    </button>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in the change order and client info.</strong> Start with the change order number, date, and original contract reference. Add the client's name, project address, and contact details. The original contract reference ties this change back to the base scope.</p>
          <p><strong class="text-text-primary">2. Describe the change.</strong> Select the reason for the change and write a detailed description of what is being added, removed, or modified. Be specific — vague change orders lead to disputes when the client's memory of the conversation differs from yours.</p>
          <p><strong class="text-text-primary">3. Break down the costs.</strong> Add line items for every material, labor hour, subcontractor charge, and equipment rental. Set your markup percentage. Transparent, itemized pricing prevents arguments about what the client is paying for.</p>
          <p><strong class="text-text-primary">4. Document the schedule impact.</strong> State how many working days this change adds and which milestones are affected. If materials have lead times, note them here. Schedule documentation prevents disputes about completion dates.</p>
          <p><strong class="text-text-primary">5. Get signatures before starting work.</strong> Both contractor and client must sign before any change order work begins. This single practice prevents more disputes than any other documentation habit in construction.</p>
        </div>
      </section>

      <!-- What Goes on a Change Order -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Goes on a Construction Change Order</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A change order is the document that authorizes modifications to the original project scope. Every section exists for a reason.</p>
          <p><strong class="text-text-primary">Original scope reference</strong> ties the change back to the original contract. Include the contract number, original scope item being modified, and the reason for the change. Without this context, disputes become impossible to resolve.</p>
          <p><strong class="text-text-primary">Cost breakdown</strong> documents the financial impact of the change. Itemize materials, labor hours, subcontractor costs, and any schedule adjustments. Detailed breakdowns prevent disputes and help with accurate job costing.</p>
          <p><strong class="text-text-primary">Material tracking</strong> protects both contractor and client. Document every material added, quantities used, and unit costs. Keep receipts and delivery tickets for verification and audit trails.</p>
          <p><strong class="text-text-primary">Schedule impact</strong> must be clearly stated. How many days does this add to the timeline? What milestones are affected? Documenting schedule impact upfront prevents arguments about completion dates.</p>
          <p><strong class="text-text-primary">Dual signatures</strong> from both contractor and client with dates create binding authorization. No work should begin on a change until both parties sign. This single step prevents more disputes than any other documentation practice.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Scope additions.</strong> When a client wants to add rooms, upgrade finishes, or include work not in the original contract, a change order documents exactly what is being added, the cost, and the timeline impact before work begins.</p>
          <p><strong class="text-text-primary">Unforeseen conditions.</strong> Hidden damage, soil issues, structural problems, or code requirements discovered during construction often require scope changes. A change order documents the discovery, the required fix, and the cost so the client understands why the project budget is changing.</p>
          <p><strong class="text-text-primary">Material substitutions.</strong> When specified materials are unavailable or a client wants to upgrade or downgrade selections, a change order records the substitution, any cost difference, and whether it affects the schedule or warranty coverage.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should be on a construction change order?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete construction change order includes the original contract reference, a clear description of the scope change, itemized cost breakdown (materials, labor, subcontractors, markup), schedule impact in working days, required approvals, and signatures from both contractor and client with the date of authorization.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why do I need detailed cost breakdowns?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Detailed cost breakdowns document the financial impact of every change. Itemize materials, labor hours, equipment rental, and subcontractor costs separately. This transparency builds client trust, prevents disputes about markup, and creates accurate records for job costing and future project estimating.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is material tracking required on change orders?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Detailed material tracking on change orders protects both contractor and client. Document every material added, quantities used, and unit costs. Keep receipts and delivery tickets for verification. This creates an audit trail for disputes and helps with accurate job costing on future projects.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How should I handle client-requested upgrades?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Client-requested upgrades should always go through the change order process even if they seem minor. Document the upgrade, cost difference, and any schedule impact. Get the client's signature before ordering materials or starting work. This protects both parties and ensures the project budget stays accurate.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // --- Default date ---
  const now = new Date();
  const dateInput = document.getElementById('wo-date') as HTMLInputElement;
  if (dateInput && !dateInput.value) {
    dateInput.value = now.toISOString().slice(0, 10);
  }

  // --- Dynamic Cost Table ---
  function addCostRow() {
    const table = document.getElementById('cost-table')!;
    const row = document.createElement('div');
    row.className = 'grid grid-cols-[1fr_120px_100px_120px_40px] gap-3 items-end cost-row';
    row.innerHTML = `
      <div>
        <input type="text" class="item-desc w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <select class="item-category w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors">
          <option value="Material">Material</option>
          <option value="Labor">Labor</option>
          <option value="Subcontractor">Sub</option>
          <option value="Equipment">Equipment</option>
        </select>
      </div>
      <div>
        <input type="number" value="1" min="1" class="item-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <input type="number" min="0" step="0.01" class="item-cost w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <button type="button" class="remove-cost-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove item">&times;</button>
      </div>
    `;
    table.appendChild(row);
    updateTotals();
  }

  document.getElementById('add-cost-btn')?.addEventListener('click', addCostRow);

  document.getElementById('cost-table')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('remove-cost-btn')) {
      const row = target.closest('.cost-row');
      const allRows = document.querySelectorAll('.cost-row');
      if (allRows.length > 1 && row) {
        row.remove();
        updateTotals();
      }
    }
  });

  // --- Totals calculation ---
  function updateTotals() {
    const rows = document.querySelectorAll('.cost-row');
    let subtotal = 0;
    rows.forEach(row => {
      const qty = parseFloat((row.querySelector('.item-qty') as HTMLInputElement)?.value) || 0;
      const cost = parseFloat((row.querySelector('.item-cost') as HTMLInputElement)?.value) || 0;
      subtotal += qty * cost;
    });

    const markup = parseFloat((document.getElementById('markup-pct') as HTMLInputElement)?.value) || 0;
    const total = subtotal * (1 + markup / 100);

    const fmt = (n: number) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    document.getElementById('subtotal-display')!.textContent = fmt(subtotal);
    document.getElementById('total-display')!.textContent = fmt(total);
  }

  // Listen for input changes in the cost table
  document.getElementById('cost-table')?.addEventListener('input', updateTotals);
  document.getElementById('markup-pct')?.addEventListener('input', updateTotals);

  // --- Generate Change Order ---
  function getVal(id: string): string {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
    return el ? el.value : '';
  }

  function generateChangeOrder() {
    // Collect cost items
    const costRows = document.querySelectorAll('.cost-row');
    let itemsHtml = '';
    let subtotal = 0;
    costRows.forEach(row => {
      const desc = (row.querySelector('.item-desc') as HTMLInputElement)?.value || '';
      const category = (row.querySelector('.item-category') as HTMLSelectElement)?.value || '';
      const qty = parseFloat((row.querySelector('.item-qty') as HTMLInputElement)?.value) || 0;
      const cost = parseFloat((row.querySelector('.item-cost') as HTMLInputElement)?.value) || 0;
      const lineTotal = qty * cost;
      subtotal += lineTotal;
      if (desc || cost) {
        itemsHtml += `<tr><td style="border:1px solid #ddd;padding:6px 10px;">${desc}</td><td style="border:1px solid #ddd;padding:6px 10px;">${category}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:center;">${qty}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:right;">$${cost.toFixed(2)}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:right;">$${lineTotal.toFixed(2)}</td></tr>`;
      }
    });

    const markup = parseFloat(getVal('markup-pct')) || 0;
    const markupAmount = subtotal * (markup / 100);
    const total = subtotal + markupAmount;
    const fmt2 = (n: number) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Change Order ${getVal('wo-number')}</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color:#1a1a1a; padding:40px; max-width:850px; margin:0 auto; font-size:14px; line-height:1.5; }
  h1 { font-size:22px; margin-bottom:4px; }
  h2 { font-size:15px; color:#333; margin:20px 0 8px; padding-bottom:4px; border-bottom:2px solid #e5e5e5; text-transform:uppercase; letter-spacing:0.5px; }
  .header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:20px; padding-bottom:16px; border-bottom:3px solid #1a1a1a; }
  .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:4px 24px; margin-bottom:6px; }
  .grid2 .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; }
  .grid2 .value { font-size:14px; margin-bottom:6px; }
  .text-block { margin-bottom:12px; }
  .text-block .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; margin-bottom:2px; }
  .text-block .value { font-size:14px; white-space:pre-wrap; background:#f9f9f9; padding:8px 10px; border-radius:4px; min-height:24px; }
  table { width:100%; border-collapse:collapse; margin-bottom:8px; }
  th { background:#f0f0f0; border:1px solid #ddd; padding:6px 10px; text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:0.3px; }
  td { border:1px solid #ddd; padding:6px 10px; }
  .totals-row { font-weight:700; }
  .signature-block { display:grid; grid-template-columns:1fr 1fr; gap:40px; margin-top:40px; padding-top:16px; }
  .sig-line { border-top:1px solid #1a1a1a; padding-top:6px; font-size:12px; color:#666; text-transform:uppercase; }
  .sig-name { font-size:16px; font-weight:600; min-height:20px; }
  .priority-badge { display:inline-block; padding:2px 10px; border-radius:4px; font-size:12px; font-weight:600; text-transform:uppercase; }
  .priority-Routine { background:#e0f2e9; color:#166534; }
  .priority-Urgent { background:#fef3c7; color:#92400e; }
  .priority-Emergency { background:#fee2e2; color:#991b1b; }
  @media print { body { padding:20px; } }
</style>
</head><body>
<div class="header">
  <div>
    <h1>Construction Change Order</h1>
    <div style="font-size:13px;color:#555;">Project: ${getVal('project-name') || '\u2014'}</div>
  </div>
  <div style="text-align:right;">
    <div style="font-size:20px;font-weight:700;">${getVal('wo-number')}</div>
    <div>${getVal('wo-date')}</div>
    <span class="priority-badge priority-${getVal('priority')}">${getVal('priority')}</span>
  </div>
</div>

<h2>Project Info</h2>
<div class="grid2">
  <div><span class="label">Client:</span></div><div><span class="label">Project Address:</span></div>
  <div class="value">${getVal('cust-name') || '\u2014'}</div><div class="value">${getVal('cust-address') || '\u2014'}</div>
  <div><span class="label">Original Contract #:</span></div><div><span class="label">Project Type:</span></div>
  <div class="value">${getVal('contract-ref') || '\u2014'}</div><div class="value">${getVal('project-type')}</div>
  <div><span class="label">Original Contract Value:</span></div><div><span class="label">Original Completion:</span></div>
  <div class="value">${getVal('original-value') ? '$' + parseInt(getVal('original-value')).toLocaleString() : '\u2014'}</div><div class="value">${getVal('original-completion') || '\u2014'}</div>
</div>

<h2>Change Description</h2>
<div class="text-block"><div class="label">Reason</div><div class="value">${getVal('change-reason')}</div></div>
<div class="text-block"><div class="label">Description of Change</div><div class="value">${getVal('change-description') || '\u2014'}</div></div>
<div class="text-block"><div class="label">Justification</div><div class="value">${getVal('justification') || '\u2014'}</div></div>

${itemsHtml ? `<h2>Cost Breakdown</h2>
<table><thead><tr><th>Description</th><th>Category</th><th style="text-align:center;">Qty</th><th style="text-align:right;">Unit Cost</th><th style="text-align:right;">Line Total</th></tr></thead><tbody>${itemsHtml}
<tr class="totals-row"><td colspan="4" style="border:1px solid #ddd;padding:6px 10px;text-align:right;">Subtotal</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:right;">${fmt2(subtotal)}</td></tr>
<tr class="totals-row"><td colspan="4" style="border:1px solid #ddd;padding:6px 10px;text-align:right;">Markup (${markup}%)</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:right;">${fmt2(markupAmount)}</td></tr>
<tr class="totals-row" style="font-size:16px;"><td colspan="4" style="border:2px solid #333;padding:8px 10px;text-align:right;">TOTAL</td><td style="border:2px solid #333;padding:8px 10px;text-align:right;">${fmt2(total)}</td></tr>
</tbody></table>` : ''}

<h2>Schedule Impact</h2>
<div class="grid2">
  <div><span class="label">Working Days Added:</span></div><div><span class="label">Revised Completion:</span></div>
  <div class="value">${getVal('days-added') || '0'} days</div><div class="value">${getVal('new-completion') || '\u2014'}</div>
</div>
${getVal('schedule-notes') ? `<div class="text-block"><div class="label">Schedule Notes</div><div class="value">${getVal('schedule-notes')}</div></div>` : ''}

<div class="signature-block">
  <div>
    <div class="sig-name">${getVal('contractor-sig') || ''}</div>
    <div class="sig-line">Contractor Signature &nbsp; &nbsp; Date: ___________</div>
  </div>
  <div>
    <div class="sig-name">${getVal('client-sig') || ''}</div>
    <div class="sig-line">Client Signature &nbsp; &nbsp; Date: ___________</div>
  </div>
</div>

<div style="margin-top:30px;padding-top:12px;border-top:1px solid #e5e5e5;font-size:11px;color:#999;text-align:center;">
  No work shall proceed on the above-described change until this document is signed by both parties.
</div>

</body></html>`;

    const printWindow = window.open('', '_blank');
    if (printWindow) {
      printWindow.document.write(html);
      printWindow.document.close();
    }
  }

  document.getElementById('generate-btn')?.addEventListener('click', generateChangeOrder);
</script>
