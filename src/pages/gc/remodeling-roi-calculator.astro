---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/gcTools';

const tool = getToolBySlug('remodeling-roi-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What remodeling projects have the best ROI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Garage door replacement, manufactured stone veneer, and minor kitchen remodels consistently deliver the highest ROI, often recovering 70-95% of cost at resale. Siding replacement and window upgrades also perform well. Major kitchen and bathroom remodels recover less percentage-wise (50-75%) but add more absolute dollar value. Decks and outdoor living spaces vary heavily by region."
      }
    },
    {
      "@type": "Question",
      "name": "How much does a kitchen remodel increase home value?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A minor kitchen remodel (cabinet refacing, new hardware, countertops, and appliances) costing $25,000-$40,000 typically recovers 70-80% at resale. A major kitchen remodel ($75,000-$150,000+) recovers 50-65%. The key insight for GCs is that mid-range projects with broad appeal recover the highest percentage. Ultra-high-end finishes in average neighborhoods recover the least."
      }
    },
    {
      "@type": "Question",
      "name": "Does a bathroom remodel add value to a home?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. A mid-range bathroom remodel costing $25,000-$40,000 typically recovers 60-70% at resale. A major upscale bathroom remodel recovers less percentage-wise but adds more absolute value. Adding a bathroom where there was none (e.g., finishing a half-bath or adding a bathroom to a basement) often has the highest ROI because it changes the functional bedroom/bath count of the home."
      }
    },
    {
      "@type": "Question",
      "name": "Should I use ROI data when selling remodeling projects?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. ROI data helps homeowners justify the investment and gives them confidence that the money is well spent. When you can show a homeowner that their $50,000 kitchen remodel is likely to add $35,000-$40,000 in home value, it reframes the project from a pure expense to a partial investment. Pair ROI data with lifestyle benefits for the most effective sales presentation."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="cost-calc">
    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="projectType">Project Type</label>
        <select id="projectType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="kitchen" selected>Kitchen Remodel</option>
          <option value="bathroom">Bathroom Remodel</option>
          <option value="basement">Basement Finish</option>
          <option value="deck">Deck Addition</option>
          <option value="addition">Room Addition</option>
          <option value="siding">Siding Replacement</option>
          <option value="windows">Window Replacement</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="projectCost">Project Cost ($)</label>
        <input type="number" id="projectCost" value="50000" min="5000" max="500000" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="homeValue">Current Home Value ($)</label>
        <input type="number" id="homeValue" value="350000" min="50000" max="5000000" step="10000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="scope">Project Scope</label>
        <select id="scope" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="minor">Minor (cosmetic refresh)</option>
          <option value="mid" selected>Mid-Range (standard remodel)</option>
          <option value="major">Major (high-end / structural)</option>
        </select>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">ROI Estimate</h3>

      <!-- Main ROI Display -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <div class="flex justify-between items-end mb-3">
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Project Cost</div>
            <div id="result-cost" class="font-heading font-extrabold text-xl text-text-secondary">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">ROI</div>
            <div id="result-roi" class="font-heading font-extrabold text-3xl text-accent">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Value Added</div>
            <div id="result-value" class="font-heading font-extrabold text-xl text-text-secondary">--</div>
          </div>
        </div>
        <div class="relative h-3 bg-bg-card rounded-full overflow-hidden mt-4">
          <div id="range-bar" class="absolute inset-y-0 left-[10%] right-[10%] rounded-full bg-gradient-to-r from-accent/40 via-accent to-accent/40"></div>
          <div id="range-marker" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-accent rounded-full border-2 border-white shadow-lg"></div>
        </div>
      </div>

      <!-- Detail Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost Recovered</div>
          <div id="result-recovered" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">at resale</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Net Cost to Owner</div>
          <div id="result-netcost" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">cost minus value added</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">New Home Value</div>
          <div id="result-newhome" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">estimated after remodel</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost as % of Home</div>
          <div id="result-percent" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">of current value</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">ROI ranges based on national cost-versus-value data. Actual returns vary by market, neighborhood, project quality, and timing of sale. Use this to set homeowner expectations, not as a guarantee of resale value.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the project type.</strong> Different remodeling categories have different typical ROI ranges. Kitchens and bathrooms are the most commonly referenced, but siding, windows, decks, and additions each have their own return profiles.</p>
          <p><strong class="text-text-primary">2. Enter the project cost.</strong> Use your actual bid or estimated project cost. The calculator applies ROI percentages based on the project type and scope to estimate how much of that cost translates to increased home value.</p>
          <p><strong class="text-text-primary">3. Enter the current home value.</strong> This provides context for the investment. A $50,000 kitchen remodel in a $200,000 home is a very different proposition than the same remodel in a $600,000 home. Projects that exceed 10-15% of home value tend to see diminishing ROI.</p>
          <p><strong class="text-text-primary">4. Choose the project scope.</strong> Minor cosmetic refreshes typically have the highest ROI percentage. Mid-range standard remodels are the sweet spot. Major high-end or structural projects recover less as a percentage but add more absolute value.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Affects Remodeling ROI</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Project type matters most.</strong> Curb appeal projects (garage doors, siding, stone veneer) consistently deliver the highest ROI because they affect every buyer's first impression. Kitchen and bath remodels add significant livability value. Luxury additions and niche projects (wine cellars, home theaters) appeal to fewer buyers and recover less.</p>
          <p><strong class="text-text-primary">Scope and finish level.</strong> Mid-range projects with broad market appeal consistently outperform ultra-high-end finishes. A $35,000 kitchen refresh with solid-surface counters and new appliances often recovers a higher percentage than a $120,000 chef's kitchen with custom everything. The sweet spot is quality finishes that appeal to the widest buyer pool in the neighborhood.</p>
          <p><strong class="text-text-primary">Neighborhood context.</strong> A remodel that is significantly above the neighborhood standard will not recover as well as one that brings a home in line with comparable properties. Advise homeowners to remodel to the top of the neighborhood range, not beyond it.</p>
          <p><strong class="text-text-primary">Market timing.</strong> In a hot seller's market, remodels recover more because buyers are competing for limited inventory. In a buyer's market, ROI drops because buyers have more options and less urgency. Long-term averages are more reliable for planning purposes.</p>
          <p><strong class="text-text-primary">Quality of work.</strong> This is where GCs can directly influence ROI. A well-executed remodel with attention to detail, proper permits, and warranty documentation recovers more at resale than cut-corner work. Your reputation and workmanship are part of the homeowner's return on investment.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Sales presentations.</strong> When a homeowner is weighing whether to pull the trigger on a remodel, showing them the ROI data helps justify the investment. Frame it as spending $50,000 and getting $35,000 back in equity, making the net cost of enjoying a new kitchen only $15,000. That reframe closes deals.</p>
          <p><strong class="text-text-primary">Scope discussions.</strong> When a homeowner is deciding between a minor refresh and a major overhaul, show them the ROI difference. Sometimes the minor version is the smarter financial move, and you build trust by recommending the option that serves their goals best rather than just selling the biggest project.</p>
          <p><strong class="text-text-primary">Marketing and content.</strong> Use ROI data in your website content, social media, and proposal materials. Homeowners who see you understand the investment side of remodeling perceive you as more professional and trustworthy than contractors who only talk about finishes and timelines.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What remodeling projects have the best ROI?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Garage door replacement, manufactured stone veneer, and minor kitchen remodels consistently deliver the highest ROI, often recovering 70-95% of cost at resale. Siding replacement and window upgrades also perform well. Major kitchen and bathroom remodels recover less percentage-wise (50-75%) but add more absolute dollar value. Decks and outdoor living spaces vary heavily by region.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does a kitchen remodel increase home value?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A minor kitchen remodel (cabinet refacing, new hardware, countertops, and appliances) costing $25,000-$40,000 typically recovers 70-80% at resale. A major kitchen remodel ($75,000-$150,000+) recovers 50-65%. The key insight for GCs is that mid-range projects with broad appeal recover the highest percentage. Ultra-high-end finishes in average neighborhoods recover the least.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Does a bathroom remodel add value to a home?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. A mid-range bathroom remodel costing $25,000-$40,000 typically recovers 60-70% at resale. A major upscale bathroom remodel recovers less percentage-wise but adds more absolute value. Adding a bathroom where there was none (e.g., finishing a half-bath or adding a bathroom to a basement) often has the highest ROI because it changes the functional bedroom/bath count of the home.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I use ROI data when selling remodeling projects?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Absolutely. ROI data helps homeowners justify the investment and gives them confidence that the money is well spent. When you can show a homeowner that their $50,000 kitchen remodel is likely to add $35,000-$40,000 in home value, it reframes the project from a pure expense to a partial investment. Pair ROI data with lifestyle benefits for the most effective sales presentation.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  interface ROIData {
    minor: { low: number; high: number };
    mid: { low: number; high: number };
    major: { low: number; high: number };
  }

  function calculate(): void {
    const projectType = (document.getElementById('projectType') as HTMLSelectElement).value;
    const projectCost = parseFloat((document.getElementById('projectCost') as HTMLInputElement).value) || 50000;
    const homeValue = parseFloat((document.getElementById('homeValue') as HTMLInputElement).value) || 350000;
    const scope = (document.getElementById('scope') as HTMLSelectElement).value;

    // ROI percentages by project type and scope (based on Cost vs Value data ranges)
    const roiData: Record<string, ROIData> = {
      kitchen: {
        minor: { low: 72, high: 85 },
        mid: { low: 57, high: 75 },
        major: { low: 45, high: 65 },
      },
      bathroom: {
        minor: { low: 65, high: 80 },
        mid: { low: 55, high: 70 },
        major: { low: 42, high: 60 },
      },
      basement: {
        minor: { low: 60, high: 75 },
        mid: { low: 50, high: 68 },
        major: { low: 40, high: 58 },
      },
      deck: {
        minor: { low: 60, high: 75 },
        mid: { low: 55, high: 72 },
        major: { low: 48, high: 65 },
      },
      addition: {
        minor: { low: 50, high: 65 },
        mid: { low: 45, high: 60 },
        major: { low: 38, high: 55 },
      },
      siding: {
        minor: { low: 70, high: 85 },
        mid: { low: 65, high: 80 },
        major: { low: 55, high: 72 },
      },
      windows: {
        minor: { low: 65, high: 78 },
        mid: { low: 60, high: 73 },
        major: { low: 52, high: 68 },
      },
    };

    const data = roiData[projectType]?.[scope as keyof ROIData] ?? { low: 50, high: 70 };

    // If project cost exceeds 15% of home value, reduce ROI slightly
    const costPercent = projectCost / homeValue;
    const overImprovementPenalty = costPercent > 0.15 ? Math.max(0.85, 1 - (costPercent - 0.15)) : 1.0;

    const lowROI = Math.round(data.low * overImprovementPenalty);
    const highROI = Math.round(data.high * overImprovementPenalty);
    const midROI = Math.round((lowROI + highROI) / 2);

    const valueAdded = Math.round(projectCost * (midROI / 100));
    const netCost = projectCost - valueAdded;
    const newHomeValue = homeValue + valueAdded;

    const fmt = (n: number): string => '$' + n.toLocaleString();

    document.getElementById('result-cost')!.textContent = fmt(projectCost);
    document.getElementById('result-roi')!.textContent = midROI + '%';
    document.getElementById('result-value')!.textContent = fmt(valueAdded);
    document.getElementById('result-recovered')!.textContent = lowROI + '-' + highROI + '%';
    document.getElementById('result-netcost')!.textContent = fmt(netCost);
    document.getElementById('result-newhome')!.textContent = fmt(newHomeValue);
    document.getElementById('result-percent')!.textContent = (costPercent * 100).toFixed(1) + '%';
  }

  document.querySelectorAll('#cost-calc select, #cost-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
