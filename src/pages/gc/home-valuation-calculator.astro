---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/gcTools';

const tool = getToolBySlug('home-valuation-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How accurate are renovation ROI estimates?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ROI estimates are based on national averages from Remodeling Magazine's annual Cost vs Value Report, which tracks actual resale data across hundreds of markets. Your results will vary based on local market conditions, quality of work, neighborhood comparables, and buyer preferences. Use these numbers as a conversation starter with customers, not a guarantee. In strong seller's markets, ROI often exceeds the averages. In buyer's markets, it can fall 10-15% below."
      }
    },
    {
      "@type": "Question",
      "name": "Which renovations give the best return on investment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Consistently, minor kitchen remodels and siding replacement deliver the highest ROI at 75-80%. These projects improve curb appeal and daily livability without overcapitalizing. Major upscale kitchen remodels and large room additions tend to have the lowest ROI at 50-65% because the cost escalates faster than the perceived value increase. Mid-range projects in kitchens, bathrooms, and basements typically land in the 60-75% range and represent the sweet spot for most homeowners."
      }
    },
    {
      "@type": "Question",
      "name": "How does the local market affect renovation value?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Market conditions significantly impact how much value a renovation adds. In a seller's market with low inventory, buyers pay premiums for move-in-ready homes, boosting renovation ROI by 10-20% above national averages. In a balanced market, returns track close to the averages. In a buyer's market with excess inventory, buyers have more options and less urgency, which can reduce ROI by 10-15%. Neighborhood price tier also matters. Overcapitalizing in an entry-level neighborhood yields lower returns than the same project in a mid-range or high-end area."
      }
    },
    {
      "@type": "Question",
      "name": "Should I show customers this tool during consultations?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Pull this up on your tablet or laptop during the initial consultation. Customers respond to concrete numbers more than vague promises about value. Enter their home value and the project you are discussing, and walk through the estimated value increase and ROI together. It reframes the conversation from cost to investment. Customers who see that a $35,000 kitchen remodel could add $25,000 or more in home value are far more likely to move forward and less likely to push back on price."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="valuation-calc">
    <!-- Two-column inputs -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <!-- Left Column: Property Details -->
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-1">Property Details</h3>
        <p class="text-text-muted text-xs mb-5">Enter the customer's home information</p>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="home-value">Current Home Value ($)</label>
            <input type="number" id="home-value" value="350000" min="50000" max="10000000" step="5000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            <p class="text-text-muted text-xs mt-1">Use Zillow estimate or recent comps</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="neighborhood">Neighborhood Tier</label>
            <select id="neighborhood" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
              <option value="entry">Entry-Level</option>
              <option value="mid" selected>Mid-Range</option>
              <option value="high">High-End</option>
            </select>
            <p class="text-text-muted text-xs mt-1">Affects how much value the market will absorb</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="market">Market Conditions</label>
            <select id="market" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
              <option value="buyer">Buyer's Market</option>
              <option value="balanced" selected>Balanced Market</option>
              <option value="seller">Seller's Market</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Right Column: Renovation Details -->
      <div class="bg-bg-card border rounded-xl p-6" style="border-color: rgba(255,107,43,0.3);">
        <h3 class="font-heading font-bold text-lg text-accent mb-1">Renovation Details</h3>
        <p class="text-text-muted text-xs mb-5">Enter the project you're quoting</p>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="reno-type">Renovation Type</label>
            <select id="reno-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
              <option value="kitchen">Kitchen Remodel</option>
              <option value="bathroom">Bathroom Remodel</option>
              <option value="basement">Basement Finishing</option>
              <option value="addition">Room Addition</option>
              <option value="deck">Deck / Patio</option>
              <option value="siding">Siding Replacement</option>
              <option value="windows">Window Replacement</option>
              <option value="garage">Garage Addition</option>
              <option value="attic">Attic Conversion</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="scope">Project Scope</label>
            <select id="scope" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
              <option value="minor">Minor / Cosmetic</option>
              <option value="midrange" selected>Mid-Range</option>
              <option value="major">Major / Upscale</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="project-cost">Estimated Project Cost ($)</label>
            <input type="number" id="project-cost" value="35000" min="1000" max="1000000" step="500" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <!-- Value Impact Cards -->
      <h3 class="font-heading font-bold text-xl mb-6">Value Impact Summary</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center border-2" style="border-color: rgba(255,107,43,0.4);">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Est. Value Increase</div>
          <div class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
            <span id="result-value-increase" class="font-heading font-extrabold text-3xl text-accent">--</span>
          </div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Estimated ROI</div>
          <div id="result-roi" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost Recovered</div>
          <div id="result-recovered" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">New Home Value</div>
          <div id="result-new-value" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <!-- Visual bar chart comparison -->
      <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Cost vs. Value Recovered</h4>
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Project Cost</span>
              <span id="bar-cost-label" class="text-text-primary font-medium">--</span>
            </div>
            <div class="w-full bg-bg-dark rounded-full h-8 overflow-hidden">
              <div id="bar-cost" class="h-full rounded-full transition-all duration-700 ease-out flex items-center justify-end pr-3" style="width: 100%; background: linear-gradient(90deg, #dc2626, #ef4444);">
                <span class="text-white text-xs font-bold whitespace-nowrap"></span>
              </div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Value Added to Home</span>
              <span id="bar-value-label" class="text-text-primary font-medium">--</span>
            </div>
            <div class="w-full bg-bg-dark rounded-full h-8 overflow-hidden">
              <div id="bar-value" class="h-full rounded-full transition-all duration-700 ease-out flex items-center justify-end pr-3" style="width: 50%; background: linear-gradient(90deg, #16a34a, #22c55e);">
                <span class="text-white text-xs font-bold whitespace-nowrap"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Side-by-side detail cards -->
      <h3 class="font-heading font-bold text-xl mb-6">Detailed Breakdown</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- Project Investment Card -->
        <div class="bg-bg-card border border-border rounded-xl p-6">
          <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Project Investment</h4>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Renovation Type</span>
              <span id="detail-reno-type" class="font-heading font-bold text-sm text-text-primary">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Project Scope</span>
              <span id="detail-scope" class="font-heading font-bold text-sm text-text-primary">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Base ROI Range</span>
              <span id="detail-base-roi" class="font-heading font-bold text-sm text-text-primary">--</span>
            </div>
            <div class="border-t border-border pt-3 flex justify-between items-center">
              <span class="text-text-primary font-medium">Total Project Cost</span>
              <span id="detail-cost" class="font-heading font-extrabold text-2xl text-text-primary">--</span>
            </div>
          </div>
        </div>

        <!-- Market Adjustments Card -->
        <div class="bg-bg-card border rounded-xl p-6" style="border-color: rgba(255,107,43,0.3);">
          <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-accent mb-4">Market Adjustments</h4>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Market Condition</span>
              <span id="detail-market" class="font-heading font-bold text-sm text-text-primary">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Market Adjustment</span>
              <span id="detail-market-adj" class="font-heading font-bold text-sm text-text-primary">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Neighborhood Adjustment</span>
              <span id="detail-hood-adj" class="font-heading font-bold text-sm text-text-primary">--</span>
            </div>
            <div class="border-t border-border pt-3 flex justify-between items-center">
              <span class="text-text-primary font-medium">Adjusted ROI</span>
              <span id="detail-adj-roi" class="font-heading font-extrabold text-2xl text-accent">--</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Cost vs Value benchmark -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">National Avg ROI</div>
          <div id="result-national-roi" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">Remodeling Magazine Cost vs Value</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Your Adjusted ROI</div>
          <div id="result-your-roi" class="font-heading font-extrabold text-2xl text-green-500">--</div>
          <div class="text-text-muted text-xs mt-1">With market and neighborhood factors</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">Estimates based on national averages from Remodeling Magazine's Cost vs Value Report, adjusted for market conditions and neighborhood tier. Actual returns vary by location, quality of materials, craftsmanship, and individual buyer preferences. Use as a conversation tool during consultations, not as a guarantee.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Tool</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the customer's home value.</strong> Use the Zillow Zestimate, a recent appraisal, or nearby comps. If the customer doesn't know, pull up Zillow on your phone and get a ballpark number. This doesn't need to be exact to have the conversation.</p>
          <p><strong class="text-text-primary">2. Set the neighborhood and market conditions.</strong> Entry-level neighborhoods have less room to absorb high-end upgrades, which lowers ROI. Seller's markets with tight inventory boost returns because buyers pay premiums for move-in-ready homes. Be honest with these settings to keep the estimate credible.</p>
          <p><strong class="text-text-primary">3. Select the renovation type and scope.</strong> Choose the project you're quoting and whether it's a minor cosmetic refresh, a solid mid-range remodel, or a full upscale overhaul. Enter your estimated project cost. The tool will pull the corresponding ROI range from industry data.</p>
          <p><strong class="text-text-primary">4. Walk the customer through the results.</strong> Show them the estimated value increase, cost recovered, and how their project compares to national averages. The bar chart makes the value gap immediately visible. Screenshot the results and attach them to your proposal.</p>
        </div>
      </section>

      <!-- Understanding Renovation ROI -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Understanding Renovation ROI</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">ROI doesn't mean dollar-for-dollar.</strong> No renovation returns 100% of its cost at resale. The industry standard benchmark is Remodeling Magazine's annual Cost vs Value Report, which tracks what homeowners spend and what they recoup when they sell. A 70% ROI on a $40,000 kitchen remodel means the home sells for roughly $28,000 more than it would have without the renovation. The homeowner gets a better kitchen to live in plus recovers most of their investment.</p>
          <p><strong class="text-text-primary">Scope matters more than most people think.</strong> Minor and mid-range projects consistently outperform major upscale ones on ROI. A minor kitchen remodel that refreshes cabinet faces, countertops, and hardware at $25,000 can return 75-80%. A major upscale gut-renovation at $80,000 might only return 55-65%. The reason is straightforward: buyers won't pay a proportional premium for luxury finishes in a mid-range neighborhood. Match the project scope to the neighborhood.</p>
          <p><strong class="text-text-primary">Market conditions shift the equation.</strong> In a seller's market, buyers compete for limited inventory and pay premiums for updated homes. Your customer's renovation ROI could beat the national average by 10-20%. In a buyer's market, there's less urgency and more alternatives, which can push returns 10-15% below average. A balanced market tracks close to the published data. Always factor in the current local conditions when setting expectations.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm">
            <p>Value Increase = Project Cost x Base ROI x Market Adjustment x Neighborhood Adjustment</p>
            <p>Adjusted ROI = Value Increase / Project Cost x 100</p>
          </div>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Pull this up during the initial consultation.</strong> When a homeowner is on the fence about a kitchen remodel or bathroom renovation, open this tool on your tablet. Enter their home value and the project details while you're sitting at their kitchen table. Seeing concrete numbers turns an abstract expense into an investment conversation. Customers who understand the value equation are less likely to chase the cheapest bid.</p>
          <p><strong class="text-text-primary">Attach the results to your proposal.</strong> Screenshot the value impact summary and include it as a page in your written proposal. When the customer is comparing your quote against a competitor's, the ROI data gives them a reason to choose the contractor who's thinking about their home's long-term value, not just the lowest number.</p>
          <p><strong class="text-text-primary">Use it to right-size the project scope.</strong> If a customer wants a major upscale renovation in an entry-level neighborhood, run the numbers side by side with a mid-range scope. Show them that the mid-range option might recover 70% of cost while the upscale version only recovers 50%. You're not upselling or downselling. You're giving them the data to make a smart decision, and that builds trust.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How accurate are renovation ROI estimates?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">ROI estimates are based on national averages from Remodeling Magazine's annual Cost vs Value Report, which tracks actual resale data across hundreds of markets. Your results will vary based on local market conditions, quality of work, neighborhood comparables, and buyer preferences. Use these numbers as a conversation starter with customers, not a guarantee. In strong seller's markets, ROI often exceeds the averages. In buyer's markets, it can fall 10-15% below.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Which renovations give the best return on investment?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Consistently, minor kitchen remodels and siding replacement deliver the highest ROI at 75-80%. These projects improve curb appeal and daily livability without overcapitalizing. Major upscale kitchen remodels and large room additions tend to have the lowest ROI at 50-65% because the cost escalates faster than the perceived value increase. Mid-range projects in kitchens, bathrooms, and basements typically land in the 60-75% range and represent the sweet spot for most homeowners.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How does the local market affect renovation value?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Market conditions significantly impact how much value a renovation adds. In a seller's market with low inventory, buyers pay premiums for move-in-ready homes, boosting renovation ROI by 10-20% above national averages. In a balanced market, returns track close to the averages. In a buyer's market with excess inventory, buyers have more options and less urgency, which can reduce ROI by 10-15%. Neighborhood price tier also matters. Overcapitalizing in an entry-level neighborhood yields lower returns than the same project in a mid-range or high-end area.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I show customers this tool during consultations?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Pull this up on your tablet or laptop during the initial consultation. Customers respond to concrete numbers more than vague promises about value. Enter their home value and the project you are discussing, and walk through the estimated value increase and ROI together. It reframes the conversation from cost to investment. Customers who see that a $35,000 kitchen remodel could add $25,000 or more in home value are far more likely to move forward and less likely to push back on price.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // --- Types ---
  interface RoiRange {
    minor: [number, number];
    midrange: [number, number];
    major: [number, number];
  }

  interface MarketMultiplier {
    buyer: number;
    balanced: number;
    seller: number;
  }

  interface NeighborhoodMultiplier {
    entry: number;
    mid: number;
    high: number;
  }

  // --- ROI Data (based on Remodeling Magazine Cost vs Value Report) ---
  const roiData: Record<string, RoiRange> = {
    kitchen:   { minor: [0.75, 0.80], midrange: [0.65, 0.75], major: [0.55, 0.70] },
    bathroom:  { minor: [0.65, 0.70], midrange: [0.60, 0.70], major: [0.55, 0.65] },
    basement:  { minor: [0.72, 0.78], midrange: [0.70, 0.75], major: [0.60, 0.70] },
    addition:  { minor: [0.58, 0.65], midrange: [0.53, 0.62], major: [0.50, 0.58] },
    deck:      { minor: [0.70, 0.78], midrange: [0.65, 0.75], major: [0.60, 0.70] },
    siding:    { minor: [0.75, 0.82], midrange: [0.70, 0.80], major: [0.65, 0.75] },
    windows:   { minor: [0.70, 0.78], midrange: [0.65, 0.75], major: [0.60, 0.70] },
    garage:    { minor: [0.60, 0.68], midrange: [0.55, 0.65], major: [0.50, 0.60] },
    attic:     { minor: [0.65, 0.72], midrange: [0.60, 0.70], major: [0.55, 0.65] },
  };

  const renoLabels: Record<string, string> = {
    kitchen: 'Kitchen Remodel',
    bathroom: 'Bathroom Remodel',
    basement: 'Basement Finishing',
    addition: 'Room Addition',
    deck: 'Deck / Patio',
    siding: 'Siding Replacement',
    windows: 'Window Replacement',
    garage: 'Garage Addition',
    attic: 'Attic Conversion',
  };

  const scopeLabels: Record<string, string> = {
    minor: 'Minor / Cosmetic',
    midrange: 'Mid-Range',
    major: 'Major / Upscale',
  };

  const marketLabels: Record<string, string> = {
    buyer: "Buyer's Market",
    balanced: 'Balanced Market',
    seller: "Seller's Market",
  };

  const marketMultipliers: MarketMultiplier = {
    buyer: 0.88,
    balanced: 1.0,
    seller: 1.15,
  };

  const neighborhoodMultipliers: NeighborhoodMultiplier = {
    entry: 0.85,
    mid: 1.0,
    high: 1.10,
  };

  function formatCurrency(val: number): string {
    return '$' + val.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function formatPercent(val: number): string {
    return val.toFixed(1) + '%';
  }

  function calculate(): void {
    // Inputs
    const homeValue = parseFloat((document.getElementById('home-value') as HTMLInputElement).value) || 350000;
    const renoType = (document.getElementById('reno-type') as HTMLSelectElement).value;
    const scope = (document.getElementById('scope') as HTMLSelectElement).value as keyof RoiRange;
    const projectCost = parseFloat((document.getElementById('project-cost') as HTMLInputElement).value) || 35000;
    const market = (document.getElementById('market') as HTMLSelectElement).value as keyof MarketMultiplier;
    const neighborhood = (document.getElementById('neighborhood') as HTMLSelectElement).value as keyof NeighborhoodMultiplier;

    // Look up base ROI range
    const renoRoi = roiData[renoType] || roiData['kitchen'];
    const roiRange = renoRoi[scope] || renoRoi['midrange'];
    const baseRoiMid = (roiRange[0] + roiRange[1]) / 2;

    // Apply adjustments
    const marketMult = marketMultipliers[market];
    const hoodMult = neighborhoodMultipliers[neighborhood];

    // Cap adjusted ROI: prevent exceeding realistic bounds
    const adjustedRoi = Math.min(baseRoiMid * marketMult * hoodMult, 0.98);

    // Calculate value impact
    const valueIncrease = projectCost * adjustedRoi;
    const roiPercent = adjustedRoi * 100;
    const costRecovered = valueIncrease;
    const newHomeValue = homeValue + valueIncrease;
    const nationalRoiMid = baseRoiMid * 100;

    // Market and neighborhood adjustment display
    const marketAdjPct = (marketMult - 1) * 100;
    const hoodAdjPct = (hoodMult - 1) * 100;

    // Update value impact summary cards
    document.getElementById('result-value-increase')!.textContent = formatCurrency(Math.round(valueIncrease));
    document.getElementById('result-roi')!.textContent = formatPercent(roiPercent);
    document.getElementById('result-recovered')!.textContent = formatCurrency(Math.round(costRecovered));
    document.getElementById('result-new-value')!.textContent = formatCurrency(Math.round(newHomeValue));

    // Update bar chart
    const maxBar = Math.max(projectCost, valueIncrease, 1);
    const costBarPct = (projectCost / maxBar) * 100;
    const valueBarPct = (valueIncrease / maxBar) * 100;
    (document.getElementById('bar-cost') as HTMLElement).style.width = costBarPct + '%';
    (document.getElementById('bar-value') as HTMLElement).style.width = valueBarPct + '%';
    document.getElementById('bar-cost-label')!.textContent = formatCurrency(Math.round(projectCost));
    document.getElementById('bar-value-label')!.textContent = formatCurrency(Math.round(valueIncrease));

    // Update detail cards
    document.getElementById('detail-reno-type')!.textContent = renoLabels[renoType] || renoType;
    document.getElementById('detail-scope')!.textContent = scopeLabels[scope] || scope;
    document.getElementById('detail-base-roi')!.textContent = (roiRange[0] * 100).toFixed(0) + '-' + (roiRange[1] * 100).toFixed(0) + '%';
    document.getElementById('detail-cost')!.textContent = formatCurrency(Math.round(projectCost));

    document.getElementById('detail-market')!.textContent = marketLabels[market] || market;
    document.getElementById('detail-market-adj')!.textContent = (marketAdjPct >= 0 ? '+' : '') + marketAdjPct.toFixed(0) + '%';
    document.getElementById('detail-hood-adj')!.textContent = (hoodAdjPct >= 0 ? '+' : '') + hoodAdjPct.toFixed(0) + '%';
    document.getElementById('detail-adj-roi')!.textContent = formatPercent(roiPercent);

    // Update benchmark comparison
    document.getElementById('result-national-roi')!.textContent = formatPercent(nationalRoiMid);
    document.getElementById('result-your-roi')!.textContent = formatPercent(roiPercent);
  }

  // Auto-calculate on any input change
  document.querySelectorAll('#valuation-calc input, #valuation-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
