---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/handymanTools';

const tool = getToolBySlug('seasonal-promoter')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much should I discount a seasonal service bundle?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most handymen find that a 10-15% bundle discount hits the sweet spot. It's enough to make the customer feel like they're getting a deal, but you're still making strong revenue because you're selling 4-7 tasks at once instead of chasing individual calls. A 15% discount on a $900 bundle still nets you $765 in a single visit, compared to maybe booking 1-2 of those tasks individually."
      }
    },
    {
      "@type": "Question",
      "name": "What seasonal tasks sell best as bundles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Spring and fall bundles tend to sell best because homeowners feel the urgency of seasonal transitions. Gutter cleaning paired with exterior caulking and power washing is a strong spring combo. In fall, storm window installation plus weatherstripping and smoke detector battery swaps are easy sells. The key is combining visible tasks (power washing, paint touch-ups) with preventive ones (insulation checks, dryer vent cleaning) so customers see immediate value."
      }
    },
    {
      "@type": "Question",
      "name": "How do I pitch a seasonal bundle to a customer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lead with the savings and convenience. Tell them: instead of calling multiple times throughout the season, you'll handle everything in one visit at a bundled rate. Show them the line-item breakdown so they see the individual value, then highlight the discount. Framing it as 'seasonal maintenance' rather than a list of repairs positions you as a proactive partner, not just someone they call when things break."
      }
    },
    {
      "@type": "Question",
      "name": "Should I offer the same bundles to every customer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start with a standard bundle as your base offering, then customize. This tool lets you check and uncheck tasks so you can tailor the bundle during the conversation. Older homes might need more weatherproofing and caulking work. Newer homes might focus on cosmetic maintenance like deck staining and power washing. Having a default bundle ready saves you time, but flexibility closes more deals."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="seasonal-promoter">
    <!-- Season Selector and Bundle Name -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="season-select">Select Season</label>
        <select id="season-select" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="spring">Spring</option>
          <option value="summer">Summer</option>
          <option value="fall" selected>Fall</option>
          <option value="winter">Winter</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="bundle-name">Bundle Name</label>
        <input type="text" id="bundle-name" value="Fall Home Maintenance Package" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" placeholder="e.g. Spring Refresh Package" />
      </div>
    </div>

    <!-- Bundle Discount -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="bundle-discount">Bundle Discount %</label>
        <input type="number" id="bundle-discount" value="15" min="0" max="50" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">10-15% is the sweet spot for most bundles</p>
      </div>
    </div>

    <!-- Task Checklist -->
    <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
      <h3 class="font-heading font-bold text-lg text-text-primary mb-1">Seasonal Tasks</h3>
      <p class="text-text-muted text-xs mb-5">Check the tasks to include, and adjust prices to match your market</p>
      <div id="task-list" class="space-y-3">
        <!-- Tasks will be populated by JavaScript -->
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Bundle Summary</h3>

      <!-- Summary cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Tasks Selected</div>
          <div id="result-task-count" class="font-heading font-extrabold text-3xl text-text-primary">0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Individual Total</div>
          <div id="result-individual-total" class="font-heading font-extrabold text-3xl text-text-primary">$0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center border-2" style="border-color: rgba(255,107,43,0.4);">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Bundled Price</div>
          <div id="result-bundle-price" class="font-heading font-extrabold text-3xl text-accent">$0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Customer Saves</div>
          <div class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
            <span id="result-customer-savings" class="font-heading font-extrabold text-3xl text-green-500">$0</span>
          </div>
        </div>
      </div>

      <!-- Visual bar comparison -->
      <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Price Comparison</h4>
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Individual Pricing</span>
              <span id="bar-individual-label" class="text-text-primary font-medium">--</span>
            </div>
            <div class="w-full bg-bg-dark rounded-full h-8 overflow-hidden">
              <div id="bar-individual" class="h-full rounded-full transition-all duration-700 ease-out flex items-center justify-end pr-3" style="width: 100%; background: linear-gradient(90deg, #dc2626, #ef4444);">
                <span class="text-white text-xs font-bold whitespace-nowrap"></span>
              </div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Your Bundle</span>
              <span id="bar-bundle-label" class="text-text-primary font-medium">--</span>
            </div>
            <div class="w-full bg-bg-dark rounded-full h-8 overflow-hidden">
              <div id="bar-bundle" class="h-full rounded-full transition-all duration-700 ease-out flex items-center justify-end pr-3" style="width: 85%; background: linear-gradient(90deg, #16a34a, #22c55e);">
                <span class="text-white text-xs font-bold whitespace-nowrap"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Revenue projection -->
      <h3 class="font-heading font-bold text-xl mb-6">Your Revenue Projection</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Revenue Per Bundle</div>
          <div id="result-revenue-per" class="font-heading font-extrabold text-2xl text-text-primary">$0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">5 Bundles Sold</div>
          <div id="result-revenue-5" class="font-heading font-extrabold text-2xl text-text-primary">$0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center border-2" style="border-color: rgba(255,107,43,0.4);">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">10 Bundles Sold</div>
          <div id="result-revenue-10" class="font-heading font-extrabold text-2xl text-accent">$0</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">Prices are defaults based on national averages. Adjust task prices to match your local market rates and labor costs.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Tool</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Pick your season.</strong> Select the season you want to build a bundle for. Each season loads a different set of common maintenance tasks that homeowners need done. Fall and spring bundles tend to sell best because of the urgency around seasonal transitions.</p>
          <p><strong class="text-text-primary">2. Check the tasks you want to include.</strong> Every task has a default price based on national averages. Edit any price to match what you actually charge in your market. Uncheck tasks that don't apply or that you don't offer.</p>
          <p><strong class="text-text-primary">3. Set your bundle discount.</strong> A 10-15% discount is the sweet spot. It's enough to motivate the customer to buy the whole package instead of cherry-picking one or two tasks. You still make strong revenue because you're selling multiple tasks in a single visit.</p>
          <p><strong class="text-text-primary">4. Name your bundle and show the customer.</strong> Give it a professional name like "Fall Home Prep Package" or "Spring Refresh Bundle." Show them the individual pricing versus the bundle price so they see the savings. The visual bar chart makes the value obvious during a sales conversation.</p>
        </div>
      </section>

      <!-- Why Seasonal Bundles Work -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Why Seasonal Bundles Work</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Bigger tickets per visit.</strong> Instead of booking a single $150 gutter cleaning, you're selling a $700+ package. Your drive time, setup, and overhead stay the same, but your revenue per visit jumps dramatically. Bundles turn small maintenance calls into profitable half-day jobs.</p>
          <p><strong class="text-text-primary">Customers see you as a partner, not a one-call fix.</strong> When you pitch seasonal maintenance as a package, you position yourself as someone who keeps their home in shape year-round. That builds recurring relationships. Many handymen who start offering seasonal bundles find that 30-40% of bundle customers rebook the next season without being asked.</p>
          <p><strong class="text-text-primary">Preventive work uncovers bigger projects.</strong> A routine insulation check might reveal a bathroom that needs remodeling. A deck inspection could lead to a full rebuild quote. Bundled maintenance visits get you inside (and around) the home, where you spot opportunities for larger projects that the customer didn't even know they needed.</p>
        </div>
      </section>

      <!-- Pricing Tips -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Pricing Your Bundles Right</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Start with your actual task rates.</strong> The default prices in this tool are national averages. Your market might be higher or lower. Edit each task price to reflect what you'd charge if a customer called you for that one job. Then the bundle discount applies on top of your real numbers, so the math is honest.</p>
          <p><strong class="text-text-primary">Don't discount more than 20%.</strong> Going over 20% starts cutting into your margins on labor-heavy tasks. The customer already gets value from the convenience of one visit and one invoice. You don't need to race to the bottom on price. If a customer pushes for a bigger discount, add a small bonus task instead of cutting the percentage.</p>
          <p><strong class="text-text-primary">Factor in efficiency gains.</strong> When you're at a home doing 5-6 tasks, you save on drive time, load/unload, and setup. A gutter cleaning that takes 45 minutes as a standalone visit might only take 30 minutes when you're already on-site with your ladder and tools out. Your effective hourly rate on bundled work is almost always higher than on individual calls.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much should I discount a seasonal service bundle?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most handymen find that a 10-15% bundle discount hits the sweet spot. It's enough to make the customer feel like they're getting a deal, but you're still making strong revenue because you're selling 4-7 tasks at once instead of chasing individual calls. A 15% discount on a $900 bundle still nets you $765 in a single visit, compared to maybe booking 1-2 of those tasks individually.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What seasonal tasks sell best as bundles?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Spring and fall bundles tend to sell best because homeowners feel the urgency of seasonal transitions. Gutter cleaning paired with exterior caulking and power washing is a strong spring combo. In fall, storm window installation plus weatherstripping and smoke detector battery swaps are easy sells. The key is combining visible tasks (power washing, paint touch-ups) with preventive ones (insulation checks, dryer vent cleaning) so customers see immediate value.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I pitch a seasonal bundle to a customer?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Lead with the savings and convenience. Tell them: instead of calling multiple times throughout the season, you'll handle everything in one visit at a bundled rate. Show them the line-item breakdown so they see the individual value, then highlight the discount. Framing it as "seasonal maintenance" rather than a list of repairs positions you as a proactive partner, not just someone they call when things break.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I offer the same bundles to every customer?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Start with a standard bundle as your base offering, then customize. This tool lets you check and uncheck tasks so you can tailor the bundle during the conversation. Older homes might need more weatherproofing and caulking work. Newer homes might focus on cosmetic maintenance like deck staining and power washing. Having a default bundle ready saves you time, but flexibility closes more deals.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  interface SeasonalTask {
    name: string;
    defaultPrice: number;
    checked: boolean;
  }

  type SeasonKey = 'spring' | 'summer' | 'fall' | 'winter';

  const seasonalTasks: Record<SeasonKey, SeasonalTask[]> = {
    spring: [
      { name: 'Gutter Cleaning', defaultPrice: 150, checked: true },
      { name: 'Power Washing (Driveway & Siding)', defaultPrice: 250, checked: true },
      { name: 'Deck Inspection & Minor Repairs', defaultPrice: 175, checked: true },
      { name: 'Window Screen Repair/Replacement', defaultPrice: 120, checked: true },
      { name: 'HVAC Filter Change', defaultPrice: 45, checked: true },
      { name: 'Caulk Inspection & Touch-Up', defaultPrice: 95, checked: true },
      { name: 'Exterior Paint Touch-Up', defaultPrice: 200, checked: false },
    ],
    summer: [
      { name: 'Fence Repair & Staining', defaultPrice: 300, checked: true },
      { name: 'Deck Staining/Sealing', defaultPrice: 275, checked: true },
      { name: 'Ceiling Fan Installation', defaultPrice: 150, checked: true },
      { name: 'Weather Stripping Check & Replace', defaultPrice: 85, checked: true },
      { name: 'Dryer Vent Cleaning', defaultPrice: 110, checked: true },
    ],
    fall: [
      { name: 'Gutter Cleaning & Downspout Check', defaultPrice: 165, checked: true },
      { name: 'Storm Window Installation', defaultPrice: 200, checked: true },
      { name: 'Insulation Inspection', defaultPrice: 125, checked: true },
      { name: 'Smoke Detector Battery Swap', defaultPrice: 55, checked: true },
      { name: 'Door & Window Weatherstripping', defaultPrice: 130, checked: true },
      { name: 'Exterior Caulking', defaultPrice: 110, checked: true },
    ],
    winter: [
      { name: 'Pipe Insulation', defaultPrice: 175, checked: true },
      { name: 'Draft Sealing (Doors & Windows)', defaultPrice: 140, checked: true },
      { name: 'Thermostat Check & Calibration', defaultPrice: 65, checked: true },
      { name: 'Ice Dam Prevention (Heat Cable Check)', defaultPrice: 195, checked: true },
      { name: 'Interior Repairs & Touch-Ups', defaultPrice: 160, checked: false },
    ],
  };

  const defaultBundleNames: Record<SeasonKey, string> = {
    spring: 'Spring Home Refresh Package',
    summer: 'Summer Ready Package',
    fall: 'Fall Home Maintenance Package',
    winter: 'Winter Prep Package',
  };

  // Clone tasks for each season so edits don't mutate defaults
  let currentTasks: SeasonalTask[] = [];

  function formatCurrency(val: number): string {
    return '$' + val.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function renderTasks(): void {
    const container = document.getElementById('task-list')!;
    container.innerHTML = '';

    currentTasks.forEach((task, index) => {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-4 bg-bg-dark border border-border rounded-lg px-4 py-3';

      row.innerHTML = `
        <input type="checkbox" id="task-check-${index}" ${task.checked ? 'checked' : ''} class="w-5 h-5 rounded border-border text-accent focus:ring-accent bg-bg-dark cursor-pointer flex-shrink-0" />
        <label for="task-check-${index}" class="flex-1 text-text-primary text-sm font-medium cursor-pointer select-none">${task.name}</label>
        <div class="flex items-center gap-1 flex-shrink-0">
          <span class="text-text-muted text-sm">$</span>
          <input type="number" id="task-price-${index}" value="${task.defaultPrice}" min="0" max="9999" step="5" class="w-20 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-text-primary text-sm text-right focus:border-accent focus:outline-none transition-colors" />
        </div>
      `;

      container.appendChild(row);

      // Bind events
      const checkbox = row.querySelector(`#task-check-${index}`) as HTMLInputElement;
      const priceInput = row.querySelector(`#task-price-${index}`) as HTMLInputElement;

      checkbox.addEventListener('change', () => {
        currentTasks[index].checked = checkbox.checked;
        calculate();
      });

      priceInput.addEventListener('input', () => {
        currentTasks[index].defaultPrice = parseFloat(priceInput.value) || 0;
        calculate();
      });
    });
  }

  function loadSeason(season: SeasonKey): void {
    // Deep clone the tasks for this season
    currentTasks = seasonalTasks[season].map(t => ({ ...t }));

    // Update bundle name
    const nameInput = document.getElementById('bundle-name') as HTMLInputElement;
    nameInput.value = defaultBundleNames[season];

    renderTasks();
    calculate();
  }

  function calculate(): void {
    const discount = parseFloat((document.getElementById('bundle-discount') as HTMLInputElement).value) || 0;
    const clampedDiscount = Math.max(0, Math.min(50, discount));

    // Calculate totals from checked tasks
    const selectedTasks = currentTasks.filter(t => t.checked);
    const taskCount = selectedTasks.length;
    const individualTotal = selectedTasks.reduce((sum, t) => sum + t.defaultPrice, 0);
    const discountAmount = individualTotal * (clampedDiscount / 100);
    const bundlePrice = individualTotal - discountAmount;
    const customerSavings = discountAmount;

    // Update summary cards
    document.getElementById('result-task-count')!.textContent = taskCount.toString();
    document.getElementById('result-individual-total')!.textContent = formatCurrency(Math.round(individualTotal));
    document.getElementById('result-bundle-price')!.textContent = formatCurrency(Math.round(bundlePrice));
    document.getElementById('result-customer-savings')!.textContent = formatCurrency(Math.round(customerSavings));

    // Update bar chart
    const maxCost = Math.max(individualTotal, 1);
    const individualBarPct = 100;
    const bundleBarPct = individualTotal > 0 ? (bundlePrice / maxCost) * 100 : 0;
    (document.getElementById('bar-individual') as HTMLElement).style.width = individualBarPct + '%';
    (document.getElementById('bar-bundle') as HTMLElement).style.width = Math.max(bundleBarPct, 2) + '%';
    document.getElementById('bar-individual-label')!.textContent = formatCurrency(Math.round(individualTotal));
    document.getElementById('bar-bundle-label')!.textContent = formatCurrency(Math.round(bundlePrice));

    // Revenue projections
    document.getElementById('result-revenue-per')!.textContent = formatCurrency(Math.round(bundlePrice));
    document.getElementById('result-revenue-5')!.textContent = formatCurrency(Math.round(bundlePrice * 5));
    document.getElementById('result-revenue-10')!.textContent = formatCurrency(Math.round(bundlePrice * 10));
  }

  // Season change handler
  const seasonSelect = document.getElementById('season-select') as HTMLSelectElement;
  seasonSelect.addEventListener('change', () => {
    loadSeason(seasonSelect.value as SeasonKey);
  });

  // Discount change handler
  const discountInput = document.getElementById('bundle-discount') as HTMLInputElement;
  discountInput.addEventListener('input', calculate);

  // Initialize with default season
  loadSeason(seasonSelect.value as SeasonKey);
</script>
