---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/handymanTools';

const tool = getToolBySlug('labor-rate-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should a handyman charge per hour?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most handymen charge $60-85 per hour for general work. Your actual rate depends on your overhead costs, desired income, and local market. Use a labor rate calculator to find your breakeven rate, then add markup. Charging less than your breakeven means you lose money on every job."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate my labor rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Add your annual overhead costs to your desired personal income, then divide by your billable hours per year. A solo handyman working full-time typically bills about 1,000-1,200 hours per year (accounting for drive time, estimates, admin, and slow weeks). Add a markup of 20-40% for profit and contingency."
      }
    },
    {
      "@type": "Question",
      "name": "How many billable hours does a handyman work per year?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A full-time solo handyman typically bills 1,000-1,200 hours per year. Out of 2,080 total work hours, roughly 50% is spent on non-billable tasks: driving, quoting, purchasing materials, bookkeeping, marketing, and taking time off. Do not base your rate on 2,080 hours or you will dramatically underprice your work."
      }
    },
    {
      "@type": "Question",
      "name": "Why is my handyman rate too low?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most handymen undercharge because they do not account for overhead, non-billable time, or profit margin. If you charge $40/hr but your overhead costs $25/hr, you are only netting $15/hr before taxes. Use this calculator to find your true breakeven rate and price accordingly."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="labor-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="annualOverhead">Annual Overhead Costs ($)</label>
        <input type="number" id="annualOverhead" value="25000" min="0" max="500000" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Vehicle, insurance, tools, phone, marketing, etc.</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="desiredIncome">Desired Annual Income ($)</label>
        <input type="number" id="desiredIncome" value="75000" min="0" max="500000" step="5000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="billableHours">Billable Hours per Year</label>
        <input type="number" id="billableHours" value="1000" min="200" max="2500" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Default 1,000 (about 50% of total work hours)</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="markupTarget">Markup Target (%)</label>
        <input type="number" id="markupTarget" value="25" min="0" max="100" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Profit margin on top of breakeven</p>
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Breakeven Rate</div>
          <div id="result-breakeven" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Target Rate</div>
          <div id="result-target" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Revenue</div>
          <div id="result-revenue" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Overhead/Hour</div>
          <div id="result-overhead-hr" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <!-- Benchmark Comparison -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Handyman Industry Benchmarks</h4>
        <div class="space-y-3">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Entry Level</span>
              <span class="text-text-primary font-semibold">$45-60/hr</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#FBBF24] h-2 rounded-full" style="width: 35%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Industry Average</span>
              <span class="text-text-primary font-semibold">$60-85/hr</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#60A5FA] h-2 rounded-full" style="width: 55%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Experienced / Specialized</span>
              <span class="text-text-primary font-semibold">$85-125/hr</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#34D399] h-2 rounded-full" style="width: 75%"></div>
            </div>
          </div>
          <div class="mt-4 pt-4 border-t border-border">
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary font-medium">Your Target Rate</span>
              <span id="benchmark-rate" class="font-heading font-bold">--</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2.5">
              <div id="benchmark-bar" class="h-2.5 rounded-full transition-all duration-500" style="width: 0%"></div>
            </div>
          </div>
        </div>
        <div id="rate-warning" class="hidden mt-3 bg-[rgba(239,68,68,0.1)] border border-[rgba(239,68,68,0.3)] rounded-lg px-4 py-3 text-sm text-[#FCA5A5]">
          Your rate is below the industry average of $60/hr. You may be undercharging for your work.
        </div>
      </div>

      <p class="text-text-muted text-sm italic">Rates are estimates. Adjust for your local market, specialization, and experience level.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter your annual overhead.</strong> Include everything that costs money to run your business: vehicle payment, fuel, insurance, tools, phone, marketing, software, and any other expenses.</p>
          <p><strong class="text-text-primary">2. Set your desired income.</strong> This is what you want to take home after business expenses. Be honest about your financial goals.</p>
          <p><strong class="text-text-primary">3. Estimate billable hours.</strong> A full-time solo handyman typically bills 1,000-1,200 hours per year. The rest goes to driving, quoting, purchasing, and admin work.</p>
          <p><strong class="text-text-primary">4. Add markup.</strong> The markup covers profit and contingency above your breakeven rate. Most successful handymen add 20-40%.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Labor Rate Formula Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Total_Annual_Need = Overhead + Desired_Income</p>
            <p>Breakeven_Rate = Total_Annual_Need / Billable_Hours</p>
            <p>Target_Rate = Breakeven_Rate x (1 + Markup%)</p>
            <p>Annual_Revenue = Target_Rate x Billable_Hours</p>
          </div>
          <p>The breakeven rate is the minimum you must charge to cover costs and take home your desired income. Charging below this means you lose money or earn less than your goal. The target rate adds a profit buffer for slow periods and unexpected expenses.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should a handyman charge per hour?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most handymen charge $60-85 per hour for general work. Your actual rate depends on your overhead costs, desired income, and local market.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate my labor rate?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Add your annual overhead costs to your desired personal income, then divide by your billable hours per year. Add a markup of 20-40% for profit and contingency.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many billable hours does a handyman work per year?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A full-time solo handyman typically bills 1,000-1,200 hours per year. Out of 2,080 total work hours, roughly 50% is non-billable.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why is my handyman rate too low?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most handymen undercharge because they do not account for overhead, non-billable time, or profit margin. Use this calculator to find your true breakeven rate.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const annualOverhead = parseFloat((document.getElementById('annualOverhead') as HTMLInputElement).value) || 0;
    const desiredIncome = parseFloat((document.getElementById('desiredIncome') as HTMLInputElement).value) || 0;
    const billableHours = parseFloat((document.getElementById('billableHours') as HTMLInputElement).value) || 1000;
    const markupTarget = parseFloat((document.getElementById('markupTarget') as HTMLInputElement).value) || 0;

    const totalNeed = annualOverhead + desiredIncome;
    const breakevenRate = totalNeed / billableHours;
    const targetRate = breakevenRate * (1 + markupTarget / 100);
    const annualRevenue = targetRate * billableHours;
    const overheadPerHour = annualOverhead / billableHours;

    document.getElementById('result-breakeven')!.textContent = '$' + breakevenRate.toFixed(0) + '/hr';
    document.getElementById('result-target')!.textContent = '$' + targetRate.toFixed(0) + '/hr';
    document.getElementById('result-revenue')!.textContent = '$' + Math.round(annualRevenue).toLocaleString();
    document.getElementById('result-overhead-hr')!.textContent = '$' + overheadPerHour.toFixed(0) + '/hr';

    // Benchmark bar (scale: $0-150)
    const clampedRate = Math.max(0, Math.min(150, targetRate));
    const barPct = (clampedRate / 150) * 100;
    const benchmarkBar = document.getElementById('benchmark-bar') as HTMLElement;
    benchmarkBar.style.width = barPct + '%';
    benchmarkBar.classList.remove('bg-[#34D399]', 'bg-[#FBBF24]', 'bg-[#EF4444]');

    const benchmarkRateEl = document.getElementById('benchmark-rate')!;
    benchmarkRateEl.textContent = '$' + targetRate.toFixed(0) + '/hr';
    benchmarkRateEl.classList.remove('text-[#34D399]', 'text-[#FBBF24]', 'text-[#EF4444]');

    if (targetRate >= 85) {
      benchmarkBar.classList.add('bg-[#34D399]');
      benchmarkRateEl.classList.add('text-[#34D399]');
    } else if (targetRate >= 60) {
      benchmarkBar.classList.add('bg-[#60A5FA]');
      benchmarkRateEl.classList.add('text-[#60A5FA]');
    } else {
      benchmarkBar.classList.add('bg-[#EF4444]');
      benchmarkRateEl.classList.add('text-[#EF4444]');
    }

    const warningEl = document.getElementById('rate-warning')!;
    if (targetRate < 60) {
      warningEl.classList.remove('hidden');
    } else {
      warningEl.classList.add('hidden');
    }
  }

  document.querySelectorAll('#labor-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
