---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/handymanTools';

const tool = getToolBySlug('customer-estimator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much should a handyman charge per hour?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most handymen charge between $75 and $150 per hour depending on the market, skill level, and job type. Major metros and specialized tasks push toward the higher end. When you factor in drive time, quoting time, and overhead, your effective hourly rate needs to be at least $75 to stay profitable as a solo operator. Many experienced handymen target $100-125/hr as their billable rate."
      }
    },
    {
      "@type": "Question",
      "name": "Should I charge a trip charge or minimum fee?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. A trip charge or minimum fee (typically $75-150) covers your drive time, vehicle costs, and the fixed overhead of showing up. Without it, small 30-minute jobs become money losers after you account for travel, quoting, and invoicing. Some handymen fold the trip charge into a minimum job price instead of listing it separately."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I mark up materials?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A standard materials markup for handyman work is 15-25%. This covers your time sourcing and picking up materials, fuel for supply runs, and the risk of buying the wrong item. Some handymen use a flat markup percentage while others charge materials at cost plus a separate supply run fee. Either way, never pass materials through at your cost — your time and vehicle have value."
      }
    },
    {
      "@type": "Question",
      "name": "How do I price a handyman job I have never done before?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Estimate the hours honestly, then add a 25-30% buffer for unknowns. Research material costs before quoting. If the job type is completely new to you, be upfront with the customer about providing a time-and-materials quote rather than a fixed price. As you complete more of those jobs, you will build a reference library of actual times that makes future bids more accurate."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="cost-calc">
    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="jobType">Job Type</label>
        <select id="jobType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="drywall-patch" selected>Drywall Patch / Repair</option>
          <option value="door-install">Interior Door Install</option>
          <option value="faucet-replacement">Faucet Replacement</option>
          <option value="ceiling-fan">Ceiling Fan Install</option>
          <option value="shelving">Shelving / Mounting</option>
          <option value="tile-repair">Tile Repair</option>
          <option value="general-repair">General Repair</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="estimatedHours">Estimated Hours</label>
        <input type="number" id="estimatedHours" value="2" min="0.5" max="40" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="hourlyRate">Your Hourly Rate ($)</label>
        <input type="number" id="hourlyRate" value="100" min="50" max="300" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="materialsCost">Materials Cost ($)</label>
        <input type="number" id="materialsCost" value="50" min="0" max="5000" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="markupPercent">Materials Markup (%)</label>
        <select id="markupPercent" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="0">0% (pass-through)</option>
          <option value="15">15%</option>
          <option value="20" selected>20%</option>
          <option value="25">25%</option>
          <option value="30">30%</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tripCharge">Trip Charge ($)</label>
        <input type="number" id="tripCharge" value="75" min="0" max="300" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Job Price Breakdown</h3>

      <!-- Total Price -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <div class="flex justify-between items-end mb-3">
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Labor</div>
            <div id="result-labor" class="font-heading font-extrabold text-xl text-text-secondary">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Total Price</div>
            <div id="result-total" class="font-heading font-extrabold text-3xl text-accent">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Materials (w/ markup)</div>
            <div id="result-materials" class="font-heading font-extrabold text-xl text-text-secondary">--</div>
          </div>
        </div>
        <div class="relative h-3 bg-bg-card rounded-full overflow-hidden mt-4">
          <div id="range-bar" class="absolute inset-y-0 left-[10%] right-[10%] rounded-full bg-gradient-to-r from-accent/40 via-accent to-accent/40"></div>
          <div id="range-marker" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-accent rounded-full border-2 border-white shadow-lg"></div>
        </div>
      </div>

      <!-- Detail Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Effective Hourly Rate</div>
          <div id="result-effective" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">all-in per hour</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Trip Charge</div>
          <div id="result-trip" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">included in total</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Markup Earned</div>
          <div id="result-markup" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">on materials</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Your Gross Profit</div>
          <div id="result-profit" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">before overhead</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">Use this as a starting point for your quote. Always adjust for job-specific complexity, access difficulty, and any factors that could extend the work beyond your initial hour estimate.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Estimator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the job type.</strong> This sets context for the estimate. Different jobs have different typical hour ranges and material needs. The job type also helps you sanity-check your hour estimate against typical completion times.</p>
          <p><strong class="text-text-primary">2. Enter your estimated hours and hourly rate.</strong> Be honest about how long the job will take including setup, the work itself, and cleanup. Your hourly rate should cover your labor, insurance, vehicle, tools, and profit margin.</p>
          <p><strong class="text-text-primary">3. Add materials cost and markup.</strong> Enter what the materials will cost you at the store. The markup percentage covers your time shopping, driving to the supply house, and the risk of returns or wrong parts. A 20% markup is standard in the industry.</p>
          <p><strong class="text-text-primary">4. Set your trip charge.</strong> This covers your drive time and vehicle costs for showing up. It ensures you get paid even on short jobs. The total price combines labor, marked-up materials, and the trip charge.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How It Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Labor is hours times your rate.</strong> Simple multiplication, but the key is estimating hours accurately. Track your actual job times for a few months and you will build a personal database of how long things really take. Most new handymen underestimate by 25-50%.</p>
          <p><strong class="text-text-primary">Materials markup protects your time.</strong> That 20 minutes at Home Depot plus the drive is unbillable time. The markup compensates you for procurement. It also covers the risk of buying something that does not work and needing to make a return trip.</p>
          <p><strong class="text-text-primary">Trip charge sets your minimum.</strong> Without a trip charge or minimum, a 30-minute job across town costs you money after drive time and overhead. A $75-150 trip charge ensures every job is worth leaving the shop for.</p>
          <p><strong class="text-text-primary">Effective hourly rate is your real metric.</strong> The calculator shows your total price divided by estimated hours. This is what you are actually making per hour on the job. If it drops below your target rate, you need to raise the hours estimate, the rate, or both.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Quoting customers on the spot.</strong> A homeowner asks you to fix a few things while you are already there. Pull this up, plug in the job, and give them a price on the spot instead of saying you will follow up later. Speed in quoting wins jobs.</p>
          <p><strong class="text-text-primary">Building a task list price book.</strong> Run common jobs through the calculator to build your own price sheet. After you know that a standard faucet swap is always around $275, you can quote it instantly without even pulling out the calculator.</p>
          <p><strong class="text-text-primary">Checking profitability on past jobs.</strong> Plug in what you actually charged and the hours you actually worked. If your effective rate keeps coming in below your target, it is time to raise your prices or get faster at specific task types.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much should a handyman charge per hour?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most handymen charge between $75 and $150 per hour depending on the market, skill level, and job type. Major metros and specialized tasks push toward the higher end. When you factor in drive time, quoting time, and overhead, your effective hourly rate needs to be at least $75 to stay profitable as a solo operator. Many experienced handymen target $100-125/hr as their billable rate.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I charge a trip charge or minimum fee?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. A trip charge or minimum fee (typically $75-150) covers your drive time, vehicle costs, and the fixed overhead of showing up. Without it, small 30-minute jobs become money losers after you account for travel, quoting, and invoicing. Some handymen fold the trip charge into a minimum job price instead of listing it separately.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much should I mark up materials?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A standard materials markup for handyman work is 15-25%. This covers your time sourcing and picking up materials, fuel for supply runs, and the risk of buying the wrong item. Some handymen use a flat markup percentage while others charge materials at cost plus a separate supply run fee. Either way, never pass materials through at your cost — your time and vehicle have value.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I price a handyman job I have never done before?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Estimate the hours honestly, then add a 25-30% buffer for unknowns. Research material costs before quoting. If the job type is completely new to you, be upfront with the customer about providing a time-and-materials quote rather than a fixed price. As you complete more of those jobs, you will build a reference library of actual times that makes future bids more accurate.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  interface JobInputs {
    jobType: string;
    estimatedHours: number;
    hourlyRate: number;
    materialsCost: number;
    markupPercent: number;
    tripCharge: number;
  }

  function calculate(): void {
    const jobType = (document.getElementById('jobType') as HTMLSelectElement).value;
    const estimatedHours = parseFloat((document.getElementById('estimatedHours') as HTMLInputElement).value) || 2;
    const hourlyRate = parseFloat((document.getElementById('hourlyRate') as HTMLInputElement).value) || 100;
    const materialsCost = parseFloat((document.getElementById('materialsCost') as HTMLInputElement).value) || 0;
    const markupPercent = parseFloat((document.getElementById('markupPercent') as HTMLSelectElement).value) / 100;
    const tripCharge = parseFloat((document.getElementById('tripCharge') as HTMLInputElement).value) || 0;

    // Calculate components
    const laborCost = estimatedHours * hourlyRate;
    const markupAmount = materialsCost * markupPercent;
    const materialsWithMarkup = materialsCost + markupAmount;
    const totalPrice = laborCost + materialsWithMarkup + tripCharge;

    // Effective hourly rate (total divided by hours)
    const effectiveRate = totalPrice / estimatedHours;

    // Gross profit (total minus raw materials cost)
    const grossProfit = totalPrice - materialsCost;

    const fmt = (n: number): string => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });

    document.getElementById('result-labor')!.textContent = fmt(laborCost);
    document.getElementById('result-total')!.textContent = fmt(totalPrice);
    document.getElementById('result-materials')!.textContent = fmt(materialsWithMarkup);
    document.getElementById('result-effective')!.textContent = fmt(Math.round(effectiveRate));
    document.getElementById('result-trip')!.textContent = fmt(tripCharge);
    document.getElementById('result-markup')!.textContent = fmt(Math.round(markupAmount));
    document.getElementById('result-profit')!.textContent = fmt(Math.round(grossProfit));
  }

  document.querySelectorAll('#cost-calc select, #cost-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
