---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/handymanTools';

const tool = getToolBySlug('drywall-patch-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a drywall patch cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A typical drywall patch costs $75 to $300 depending on size and complexity. Small nail holes run $50-75, medium patches (up to 12 inches) cost $100-200, and large patches or texture-matched repairs can run $200-400. Material cost is usually under $20; the majority is labor."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to patch drywall?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A small drywall patch takes 1-2 hours of active work, but requires 24 hours of drying time between coats. A standard patch needs 3 coats of joint compound with sanding between each coat. Plan for 3 visits or one long day if using quick-set compound."
      }
    },
    {
      "@type": "Question",
      "name": "What materials do I need for a drywall patch?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For a standard drywall patch you need joint compound, mesh or paper tape, a drywall patch kit (for holes larger than 4 inches), sandpaper (120-150 grit), primer, and paint. For texture matching, add texture spray or a hopper gun. Total material cost is typically $10-25 per patch."
      }
    },
    {
      "@type": "Question",
      "name": "How do I match drywall texture?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Matching drywall texture requires identifying the existing pattern (orange peel, knockdown, or smooth), then replicating it on the patch. Orange peel uses a spray can or hopper gun. Knockdown applies texture then flattens it with a knife. Practice on cardboard first. Texture matching adds 30-60 minutes to the job."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="drywall-calc">
    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="patchWidth">Patch Width (inches)</label>
        <input type="number" id="patchWidth" value="12" min="1" max="120" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="patchHeight">Patch Height (inches)</label>
        <input type="number" id="patchHeight" value="12" min="1" max="120" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="surfaceType">Surface Type</label>
        <select id="surfaceType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="smooth">Smooth</option>
          <option value="orangepeel" selected>Orange Peel</option>
          <option value="knockdown">Knockdown</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="includesSanding">Includes Sanding & Priming</label>
        <select id="includesSanding" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="yes" selected>Yes</option>
          <option value="no">No</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="textureMatch">Texture Matching Required</label>
        <select id="textureMatch" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="yes">Yes</option>
          <option value="no" selected>No</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="hourlyRate">Hourly Rate ($)</label>
        <input type="number" id="hourlyRate" value="72.50" min="25" max="200" step="2.50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Material Cost</div>
          <div id="result-material" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Labor Hours</div>
          <div id="result-hours" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Cost</div>
          <div id="result-cost" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Customer Price</div>
          <div id="result-price" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
      </div>
      <p class="text-text-muted text-sm italic">Rates vary by region. Adjust your hourly rate as needed. Material costs based on national averages.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Measure the patch area.</strong> Measure the width and height of the damaged area in inches. For irregular shapes, measure the bounding rectangle.</p>
          <p><strong class="text-text-primary">2. Select the surface type.</strong> Smooth walls are fastest to repair. Orange peel and knockdown textures require additional matching work.</p>
          <p><strong class="text-text-primary">3. Set sanding and texture options.</strong> Most patches need sanding and priming before paint. Texture matching adds time but is essential for invisible repairs.</p>
          <p><strong class="text-text-primary">4. Adjust your hourly rate.</strong> The default $72.50 is the median handyman rate. Adjust for your market and experience level.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Drywall Patch Formula Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>The calculator converts your patch dimensions to square feet, then applies material costs for joint compound ($0.15/sqft for 3-coat coverage), sandpaper ($0.08/sqft), and primer ($0.12/sqft).</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Patch_Area = (Width x Height) / 144 sq ft</p>
            <p>Material = Area x ($0.15 + $0.08 + $0.12)</p>
            <p>Labor = 0.5 base + (Area x 0.25) + Texture_factor</p>
            <p>Total = Material + (Labor x Rate)</p>
            <p>Customer_Price = Total x 1.40 (40% markup)</p>
          </div>
          <p>Labor includes 0.5 hours base time for setup and cleanup, plus 0.25 hours per square foot for cutting, mudding, and sanding. Texture matching adds 0.5 hours.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does a drywall patch cost?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A typical drywall patch costs $75 to $300 depending on size and complexity. Small nail holes run $50-75, medium patches (up to 12 inches) cost $100-200, and large patches or texture-matched repairs can run $200-400. Material cost is usually under $20; the majority is labor.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How long does it take to patch drywall?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A small drywall patch takes 1-2 hours of active work, but requires 24 hours of drying time between coats. A standard patch needs 3 coats of joint compound with sanding between each coat. Plan for 3 visits or one long day if using quick-set compound.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What materials do I need for a drywall patch?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For a standard drywall patch you need joint compound, mesh or paper tape, a drywall patch kit (for holes larger than 4 inches), sandpaper (120-150 grit), primer, and paint. For texture matching, add texture spray or a hopper gun. Total material cost is typically $10-25 per patch.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I match drywall texture?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Matching drywall texture requires identifying the existing pattern (orange peel, knockdown, or smooth), then replicating it on the patch. Orange peel uses a spray can or hopper gun. Knockdown applies texture then flattens it with a knife. Practice on cardboard first. Texture matching adds 30-60 minutes to the job.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const width = parseFloat((document.getElementById('patchWidth') as HTMLInputElement).value) || 12;
    const height = parseFloat((document.getElementById('patchHeight') as HTMLInputElement).value) || 12;
    const surfaceType = (document.getElementById('surfaceType') as HTMLSelectElement).value;
    const includesSanding = (document.getElementById('includesSanding') as HTMLSelectElement).value;
    const textureMatch = (document.getElementById('textureMatch') as HTMLSelectElement).value;
    const hourlyRate = parseFloat((document.getElementById('hourlyRate') as HTMLInputElement).value) || 72.50;

    const patchAreaSqFt = (width * height) / 144;

    // Material costs per sqft
    const compoundCost = 0.15;
    const sandpaperCost = includesSanding === 'yes' ? 0.08 : 0;
    const primerCost = includesSanding === 'yes' ? 0.12 : 0;
    const materialCost = patchAreaSqFt * (compoundCost + sandpaperCost + primerCost);

    // Labor hours
    const baseHours = 0.5;
    const areaFactor = patchAreaSqFt * 0.25;
    const textureFactor = textureMatch === 'yes' ? 0.5 : 0;
    const laborHours = baseHours + areaFactor + textureFactor;

    const laborCost = laborHours * hourlyRate;
    const totalCost = materialCost + laborCost;
    const customerPrice = totalCost * 1.40;

    document.getElementById('result-material')!.textContent = '$' + materialCost.toFixed(2);
    document.getElementById('result-hours')!.textContent = laborHours.toFixed(1) + ' hrs';
    document.getElementById('result-cost')!.textContent = '$' + totalCost.toFixed(0);
    document.getElementById('result-price')!.textContent = '$' + customerPrice.toFixed(0);
  }

  document.querySelectorAll('#drywall-calc input, #drywall-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
