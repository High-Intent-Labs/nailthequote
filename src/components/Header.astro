---
import { getLiveTrades } from '../data/trades';

interface Props {
  currentPath?: string;
}
const { currentPath = '' } = Astro.props;
const liveTrades = getLiveTrades();
---

<nav class="flex justify-between items-center gap-6 px-6 md:px-12 py-5 max-w-[1280px] mx-auto">
  <a href="/" class="font-heading font-extrabold text-[26px] tracking-tight text-text-primary no-underline shrink-0">
    Nail<span class="text-accent">The</span>Quote
  </a>

  <!-- Mobile menu button -->
  <button id="mobile-menu-btn" class="md:hidden text-text-secondary p-2" aria-label="Toggle menu">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>

  <!-- Desktop nav -->
  <div class="hidden md:flex gap-8 items-center">
    {liveTrades.map(trade => (
      <a href={`/${trade.slug}/`} class:list={[
        "text-sm font-medium no-underline transition-colors",
        currentPath.startsWith(`/${trade.slug}`) ? 'text-text-primary' : 'text-text-secondary hover:text-text-primary'
      ]}>{trade.name} Tools</a>
    ))}
    <a href="/#trades" class="text-text-secondary text-sm font-medium no-underline hover:text-text-primary transition-colors">All Trades</a>
    <!-- Auth: swapped via JS based on login state -->
    <a href="/dashboard" id="header-dashboard-link" class="hidden items-center gap-2 text-sm font-medium text-text-primary no-underline hover:text-accent transition-colors">
      <span class="w-7 h-7 rounded-full bg-accent/20 flex items-center justify-center">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" class="text-accent">
          <path d="M10 10a4 4 0 100-8 4 4 0 000 8zm-7 8a7 7 0 0114 0H3z" fill="currentColor"/>
        </svg>
      </span>
      My Account
    </a>
    <button id="header-login-btn" type="button" class="text-sm font-medium text-accent hover:text-accent-hover transition-colors cursor-pointer">Log In</button>
  </div>
</nav>

<!-- Mobile nav -->
<div id="mobile-menu" class="hidden md:hidden px-6 pb-4">
  <div class="flex flex-col gap-4 border-t border-border pt-4">
    {liveTrades.map(trade => (
      <a href={`/${trade.slug}/`} class:list={[
        "text-sm font-medium no-underline",
        currentPath.startsWith(`/${trade.slug}`) ? 'text-text-primary' : 'text-text-secondary'
      ]}>{trade.name} Tools</a>
    ))}
    <a href="/#trades" class="text-text-secondary text-sm font-medium no-underline">All Trades</a>
    <a href="/dashboard" id="mobile-dashboard-link" class="hidden text-sm font-medium text-text-primary no-underline">Dashboard</a>
    <button id="mobile-login-btn" type="button" class="text-sm font-medium text-accent text-left cursor-pointer">Log In</button>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Auth state: show Dashboard link or Log In button
  const hasAccount = localStorage.getItem('ntq_has_account');
  const dashboardLink = document.getElementById('header-dashboard-link');
  const loginBtn = document.getElementById('header-login-btn');

  const mobileDashboard = document.getElementById('mobile-dashboard-link');
  const mobileLogin = document.getElementById('mobile-login-btn');

  if (hasAccount) {
    dashboardLink?.classList.remove('hidden');
    dashboardLink?.classList.add('flex');
    loginBtn?.classList.add('hidden');
    mobileDashboard?.classList.remove('hidden');
    mobileLogin?.classList.add('hidden');
  }

  loginBtn?.addEventListener('click', () => {
    (window as any).openSignupModal?.('direct');
  });
  mobileLogin?.addEventListener('click', () => {
    (window as any).openSignupModal?.('direct');
  });
</script>
